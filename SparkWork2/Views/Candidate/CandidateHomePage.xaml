<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Candidate.CandidateHomePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F8F6FF">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="32,34,32,24" Spacing="18">

                <!-- HEADER -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="lblGreeting"
                               Text="Bonjour"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label Text="Prêt à trouver ta prochaine opportunité ?"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#8B86A3"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <Frame Grid.Column="1"
                           WidthRequest="52"
                           HeightRequest="52"
                           CornerRadius="26"
                           Padding="0"
                           HasShadow="False">
                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>

                        <Label x:Name="lblInitials"
                               Text="A"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="17"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>
                </Grid>

                <!-- SEARCH -->
                <Frame CornerRadius="16"
                       Padding="14"
                       BackgroundColor="White"
                       BorderColor="#DED8F5"
                       HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Label Text="&#xE8B6;"
                               FontFamily="MaterialIcons"
                               FontSize="22"
                               TextColor="#8B86A3"
                               VerticalTextAlignment="Center" />

                        <Label Grid.Column="1"
                               Text="Rechercher un poste, une compétence..."
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#B0ABCE"
                               VerticalTextAlignment="Center"
                               LineBreakMode="TailTruncation" />

                        <Button Grid.Column="2"
                                Text="Filtres"
                                HeightRequest="40"
                                Padding="14,0"
                                BackgroundColor="#F0EAFE"
                                TextColor="#7C4DFF"
                                FontAttributes="Bold"
                                FontSize="14"
                                CornerRadius="14" />
                    </Grid>
                </Frame>

                <!-- TOP STATS -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Frame CornerRadius="18"
                           Padding="16"
                           BackgroundColor="White"
                           BorderColor="#DED8F5"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Compatibilité"
                                   FontSize="13"
                                   TextColor="#8581A6" />

                            <Label x:Name="lblCompatibilityValue"
                                   Text="--"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Label x:Name="lblCompatibilitySubtext"
                                   Text="meilleure offre récente"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#7C4DFF"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1"
                           CornerRadius="18"
                           Padding="16"
                           BackgroundColor="White"
                           BorderColor="#DED8F5"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Distance"
                                   FontSize="13"
                                   TextColor="#8581A6" />

                            <Label x:Name="lblDistanceValue"
                                   Text="--"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Label x:Name="lblDistanceSubtext"
                                   Text="préférence active"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#7C4DFF" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- RECOMMENDED -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Recommandé pour toi"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           VerticalTextAlignment="Center" />

                    <Button Grid.Column="1"
                            Text="Voir"
                            HeightRequest="34"
                            Padding="16,0"
                            BackgroundColor="#F0EAFE"
                            TextColor="#7C4DFF"
                            FontAttributes="Bold"
                            FontSize="14"
                            CornerRadius="14"
                            Clicked="BrowseJobOffers_Clicked" />
                </Grid>

                <Frame CornerRadius="20"
                       Padding="16"
                       BackgroundColor="White"
                       BorderColor="#DED8F5"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Frame WidthRequest="42"
                                   HeightRequest="42"
                                   CornerRadius="10"
                                   Padding="0"
                                   BackgroundColor="#17172A"
                                   HasShadow="False">
                                <Label x:Name="lblRecommendedLogo"
                                       Text="M"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <Label x:Name="lblRecommendedCompanyLocation"
                                   Grid.Column="1"
                                   Text="mcdo · Nivelles"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6"
                                   VerticalTextAlignment="Center"
                                   LineBreakMode="TailTruncation" />

                            <Label x:Name="lblRecommendedScore"
                                   Grid.Column="2"
                                   Text="100%"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#7C4DFF"
                                   VerticalTextAlignment="Center" />
                        </Grid>

                        <VerticalStackLayout Spacing="3">
                            <Label x:Name="lblRecommendedTitle"
                                   Text="Vendeur"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Label x:Name="lblRecommendedMeta"
                                   Text="Full-Time · Junior · Présentiel"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />
                        </VerticalStackLayout>

                        <FlexLayout x:Name="recommendedTagsLayout"
                                    Direction="Row"
                                    Wrap="Wrap"
                                    AlignItems="Center"
                                    JustifyContent="Start" />

                        <ProgressBar x:Name="recommendedCompatibilityProgress"
                                     Progress="1"
                                     ProgressColor="#D34C88"
                                     BackgroundColor="#EEEAF8"
                                     HeightRequest="6" />

                        <Frame HeightRequest="48"
                               CornerRadius="14"
                               Padding="0"
                               HasShadow="False">
                            <Frame.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C4DFF" Offset="0.0" />
                                    <GradientStop Color="#D34C88" Offset="1.0" />
                                </LinearGradientBrush>
                            </Frame.Background>

                            <Grid>
                                <HorizontalStackLayout Spacing="8"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center">
                                    <Label Text="&#xE8F4;"
                                           FontFamily="MaterialIcons"
                                           FontSize="20"
                                           TextColor="White" />
                                    <Label Text="Voir l'offre"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                </HorizontalStackLayout>

                                <Button x:Name="btnRecommendedOffer"
                                        BackgroundColor="Transparent"
                                        Text=""
                                        Clicked="RecommendedOffer_Clicked" />
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- NEARBY OFFERS -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Offres près de toi"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           VerticalTextAlignment="Center" />

                    <Button Grid.Column="1"
                            Text="Tout voir"
                            HeightRequest="34"
                            Padding="16,0"
                            BackgroundColor="#F0EAFE"
                            TextColor="#7C4DFF"
                            FontAttributes="Bold"
                            FontSize="14"
                            CornerRadius="14"
                            Clicked="BrowseJobOffers_Clicked" />
                </Grid>

                <VerticalStackLayout x:Name="nearbyOffersLayout" Spacing="12" />

                <Label x:Name="lblNoNearbyOffers"
                       Text="Aucune offre proche pour le moment."
                       FontSize="13"
                       TextColor="#8B86A3"
                       IsVisible="False" />

                <!-- ACTIVITY -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,-4">
                    <Label Text="Votre activité"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           VerticalTextAlignment="Center" />

                    <Frame Grid.Column="1"
                           Padding="14,6"
                           CornerRadius="14"
                           BackgroundColor="#F0EAFE"
                           HasShadow="False">
                        <Label Text="Cette semaine"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#7C4DFF" />
                    </Frame>
                </Grid>

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                    <Frame CornerRadius="16" Padding="14" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="lblViewedOffersCount" Text="--" FontSize="24" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Offres vues" FontSize="13" FontAttributes="Bold" TextColor="#8581A6" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1" CornerRadius="16" Padding="14" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="lblLikedOffersCount" Text="--" FontSize="24" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Postulations" FontSize="13" FontAttributes="Bold" TextColor="#8581A6" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" CornerRadius="16" Padding="14" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="lblMatchesCount" Text="--" FontSize="24" FontAttributes="Bold" TextColor="#D34C88" />
                            <Label Text="Matchs" FontSize="13" FontAttributes="Bold" TextColor="#8581A6" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" Grid.Column="1" CornerRadius="16" Padding="14" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="lblProfileCompletion" Text="--" FontSize="24" FontAttributes="Bold" TextColor="#7C4DFF" />
                            <Label Text="Profil complété" FontSize="13" FontAttributes="Bold" TextColor="#8581A6" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- ADVICE -->
                <Frame CornerRadius="22"
                       Padding="20"
                       BackgroundColor="#F7EFFF"
                       BorderColor="#D8B4FE"
                       HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Frame WidthRequest="44"
                               HeightRequest="44"
                               CornerRadius="14"
                               Padding="0"
                               BackgroundColor="White"
                               HasShadow="False">
                            <Label Text="&#xE90F;"
                                   FontFamily="MaterialIcons"
                                   FontSize="22"
                                   TextColor="#D97706"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label x:Name="lblAdviceTitle"
                                   Text="Complétez votre profil"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Label x:Name="lblAdviceText"
                                   Text="Ajoutez vos expériences et votre CV pour augmenter votre compatibilité avec les offres recruteurs."
                                   FontSize="15"
                                   TextColor="#4B2FBF"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <!-- BOTTOM NAV -->
        <Grid Grid.Row="1"
              BackgroundColor="White"
              Padding="18,8,18,18"
              ColumnDefinitions="*,*,*,*">

            <Grid Grid.Column="0">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="&#xE88A;" FontFamily="MaterialIcons" FontSize="25" TextColor="#7C4DFF" HorizontalTextAlignment="Center" />
                    <Label Text="Accueil" FontSize="11" FontAttributes="Bold" TextColor="#7C4DFF" HorizontalTextAlignment="Center" />
                    <BoxView WidthRequest="4" HeightRequest="4" CornerRadius="2" Color="#7C4DFF" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>

            <Grid Grid.Column="1">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="&#xE8B6;" FontFamily="MaterialIcons" FontSize="25" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                    <Label Text="Découvrir" FontSize="11" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <Button BackgroundColor="Transparent" Text="" Clicked="BrowseJobOffers_Clicked" />
            </Grid>

            <Grid Grid.Column="2">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="&#xE0BF;" FontFamily="MaterialIcons" FontSize="25" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                    <Label Text="Messages" FontSize="11" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <Button BackgroundColor="Transparent" Text="" Clicked="Messages_Clicked" />
            </Grid>

            <Grid Grid.Column="3">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="&#xE7FD;" FontFamily="MaterialIcons" FontSize="25" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                    <Label Text="Profil" FontSize="11" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <Button BackgroundColor="Transparent" Text="" Clicked="CandidateProfile_Clicked" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
