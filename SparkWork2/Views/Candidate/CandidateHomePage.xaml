<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Candidate.CandidateHomePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,28,24,24" Spacing="20">

                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="lblGreeting"
                               Text="Bonjour"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label Text="Prêt à trouver ta prochaine opportunité ?"
                               FontSize="13"
                               TextColor="#8B86A3" />
                    </VerticalStackLayout>

                    <Frame Grid.Column="1"
                           WidthRequest="52"
                           HeightRequest="52"
                           CornerRadius="26"
                           Padding="0"
                           HasShadow="False">
                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>

                        <Label x:Name="lblInitials"
                               Text="ME"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="16"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>
                </Grid>

                <Frame CornerRadius="18"
                       Padding="14"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Text="⌕"
                               FontSize="18"
                               TextColor="#8B86A3"
                               VerticalTextAlignment="Center" />

                        <Label Grid.Column="1"
                               Text="Rechercher un poste, une compétence..."
                               FontSize="13"
                               TextColor="#A6A0C0"
                               VerticalTextAlignment="Center" />

                        <Button Grid.Column="2"
                                Text="Filtres"
                                HeightRequest="36"
                                Padding="12,0"
                                BackgroundColor="#F0EAFE"
                                TextColor="#7C4DFF"
                                FontAttributes="Bold"
                                FontSize="12"
                                CornerRadius="12" />
                    </Grid>
                </Frame>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Frame CornerRadius="18" Padding="16" BackgroundColor="White" BorderColor="#EEEAF8" HasShadow="False">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Compatibilité"
                                   FontSize="13"
                                   TextColor="#8581A6" />
                            <Label x:Name="lblCompatibilityValue"
                                   Text="--"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Label x:Name="lblCompatibilitySubtext"
                                   Text="calcul en cours"
                                   FontSize="11"
                                   TextColor="#10B981" />

                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1" CornerRadius="18" Padding="16" BackgroundColor="White" BorderColor="#EEEAF8" HasShadow="False">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Distance"
                                   FontSize="13"
                                   TextColor="#8581A6" />
                            <Label x:Name="lblDistanceValue"
                                   Text="--"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Label x:Name="lblDistanceSubtext"
                                   Text="préférence active"
                                   FontSize="11"
                                   TextColor="#7C4DFF" />

                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Frame CornerRadius="24"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Recommandé pour toi"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />

                                <Label Text="Offres horeca selon ton profil"
                                       FontSize="12"
                                       TextColor="#8B86A3" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="Voir"
                                    HeightRequest="34"
                                    Padding="14,0"
                                    BackgroundColor="#7C4DFF"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    CornerRadius="12"
                                    Clicked="BrowseJobOffers_Clicked" />
                        </Grid>

                        <Frame CornerRadius="18"
                               Padding="14"
                               BackgroundColor="#FAF9FF"
                               BorderColor="#EEEAF8"
                               HasShadow="False">

                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label x:Name="lblRecommendedTitle"
                                           Text="Recherche en cours..."
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />

                                    <Label x:Name="lblRecommendedScore"
                                           Grid.Column="1"
                                           Text="--"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#10B981" />
                                </Grid>

                                <Label x:Name="lblRecommendedMeta"
                                       Text="Analyse de ton profil"
                                       FontSize="13"
                                       TextColor="#5F5A75" />

                                <FlexLayout x:Name="recommendedSkillsLayout"
                            Direction="Row"
                            Wrap="Wrap"
                            AlignItems="Center"
                            JustifyContent="Start" />
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>


                <Frame CornerRadius="24"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Votre activité"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />

                                <Label Text="Résumé de vos opportunités"
                                       FontSize="12"
                                       TextColor="#8B86A3" />
                            </VerticalStackLayout>

                            <Label Grid.Column="1"
                                   Text="Cette semaine"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#7C4DFF"
                                   VerticalTextAlignment="Center" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                            <Frame CornerRadius="16"
                                   Padding="14"
                                   BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   HasShadow="False">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Offres vues"
                                           FontSize="12"
                                           TextColor="#8581A6" />
                                    <Label x:Name="lblViewedOffersCount"
                                           Text="--"
                                           FontSize="22"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                </VerticalStackLayout>
                            </Frame>

                            <Frame Grid.Column="1"
                                   CornerRadius="16"
                                   Padding="14"
                                   BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   HasShadow="False">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Postulations"
                                           FontSize="12"
                                           TextColor="#8581A6" />
                                    <Label x:Name="lblLikedOffersCount"
                                           Text="--"
                                           FontSize="22"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                </VerticalStackLayout>
                            </Frame>

                            <Frame Grid.Row="1"
                                   CornerRadius="16"
                                   Padding="14"
                                   BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   HasShadow="False">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Matches"
                                           FontSize="12"
                                           TextColor="#8581A6" />
                                    <Label x:Name="lblMatchesCount"
                                           Text="--"
                                           FontSize="22"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                </VerticalStackLayout>
                            </Frame>

                            <Frame Grid.Row="1"
                                   Grid.Column="1"
                                   CornerRadius="16"
                                   Padding="14"
                                   BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   HasShadow="False">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Profil"
                                           FontSize="12"
                                           TextColor="#8581A6" />
                                    <Label x:Name="lblProfileCompletion"
                                           Text="--"
                                           FontSize="22"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                </VerticalStackLayout>
                            </Frame>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              BackgroundColor="White"
              Padding="18,8,18,18"
              ColumnDefinitions="*,*,*,*">

            <Button Text="Accueil"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#7C4DFF" />

            <Button Grid.Column="1"
                    Text="Découvrir"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="BrowseJobOffers_Clicked" />

            <Button Grid.Column="2"
                    Text="Messages"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Messages_Clicked" />

            <Button Grid.Column="3"
                    Text="Profil"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="CandidateProfile_Clicked" />
        </Grid>
    </Grid>
</ContentPage>
