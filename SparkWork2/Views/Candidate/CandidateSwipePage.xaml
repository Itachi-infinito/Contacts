<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Candidate.CandidateSwipePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">


    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="20,24,20,8"
              RowDefinitions="Auto,Auto"
              RowSpacing="14"
              ColumnDefinitions="*,Auto">

            <VerticalStackLayout Spacing="4">
                <Label Text="Découvrir"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#111827" />

                <Label Text="Offres horeca recommandées pour vous"
                       FontSize="13"
                       TextColor="#8B86A3" />
            </VerticalStackLayout>

            <Frame Grid.Column="1"
                   HeightRequest="52"
                   WidthRequest="52"
                   CornerRadius="26"
                   Padding="0"
                   HasShadow="False"
                   VerticalOptions="Center">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Profile_Tapped" />
                </Frame.GestureRecognizers>

                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label Text="ME"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="16"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>

            <HorizontalStackLayout Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   Spacing="10">
                <Frame BackgroundColor="#7C4DFF"
                       CornerRadius="16"
                       Padding="14,7"
                       HasShadow="False">
                    <Label Text="Pour vous"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="White" />
                </Frame>

                <Frame BackgroundColor="#F5F3FF"
                       CornerRadius="16"
                       Padding="14,7"
                       HasShadow="False">
                    <Label Text="Récents"
                           FontSize="12"
                           TextColor="#5F5A75" />
                </Frame>

                <Frame BackgroundColor="#F5F3FF"
                       CornerRadius="16"
                       Padding="14,7"
                       HasShadow="False">
                    <Label Text="À proximité"
                           FontSize="12"
                           TextColor="#5F5A75" />
                </Frame>
            </HorizontalStackLayout>
        </Grid>



        <!-- CARD AREA -->
        <Grid Grid.Row="1">

            <ScrollView x:Name="cardScrollView"
                        Padding="0,64,0,0">

                <VerticalStackLayout Spacing="16"
                                     HorizontalOptions="Center">

                    <Frame x:Name="jobCard"
                           WidthRequest="320"
                           BackgroundColor="White"
                           CornerRadius="24"
                           Padding="0"
                           HasShadow="True"
                           IsClippedToBounds="True">

                        <Frame.Shadow>
                            <Shadow Brush="#25A78BFA"
                                    Offset="0,18"
                                    Radius="32"
                                    Opacity="1" />
                        </Frame.Shadow>

                        <Frame.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="Card_PanUpdated" />
                        </Frame.GestureRecognizers>

                        <Grid RowDefinitions="220,Auto,Auto">

                            <!-- IMAGE -->
                            <Grid Grid.Row="0">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="Image_Tapped" />
                                </Grid.GestureRecognizers>

                                <Frame CornerRadius="0"
                                       Padding="0"
                                       HasShadow="False"
                                       IsClippedToBounds="True">

                                    <Grid>
                                        <Image x:Name="imgJob"
                                               Source="horeca_default.jpg"
                                               Aspect="AspectFill"
                                               Opacity="1"
                                               IsVisible="True" />

                                        <BoxView BackgroundColor="#12000000" />
                                        <Frame Padding="10,6"
                                               BackgroundColor="White"
                                               CornerRadius="12"
                                               HasShadow="False"
                                               Margin="16,16,0,0"
                                               HorizontalOptions="Start"
                                               VerticalOptions="Start"
                                               Opacity="{Binding Source={x:Reference lblLikeOverlay}, Path=Opacity}">
                                            <Label x:Name="lblLikeOverlay"
                                                   Text="LIKE"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="#10B981"
                                                   Opacity="0" />
                                        </Frame>

                                        <Frame Padding="10,6"
                                               BackgroundColor="White"
                                               CornerRadius="12"
                                               HasShadow="False"
                                               Margin="0,16,16,0"
                                               HorizontalOptions="End"
                                               VerticalOptions="Start"
                                               Opacity="{Binding Source={x:Reference lblNopeOverlay}, Path=Opacity}">
                                            <Label x:Name="lblNopeOverlay"
                                                   Text="SKIP"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="#EF4444"
                                                   Opacity="0" />
                                        </Frame>


                                        <Frame x:Name="compatibilityBadge"
                                               BackgroundColor="#7C4DFF"
                                               CornerRadius="18"
                                               Padding="12,8"
                                               HasShadow="True"
                                               Margin="0,14,14,0"
                                               HorizontalOptions="End"
                                               VerticalOptions="Start"
                                               IsVisible="False">

                                            <Label x:Name="lblCompatibility"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   HorizontalTextAlignment="Center" />
                                        </Frame>

                                        <Button x:Name="btnImageExpandCollapse"
                                                Text="Détails"
                                                HeightRequest="34"
                                                Padding="14,0"
                                                BackgroundColor="White"
                                                TextColor="#7C4DFF"
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                CornerRadius="14"
                                                Margin="0,0,14,14"
                                                HorizontalOptions="End"
                                                VerticalOptions="End"
                                                Clicked="ToggleDetails_Clicked" />
                                    </Grid>
                                </Frame>
                            </Grid>



                            <!-- MAIN INFO -->
                            <VerticalStackLayout x:Name="offerInfoSection"
                                                 Grid.Row="1"
                                                 Padding="18,16,18,18"
                                                 Spacing="13">

                                <Grid ColumnDefinitions="Auto,*,Auto"
                                        ColumnSpacing="12">

                                    <Frame WidthRequest="52"
                                           HeightRequest="52"
                                           CornerRadius="14"
                                           Padding="0"
                                           BackgroundColor="#111827"
                                           HasShadow="False">

                                        <Label x:Name="lblCompanyLogoInitials"
                                               Text="SW"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="White"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Frame>

                                    <VerticalStackLayout Grid.Column="1"
                                                        Spacing="3"
                                                        VerticalOptions="Center">

                                        <Label x:Name="lblTitle"
                                               FontSize="21"
                                               FontAttributes="Bold"
                                               TextColor="#111827"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />

                                        <Label x:Name="lblCompany"
                                               FontSize="14"
                                               TextColor="#7C4DFF"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />
                                    </VerticalStackLayout>

                                    <Frame Grid.Column="2"
                                           x:Name="contractTypeBadge"
                                           BackgroundColor="#ECFDF5"
                                           CornerRadius="13"
                                           Padding="10,4"
                                           HasShadow="False"
                                           VerticalOptions="Center">

                                        <Label x:Name="lblContractType"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="#10B981" />
                                    </Frame>
                                </Grid>

                                <FlexLayout Direction="Row"
                                            Wrap="Wrap"
                                            AlignItems="Center"
                                            JustifyContent="Start">

                                    <Label Text="📍"
                                           FontSize="13"
                                           Margin="0,0,4,8" />

                                    <Label x:Name="lblLocation"
                                           FontSize="13"
                                           TextColor="#5F5A75"
                                           Margin="0,0,14,8" />

                                    <Label Text="↔"
                                           FontSize="13"
                                           Margin="0,0,4,8" />

                                    <Label x:Name="lblDistance"
                                           FontSize="13"
                                           TextColor="#5F5A75"
                                           Margin="0,0,14,8"
                                           IsVisible="False" />

                                    <Label Text="💶"
                                           FontSize="13"
                                           Margin="0,0,4,8" />

                                    <Label x:Name="lblSalary"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#111827"
                                           Margin="0,0,14,8"
                                           IsVisible="False" />
                                </FlexLayout>
                                <FlexLayout Direction="Row"
                                            Wrap="Wrap"
                                            AlignItems="Center"
                                            JustifyContent="Start">

                                    <Frame x:Name="levelBadge"
                                           BackgroundColor="#F0EAFE"
                                           CornerRadius="12"
                                           Padding="9,3"
                                           Margin="0,0,8,8"
                                           HasShadow="False"
                                           IsVisible="False">
                                        <Label x:Name="lblLevel"
                                               FontSize="11"
                                               TextColor="#7C4DFF" />
                                    </Frame>

                                    <Frame x:Name="remoteBadge"
                                           BackgroundColor="#F0EAFE"
                                           CornerRadius="12"
                                           Padding="9,3"
                                           Margin="0,0,8,8"
                                           HasShadow="False"
                                           IsVisible="False">
                                        <Label x:Name="lblRemoteMode"
                                               FontSize="11"
                                               TextColor="#7C4DFF" />
                                    </Frame>
                                </FlexLayout>


                                <Label x:Name="lblShortDescription"
                                       FontSize="13"
                                       TextColor="#5F5A75"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2" />

                                <Frame x:Name="skillsPreviewCard"
                                        BackgroundColor="#FAF9FF"
                                       BorderColor="#EEEAF8"
                                       CornerRadius="16"
                                       Padding="12"
                                       HasShadow="False"
                                       IsVisible="False">

                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="Compétences principales"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="#8581A6" />

                                        <Label x:Name="lblSkillsPreview"
                                               FontSize="13"
                                               TextColor="#5F5A75"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                    </VerticalStackLayout>
                                </Frame>
                            </VerticalStackLayout>




                            <!-- EXPANDED DETAILS -->
                            <VerticalStackLayout x:Name="expandedDetailsSection"
                                                 Grid.Row="2"
                                                 IsVisible="False"
                                                 Opacity="0"
                                                 Padding="20,0,20,22"
                                                 Spacing="8">

                                <BoxView HeightRequest="1"
                                         Color="#EEEAF8" />

                                <Label Text="Détails de l'offre"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />

                                <Label x:Name="lblDetailCompany"
                                       TextColor="#374151" />

                                <Label x:Name="lblDetailLocation"
                                       TextColor="#374151" />

                                <Label x:Name="lblDetailContractType"
                                       TextColor="#374151" />

                                <Label x:Name="lblDetailSalary"
                                       TextColor="#374151"
                                       IsVisible="False" />

                                <Label x:Name="lblDetailLevel"
                                       TextColor="#374151"
                                       IsVisible="False" />

                                <Label x:Name="lblDetailRemoteMode"
                                       TextColor="#374151"
                                       IsVisible="False" />

                                <VerticalStackLayout x:Name="requiredSkillsDetailSection"
                                                     Spacing="6"
                                                     IsVisible="False">

                                    <Label Text="Compétences obligatoires"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />

                                    <Label x:Name="lblDetailRequiredSkills"
                                           FontSize="13"
                                           LineBreakMode="WordWrap"
                                           TextColor="#5F5A75" />
                                </VerticalStackLayout>

                                <VerticalStackLayout x:Name="niceSkillsDetailSection"
                                                     Spacing="6"
                                                     IsVisible="False">

                                    <Label Text="Compétences bonus"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />

                                    <Label x:Name="lblDetailNiceToHaveSkills"
                                           FontSize="13"
                                           LineBreakMode="WordWrap"
                                           TextColor="#5F5A75" />
                                </VerticalStackLayout>

                                <VerticalStackLayout x:Name="descriptionSection"
                                                     Spacing="6">

                                    <Label Text="Description"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />

                                    <Label x:Name="lblDescription"
                                           FontSize="13"
                                           LineBreakMode="WordWrap"
                                           TextColor="#5F5A75" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                    <Frame x:Name="matchTipCard"
                           WidthRequest="326"
                           BackgroundColor="#FAF9FF"
                           BorderColor="#EEEAF8"
                           CornerRadius="18"
                           Padding="14"
                           HasShadow="False"
                           IsVisible="False">

                        <Grid ColumnDefinitions="Auto,*,Auto"
                             ColumnSpacing="12">

                            <Label Text="✦"
                                   FontSize="22"
                                   TextColor="#7C4DFF"
                                   VerticalTextAlignment="Center" />

                            <VerticalStackLayout Grid.Column="1"
                                                Spacing="2">

                                <Label Text="Astuce match"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#7C4DFF" />

                                <Label x:Name="lblMatchTip"
                                       FontSize="13"
                                       TextColor="#5F5A75"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="›"
                                   FontSize="24"
                                   TextColor="#7C4DFF"
                                   VerticalTextAlignment="Center" />
                        </Grid>
                    </Frame>


                    <Label x:Name="lblSwipeHint"
                           Text="← Passer    •    Liker →"
                           FontSize="12"
                           TextColor="#8B86A3"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </ScrollView>

            <!-- EMPTY STATE -->
            <VerticalStackLayout x:Name="emptyStateSection"
                                 IsVisible="False"
                                 Spacing="14"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">

                <Label x:Name="lblEmptyMessage"
                       Text="No more opportunities right now."
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center" />

                <Button x:Name="btnRefreshJobs"
                        Text="Refresh"
                        HeightRequest="42"
                        WidthRequest="136"
                        BackgroundColor="#7C4DFF"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        Clicked="Reload_Clicked" />
            </VerticalStackLayout>
        </Grid>

        <!-- ACTIONS -->
        <Grid x:Name="actionsGrid"
                Grid.Row="2"
                ColumnDefinitions="*,*"
                ColumnSpacing="12"
                Padding="34,0,34,14">

            <Button Text="Passer"
                    HeightRequest="50"
                    BackgroundColor="White"
                    BorderColor="#DED8F5"
                    BorderWidth="1"
                    TextColor="#111827"
                    FontAttributes="Bold"
                    CornerRadius="16"
                    Clicked="Reject_Clicked" />

            <Button Grid.Column="1"
                    Text="Postuler"
                    HeightRequest="50"
                    BackgroundColor="#7C4DFF"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="16"
                    Clicked="Like_Clicked" />
        </Grid>

        <!-- BOTTOM NAV -->
        <Grid Grid.Row="3"
              BackgroundColor="White"
              Padding="18,8,18,18"
              ColumnDefinitions="*,*,*,*">

            <Button Text="Accueil"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Home_Clicked" />

            <Button Grid.Column="1"
                    Text="Découvrir"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#7C4DFF" />

            <Button Grid.Column="2"
                    Text="Messages"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Messages_Button_Clicked" />

            <Button Grid.Column="3"
                    Text="Profil"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Profile_Button_Clicked" />
        </Grid>

    </Grid>
</ContentPage>
