<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Candidate.CandidateSwipePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="28,26,28,0"
              RowDefinitions="Auto,Auto"
              ColumnDefinitions="*,Auto">

            <Label Text="SparkWork"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#7C4DFF"
                   VerticalOptions="Center" />

            <ImageButton x:Name="btnHeaderExpandCollapse"
                         Grid.Column="1"
                         Source="arrow_down.png"
                         IsVisible="False"
                         BackgroundColor="Transparent"
                         Clicked="ToggleDetails_Clicked" />

            <Frame Grid.Column="1"
                   HeightRequest="54"
                   WidthRequest="54"
                   CornerRadius="27"
                   Padding="0"
                   HasShadow="False"
                   HorizontalOptions="End"
                   VerticalOptions="Center">

                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Profile_Tapped" />
                </Frame.GestureRecognizers>

                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label Text="ME"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="16"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>

            <Grid Grid.Row="1"
                  Grid.ColumnSpan="2"
                  ColumnDefinitions="*,*,*"
                  Margin="0,24,0,0"
                  HeightRequest="42">

                <Label Text="DÉCOUVRIR"
                       Grid.Column="0"
                       FontSize="15"
                       TextColor="#7C4DFF"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Discover_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="MESSAGES"
                       Grid.Column="1"
                       FontSize="15"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Messages_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="STATS"
                       Grid.Column="2"
                       FontSize="15"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Stats_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <BoxView Grid.Column="0"
                         HeightRequest="3"
                         Color="#7C4DFF"
                         VerticalOptions="End"
                         Margin="14,0,14,0" />
            </Grid>
        </Grid>

        <!-- CARD AREA -->
        <Grid Grid.Row="1">

            <ScrollView x:Name="cardScrollView"
                        Padding="0,64,0,0">

                <VerticalStackLayout Spacing="16"
                                     HorizontalOptions="Center">

                    <Frame x:Name="jobCard"
                           WidthRequest="320"
                           BackgroundColor="White"
                           CornerRadius="24"
                           Padding="0"
                           HasShadow="True"
                           IsClippedToBounds="True">

                        <Frame.Shadow>
                            <Shadow Brush="#25A78BFA"
                                    Offset="0,18"
                                    Radius="32"
                                    Opacity="1" />
                        </Frame.Shadow>

                        <Frame.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="Card_PanUpdated" />
                        </Frame.GestureRecognizers>

                        <Grid RowDefinitions="220,Auto,Auto">

                            <!-- IMAGE -->
                            <Grid Grid.Row="0">
                                <Frame CornerRadius="0"
                                       Padding="0"
                                       HasShadow="False"
                                       IsClippedToBounds="True">

                                    <Frame.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#C4B5FD" Offset="0.0" />
                                            <GradientStop Color="#A78BFA" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Frame.Background>

                                    <Grid>
                                        <Image x:Name="imgJob"
                                               Aspect="AspectFill"
                                               Opacity="0"
                                               IsVisible="False" />

                                        <Grid x:Name="jobPlaceholderIllustration">

                                            <Ellipse WidthRequest="130"
                                                     HeightRequest="130"
                                                     Fill="#7C4DFF"
                                                     Opacity="0.22"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     Margin="0,-18,0,0" />

                                            <Ellipse WidthRequest="78"
                                                     HeightRequest="78"
                                                     Fill="#FFFFFF"
                                                     Opacity="0.92"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     Margin="0,-76,0,0" />

                                            <Ellipse WidthRequest="52"
                                                     HeightRequest="52"
                                                     Fill="#7C4DFF"
                                                     Opacity="0.75"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     Margin="0,-76,0,0" />

                                            <Ellipse WidthRequest="172"
                                                     HeightRequest="70"
                                                     Fill="#8B5CF6"
                                                     Opacity="0.22"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="End"
                                                     Margin="0,0,0,36" />

                                            <Ellipse WidthRequest="116"
                                                     HeightRequest="46"
                                                     Fill="#FFFFFF"
                                                     Opacity="0.22"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="End"
                                                     Margin="0,0,0,42" />
                                        </Grid>
                                    </Grid>
                                </Frame>

                                <Frame Padding="10,6"
                                       BackgroundColor="White"
                                       CornerRadius="12"
                                       HasShadow="False"
                                       Margin="18,18,0,0"
                                       HorizontalOptions="Start"
                                       VerticalOptions="Start"
                                       Opacity="{Binding Source={x:Reference lblLikeOverlay}, Path=Opacity}">

                                    <Label x:Name="lblLikeOverlay"
                                           Text="LIKE"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#10B981"
                                           Opacity="0" />
                                </Frame>

                                <Frame Padding="10,6"
                                       BackgroundColor="White"
                                       CornerRadius="12"
                                       HasShadow="False"
                                       Margin="0,18,18,0"
                                       HorizontalOptions="End"
                                       VerticalOptions="Start"
                                       Opacity="{Binding Source={x:Reference lblNopeOverlay}, Path=Opacity}">

                                    <Label x:Name="lblNopeOverlay"
                                           Text="SKIP"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#EF4444"
                                           Opacity="0" />
                                </Frame>

                                <ImageButton x:Name="btnImageExpandCollapse"
                                             Source="arrow_down.png"
                                             HeightRequest="28"
                                             WidthRequest="28"
                                             BackgroundColor="Transparent"
                                             Margin="0,0,16,16"
                                             HorizontalOptions="End"
                                             VerticalOptions="End"
                                             Clicked="ToggleDetails_Clicked" />
                            </Grid>

                            <!-- MAIN INFO -->
                            <VerticalStackLayout x:Name="offerInfoSection"
                                                 Grid.Row="1"
                                                 Padding="20,16,20,24"
                                                 Spacing="7">

                                <Label x:Name="lblTitle"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#111827"
                                       LineBreakMode="WordWrap" />

                                <Label x:Name="lblCompany"
                                       FontSize="14"
                                       TextColor="#7C4DFF" />

                                <Label x:Name="lblLocation"
                                       FontSize="13"
                                       TextColor="#7D7898" />

                                <Label x:Name="lblSalary"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#111827"
                                       IsVisible="False" />
                                <Frame x:Name="compatibilityBadge"
                                       BackgroundColor="#F0EAFE"
                                       CornerRadius="14"
                                       Padding="10,5"
                                       HasShadow="False"
                                       HorizontalOptions="Start"
                                       IsVisible="False">

                                    <Label x:Name="lblCompatibility"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#7C4DFF" />
                                </Frame>


                                <FlexLayout Direction="Row"
                                            Wrap="Wrap"
                                            AlignItems="Center"
                                            JustifyContent="Start">

                                    <Frame x:Name="contractTypeBadge"
                                           BackgroundColor="#F0EAFE"
                                           CornerRadius="12"
                                           Padding="9,3"
                                           Margin="0,0,8,8"
                                           HasShadow="False">
                                        <Label x:Name="lblContractType"
                                               FontSize="11"
                                               TextColor="#7C4DFF" />
                                    </Frame>

                                    <Frame x:Name="levelBadge"
                                           BackgroundColor="#F0EAFE"
                                           CornerRadius="12"
                                           Padding="9,3"
                                           Margin="0,0,8,8"
                                           HasShadow="False"
                                           IsVisible="False">
                                        <Label x:Name="lblLevel"
                                               FontSize="11"
                                               TextColor="#7C4DFF" />
                                    </Frame>

                                    <Frame x:Name="remoteBadge"
                                           BackgroundColor="#F0EAFE"
                                           CornerRadius="12"
                                           Padding="9,3"
                                           Margin="0,0,8,8"
                                           HasShadow="False"
                                           IsVisible="False">
                                        <Label x:Name="lblRemoteMode"
                                               FontSize="11"
                                               TextColor="#7C4DFF" />
                                    </Frame>
                                </FlexLayout>

                                <Frame x:Name="skillsPreviewCard"
                                       BackgroundColor="#FAF9FF"
                                       BorderColor="#EEEAF8"
                                       CornerRadius="16"
                                       Padding="12"
                                       HasShadow="False"
                                       IsVisible="False">

                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="Compétences"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="#8581A6" />

                                        <Label x:Name="lblSkillsPreview"
                                               FontSize="13"
                                               TextColor="#5F5A75"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                    </VerticalStackLayout>
                                </Frame>
                            </VerticalStackLayout>

                            <!-- EXPANDED DETAILS -->
                            <VerticalStackLayout x:Name="expandedDetailsSection"
                                                 Grid.Row="2"
                                                 IsVisible="False"
                                                 Opacity="0"
                                                 Padding="20,0,20,22"
                                                 Spacing="8">

                                <BoxView HeightRequest="1"
                                         Color="#EEEAF8" />

                                <Label Text="Détails de l'offre"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />

                                <Label x:Name="lblDetailCompany"
                                       TextColor="#374151" />

                                <Label x:Name="lblDetailLocation"
                                       TextColor="#374151" />

                                <Label x:Name="lblDetailContractType"
                                       TextColor="#374151" />

                                <Label x:Name="lblDetailSalary"
                                       TextColor="#374151"
                                       IsVisible="False" />

                                <Label x:Name="lblDetailLevel"
                                       TextColor="#374151"
                                       IsVisible="False" />

                                <Label x:Name="lblDetailRemoteMode"
                                       TextColor="#374151"
                                       IsVisible="False" />

                                <VerticalStackLayout x:Name="requiredSkillsDetailSection"
                                                     Spacing="6"
                                                     IsVisible="False">

                                    <Label Text="Compétences obligatoires"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />

                                    <Label x:Name="lblDetailRequiredSkills"
                                           FontSize="13"
                                           LineBreakMode="WordWrap"
                                           TextColor="#5F5A75" />
                                </VerticalStackLayout>

                                <VerticalStackLayout x:Name="niceSkillsDetailSection"
                                                     Spacing="6"
                                                     IsVisible="False">

                                    <Label Text="Compétences bonus"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />

                                    <Label x:Name="lblDetailNiceToHaveSkills"
                                           FontSize="13"
                                           LineBreakMode="WordWrap"
                                           TextColor="#5F5A75" />
                                </VerticalStackLayout>

                                <VerticalStackLayout x:Name="descriptionSection"
                                                     Spacing="6">

                                    <Label Text="Description"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />

                                    <Label x:Name="lblDescription"
                                           FontSize="13"
                                           LineBreakMode="WordWrap"
                                           TextColor="#5F5A75" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>

                    <Label x:Name="lblSwipeHint"
                           Text="← Passer    •    Liker →"
                           FontSize="12"
                           TextColor="#8B86A3"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </ScrollView>

            <!-- EMPTY STATE -->
            <VerticalStackLayout x:Name="emptyStateSection"
                                 IsVisible="False"
                                 Spacing="14"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">

                <Label x:Name="lblEmptyMessage"
                       Text="No more opportunities right now."
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center" />

                <Button x:Name="btnRefreshJobs"
                        Text="Refresh"
                        HeightRequest="42"
                        WidthRequest="136"
                        BackgroundColor="#7C4DFF"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        Clicked="Reload_Clicked" />
            </VerticalStackLayout>
        </Grid>

        <!-- ACTIONS -->
        <Grid x:Name="actionsGrid"
              Grid.Row="2"
              ColumnDefinitions="*,*"
              ColumnSpacing="28"
              Padding="90,0,90,36"
              HorizontalOptions="Fill">

            <Frame Grid.Column="0"
                   HeightRequest="58"
                   WidthRequest="58"
                   CornerRadius="10"
                   Padding="0"
                   BackgroundColor="White"
                   HasShadow="True"
                   HorizontalOptions="Center">
                <Frame.Shadow>
                    <Shadow Brush="#35EF4D7A"
                            Offset="0,10"
                            Radius="18" />
                </Frame.Shadow>

                <Button Text="×"
                        FontSize="24"
                        TextColor="#111827"
                        BackgroundColor="Transparent"
                        Clicked="Reject_Clicked" />
            </Frame>

            <Frame Grid.Column="1"
                   HeightRequest="58"
                   WidthRequest="64"
                   CornerRadius="10"
                   Padding="0"
                   BackgroundColor="White"
                   HasShadow="True"
                   HorizontalOptions="Center">
                <Frame.Shadow>
                    <Shadow Brush="#456FD6A5"
                            Offset="0,12"
                            Radius="22" />
                </Frame.Shadow>

                <Button Text="♥"
                        FontSize="22"
                        TextColor="#111827"
                        BackgroundColor="Transparent"
                        Clicked="Like_Clicked" />
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
