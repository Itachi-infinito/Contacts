<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Candidate.JobOfferDetailPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="18,24,24,0"
              RowDefinitions="Auto,Auto"
              ColumnDefinitions="Auto,*,Auto">

            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="34"
                    Padding="0"
                    HeightRequest="44"
                    WidthRequest="44"
                    BackgroundColor="Transparent"
                    TextColor="#111827"
                    Clicked="Back_Clicked" />

            <Label Grid.Column="1"
                   Text="Détail de l'offre"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />

            <Frame Grid.Column="2"
                   HeightRequest="46"
                   WidthRequest="46"
                   CornerRadius="23"
                   Padding="0"
                   HasShadow="False"
                   VerticalOptions="Center">
                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label Text="ME"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="15"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>

            <Grid Grid.Row="1"
                  Grid.ColumnSpan="3"
                  ColumnDefinitions="*,*,*"
                  Margin="0,22,0,0"
                  HeightRequest="42">

                <Label Text="DÉCOUVRIR"
                       Grid.Column="0"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Discover_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="MESSAGES"
                       Grid.Column="1"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Messages_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="STATS"
                       Grid.Column="2"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Stats_Tapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

        </Grid>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,24,20,28"
                                 Spacing="16">

                <Frame CornerRadius="26"
                       Padding="0"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False"
                       IsClippedToBounds="True">

                    <Grid RowDefinitions="160,Auto">

                        <Grid Grid.Row="0">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#C4B5FD" Offset="0.0" />
                                    <GradientStop Color="#A78BFA" Offset="1.0" />
                                </LinearGradientBrush>
                            </Grid.Background>

                            <Ellipse WidthRequest="132"
                                     HeightRequest="132"
                                     Fill="#7C4DFF"
                                     Opacity="0.22"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center" />

                            <Ellipse WidthRequest="78"
                                     HeightRequest="78"
                                     Fill="White"
                                     Opacity="0.92"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Margin="0,-28,0,0" />

                            <Ellipse WidthRequest="52"
                                     HeightRequest="52"
                                     Fill="#7C4DFF"
                                     Opacity="0.75"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Margin="0,-28,0,0" />

                            <Ellipse WidthRequest="172"
                                     HeightRequest="70"
                                     Fill="#8B5CF6"
                                     Opacity="0.22"
                                     HorizontalOptions="Center"
                                     VerticalOptions="End"
                                     Margin="0,0,0,24" />
                        </Grid>

                        <VerticalStackLayout Grid.Row="1"
                                             Padding="20"
                                             Spacing="12">

                            <VerticalStackLayout Spacing="6">
                                <Label x:Name="lblTitle"
                                       FontSize="26"
                                       FontAttributes="Bold"
                                       TextColor="#111827"
                                       LineBreakMode="WordWrap" />

                                <Label x:Name="lblCompany"
                                       FontSize="16"
                                       TextColor="#7C4DFF" />

                                <Label x:Name="lblLocation"
                                       FontSize="14"
                                       TextColor="#8581A6" />
                            </VerticalStackLayout>

                            <HorizontalStackLayout Spacing="8">
                                <Frame BackgroundColor="#F0EAFE"
                                       CornerRadius="12"
                                       Padding="10,4"
                                       HasShadow="False">
                                    <Label x:Name="lblContractType"
                                           FontSize="12"
                                           TextColor="#7C4DFF" />
                                </Frame>

                                <Frame BackgroundColor="#F0EAFE"
                                       CornerRadius="12"
                                       Padding="10,4"
                                       HasShadow="False">
                                    <Label Text="Actif"
                                           FontSize="12"
                                           TextColor="#7C4DFF" />
                                </Frame>
                                <Frame x:Name="levelBadge"
                                        BackgroundColor="#F0EAFE"
                                        CornerRadius="12"
                                        Padding="10,4"
                                        HasShadow="False"
                                        IsVisible="False">
                                    <Label x:Name="lblLevel"
                                           FontSize="12"
                                           TextColor="#7C4DFF" />
                                </Frame>

                                <Frame x:Name="remoteBadge"
                                       BackgroundColor="#F0EAFE"
                                       CornerRadius="12"
                                       Padding="10,4"
                                       HasShadow="False"
                                       IsVisible="False">
                                    <Label x:Name="lblRemoteMode"
                                           FontSize="12"
                                           TextColor="#7C4DFF" />
                                </Frame>


                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>
                <Frame x:Name="compatibilityCard"
                        CornerRadius="22"
                        Padding="18"
                        BackgroundColor="White"
                        BorderColor="#EEEAF8"
                        HasShadow="False"
                        IsVisible="False">

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Compatibilité"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Label x:Name="lblCompatibilityScore"
                                   Grid.Column="1"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#7C4DFF" />
                        </Grid>

                        <ProgressBar x:Name="compatibilityProgress"
                                     Progress="0"
                                     ProgressColor="#7C4DFF"
                                     BackgroundColor="#E7E2F5"
                                     HeightRequest="6" />

                        <VerticalStackLayout x:Name="matchedRequiredSkillsSection"
                                             Spacing="5"
                                             IsVisible="False">
                            <Label Text="Compétences obligatoires trouvées"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#10B981" />

                            <Label x:Name="lblMatchedRequiredSkills"
                                   FontSize="13"
                                   TextColor="#5F5A75"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="missingRequiredSkillsSection"
                                             Spacing="5"
                                             IsVisible="False">
                            <Label Text="Compétences obligatoires manquantes"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#E11D48" />

                            <Label x:Name="lblMissingRequiredSkills"
                                   FontSize="13"
                                   TextColor="#5F5A75"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="matchedNiceSkillsSection"
                                             Spacing="5"
                                             IsVisible="False">
                            <Label Text="Compétences bonus trouvées"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#7C4DFF" />

                            <Label x:Name="lblMatchedNiceSkills"
                                   FontSize="13"
                                   TextColor="#5F5A75"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Frame>


                <Frame x:Name="salaryCard"
                       CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False"
                       IsVisible="False">

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Salaire"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label x:Name="lblSalary"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#7C4DFF" />
                    </VerticalStackLayout>
                </Frame>
                <Button x:Name="btnOpenMaps"
                        Text="Voir l'itinéraire"
                        HeightRequest="52"
                        BackgroundColor="White"
                        BorderColor="#DED8F5"
                        BorderWidth="1"
                        TextColor="#111827"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        IsVisible="False"
                        Clicked="OpenMaps_Clicked" />



                <Frame x:Name="skillsCard"
                       CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False"
                       IsVisible="False">

                    <VerticalStackLayout Spacing="14">
                        <Label Text="Compétences recherchées"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <VerticalStackLayout x:Name="requiredSkillsLayout"
                                             Spacing="6"
                                             IsVisible="False">
                            <Label Text="Obligatoires"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Label x:Name="lblRequiredSkills"
                                   FontSize="14"
                                   TextColor="#5F5A75"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="niceSkillsLayout"
                                             Spacing="6"
                                             IsVisible="False">
                            <Label Text="Bonus"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Label x:Name="lblNiceToHaveSkills"
                                   FontSize="14"
                                   TextColor="#5F5A75"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>


                <Frame CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Description"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label x:Name="lblDescription"
                               FontSize="14"
                               TextColor="#5F5A75"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="14">
                        <Label Text="Intéressé par cette offre ?"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label Text="Envoie ton intérêt au recruteur. Si l'intérêt est mutuel, un match sera créé."
                               FontSize="13"
                               TextColor="#8581A6"
                               LineBreakMode="WordWrap" />

                        <Button x:Name="btnLike"
                                Text="Liker cette offre"
                                HeightRequest="52"
                                BackgroundColor="#7C4DFF"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                Clicked="Like_Clicked" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
