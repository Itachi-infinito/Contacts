<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Candidate.JobOfferDetailPage"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F9FFFD" Offset="0.0" />
            <GradientStop Color="#EAF8F5" Offset="0.4" />
            <GradientStop Color="#1ABC9C" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="20,26,20,24"
                             Spacing="18">

            <!-- HEADER -->
            <Grid ColumnDefinitions="56,*,56"
                  VerticalOptions="Center"
                  Margin="0,0,0,10">

                <Button Grid.Column="0"
                        Text="←"
                        FontSize="22"
                        BackgroundColor="Transparent"
                        TextColor="#0B1F1D"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="40"
                        Clicked="Back_Clicked" />

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="4"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                        <Label Text="✦"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#1ABC9C" />
                        <Label Text="SparkWork"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#1ABC9C" />
                    </HorizontalStackLayout>

                    <Label Text="Job Offer Detail"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#0B1F1D"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Label Grid.Column="2" />
            </Grid>

            <!-- CARD -->
            <Frame BackgroundColor="White"
                   BorderColor="#DCEDE7"
                   CornerRadius="24"
                   Padding="22"
                   HasShadow="True">

                <VerticalStackLayout Spacing="18">

                    <!-- Top info -->
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="lblTitle"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#0B1F1D" />

                        <Label x:Name="lblCompany"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#1ABC9C" />

                        <Label x:Name="lblLocation"
                               FontSize="15"
                               TextColor="#6A7A7A" />

                        <Frame BackgroundColor="#F2FBF8"
                               BorderColor="#DDEEE8"
                               CornerRadius="12"
                               Padding="10,6"
                               HasShadow="False"
                               HorizontalOptions="Start">
                            <Label x:Name="lblContractType"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#4E6663" />
                        </Frame>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             Color="#EDF5F3" />

                    <!-- Description -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Description"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#0B1F1D" />

                        <Label x:Name="lblDescription"
                               FontSize="15"
                               TextColor="#334A48"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <!-- Button -->
                    <Button x:Name="btnLike"
                            Text="Like"
                            HeightRequest="52"
                            BackgroundColor="White"
                            BorderColor="#BFEADF"
                            BorderWidth="1.5"
                            TextColor="#1ABC9C"
                            FontAttributes="Bold"
                            CornerRadius="16"
                            Clicked="Like_Clicked" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>