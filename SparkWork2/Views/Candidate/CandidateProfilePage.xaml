<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Candidate.CandidateProfilePage"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F9FFFD" Offset="0.0" />
            <GradientStop Color="#EAF8F5" Offset="0.4" />
            <GradientStop Color="#1ABC9C" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="20,26,20,24"
                             Spacing="18">

            <!-- HEADER -->
            <Grid ColumnDefinitions="56,*,56"
                  VerticalOptions="Center"
                  Margin="0,0,0,10">

                <Button Grid.Column="0"
                        Text="☰"
                        FontSize="22"
                        BackgroundColor="Transparent"
                        TextColor="#0B1F1D"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="40"
                        Clicked="Menu_Clicked" />

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="4"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                        <Label Text="✦"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#1ABC9C" />
                        <Label Text="SparkWork"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#1ABC9C" />
                    </HorizontalStackLayout>

                    <Label Text="Candidate Profile"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="#334A48"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Label Grid.Column="2" />
            </Grid>
            

            <!-- PROFILE CARD -->
            <Frame BackgroundColor="White"
                   BorderColor="#DCEDE7"
                   CornerRadius="24"
                   Padding="22"
                   HasShadow="True">

                <VerticalStackLayout Spacing="18">
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="10">

                        <Frame WidthRequest="120"
                               HeightRequest="120"
                               CornerRadius="60"
                               Padding="0"
                               BackgroundColor="White"
                               BorderColor="#DCEDE7"
                               HasShadow="True"
                               HorizontalOptions="Center">

                            <Image x:Name="imgProfilePhoto"
                                   Source="dotnet_bot.png"
                                   Aspect="AspectFill" />
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Full Name"
                               FontAttributes="Bold"
                               TextColor="#1ABC9C" />
                        <Label x:Name="lblFullName"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#0B1F1D" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#EDF5F3" />

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Title"
                               FontAttributes="Bold"
                               TextColor="#1ABC9C" />
                        <Label x:Name="lblTitle"
                               FontSize="16"
                               TextColor="#334A48" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#EDF5F3" />

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Location"
                               FontAttributes="Bold"
                               TextColor="#1ABC9C" />
                        <Label x:Name="lblLocation"
                               FontSize="16"
                               TextColor="#334A48" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#EDF5F3" />

                    <VerticalStackLayout Spacing="8">
                        <Label Text="About"
                               FontAttributes="Bold"
                               TextColor="#1ABC9C" />
                        <Label x:Name="lblAbout"
                               FontSize="16"
                               TextColor="#334A48"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#EDF5F3" />

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Email"
                               FontAttributes="Bold"
                               TextColor="#1ABC9C" />
                        <Label x:Name="lblEmail"
                               FontSize="16"
                               TextColor="#334A48" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- ACTION -->
            <Button Text="Edit Profile"
                    HeightRequest="54"
                    BackgroundColor="White"
                    TextColor="#1ABC9C"
                    FontAttributes="Bold"
                    CornerRadius="16"
                    Clicked="EditProfile_Clicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>