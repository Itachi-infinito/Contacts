<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Candidate.CandidateProfilePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,28,24,24"
                                 Spacing="18">

                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Profil"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label Text="Votre vitrine auprès des recruteurs"
                               FontSize="13"
                               TextColor="#8B86A3" />
                    </VerticalStackLayout>

                    <Frame Grid.Column="1"
                           WidthRequest="52"
                           HeightRequest="52"
                           CornerRadius="26"
                           Padding="0"
                           HasShadow="False">

                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>

                        <Label x:Name="lblHeaderInitials"
                               Text="ME"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="16"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>
                </Grid>

                <Frame CornerRadius="26"
                       Padding="20"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16"
                                         HorizontalOptions="Center">

                        <Grid WidthRequest="116"
                              HeightRequest="116">

                            <Frame x:Name="profilePlaceholderFrame"
                                   WidthRequest="116"
                                   HeightRequest="116"
                                   CornerRadius="58"
                                   Padding="0"
                                   HasShadow="False">
                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                                        <GradientStop Color="#D34C88" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>

                                <Label x:Name="lblProfileInitials"
                                       Text="ME"
                                       FontSize="30"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <Frame x:Name="profilePhotoFrame"
                                   WidthRequest="116"
                                   HeightRequest="116"
                                   CornerRadius="58"
                                   Padding="0"
                                   HasShadow="False"
                                   IsClippedToBounds="True"
                                   IsVisible="False">

                                <Image x:Name="imgProfilePhoto"
                                       Aspect="AspectFill" />
                            </Frame>
                        </Grid>

                        <VerticalStackLayout Spacing="5"
                                             HorizontalOptions="Center">

                            <Label x:Name="lblFullName"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="Center" />

                            <Label x:Name="lblTitle"
                                   FontSize="15"
                                   TextColor="#7C4DFF"
                                   HorizontalTextAlignment="Center" />

                            <Label x:Name="lblLocation"
                                   FontSize="13"
                                   TextColor="#8581A6"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <Button Text="Modifier le profil"
                                HeightRequest="46"
                                Padding="22,0"
                                BackgroundColor="#7C4DFF"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="16"
                                Clicked="EditProfile_Clicked" />
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="À propos"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label x:Name="lblAbout"
                               FontSize="14"
                               TextColor="#5F5A75"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="Compétences horeca"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <FlexLayout x:Name="skillsLayout"
                                    Wrap="Wrap"
                                    Direction="Row"
                                    AlignItems="Start"
                                    JustifyContent="Start" />

                        <Label x:Name="lblNoSkills"
                               Text="Aucune compétence renseignée."
                               FontSize="13"
                               TextColor="#8B86A3"
                               IsVisible="False" />
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="14">
                        <Label Text="Préférences"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">

                            <Frame CornerRadius="16"
                                   Padding="14"
                                   BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   HasShadow="False">

                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Contrat"
                                           FontSize="12"
                                           TextColor="#8581A6" />

                                    <Label x:Name="lblDesiredContractType"
                                           Text="Non renseigné"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                </VerticalStackLayout>
                            </Frame>

                            <Frame Grid.Column="1"
                                   CornerRadius="16"
                                   Padding="14"
                                   BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   HasShadow="False">

                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Niveau"
                                           FontSize="12"
                                           TextColor="#8581A6" />

                                    <Label x:Name="lblExperienceLevel"
                                           Text="Non renseigné"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                </VerticalStackLayout>
                            </Frame>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">

                            <Frame CornerRadius="16"
                                   Padding="14"
                                   BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   HasShadow="False">

                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Salaire"
                                           FontSize="12"
                                           TextColor="#8581A6" />

                                    <Label x:Name="lblDesiredSalary"
                                           Text="Non renseigné"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                </VerticalStackLayout>
                            </Frame>

                            <Frame Grid.Column="1"
                                   CornerRadius="16"
                                   Padding="14"
                                   BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   HasShadow="False">

                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Distance"
                                           FontSize="12"
                                           TextColor="#8581A6" />

                                    <Label x:Name="lblMaxDistance"
                                           Text="Non renseignée"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                </VerticalStackLayout>
                            </Frame>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="14">

                        <Label Text="Informations"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">

                            <Label Text="Email"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Label Grid.Column="1"
                                   x:Name="lblEmail"
                                   FontSize="14"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="End"
                                   LineBreakMode="TailTruncation" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="#EEEAF8" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">

                            <Label Text="Statut"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Label Grid.Column="1"
                                   Text="Visible par les recruteurs"
                                   FontSize="14"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="End" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Button Text="Paramètres"
                        HeightRequest="50"
                        BackgroundColor="White"
                        BorderColor="#DED8F5"
                        BorderWidth="1"
                        TextColor="#111827"
                        FontAttributes="Bold"
                        CornerRadius="16"
                        Clicked="Settings_Clicked" />
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              BackgroundColor="White"
              Padding="18,8,18,18"
              ColumnDefinitions="*,*,*,*">

            <Button Text="Accueil"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Home_Clicked" />

            <Button Grid.Column="1"
                    Text="Découvrir"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Discover_Clicked" />

            <Button Grid.Column="2"
                    Text="Messages"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Messages_Clicked" />

            <Button Grid.Column="3"
                    Text="Profil"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#7C4DFF" />
        </Grid>
    </Grid>
</ContentPage>
