<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Candidate.CandidateProfilePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="28,26,28,0"
              RowDefinitions="Auto,Auto"
              ColumnDefinitions="*,Auto">

            <Label Text="SparkWork"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#7C4DFF"
                   VerticalOptions="Center" />

            <Frame Grid.Column="1"
                   HeightRequest="54"
                   WidthRequest="54"
                   CornerRadius="27"
                   Padding="0"
                   HasShadow="False"
                   HorizontalOptions="End"
                   VerticalOptions="Center">
                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label x:Name="lblHeaderInitials"
                       Text="ME"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="16"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>

            <Grid Grid.Row="1"
                  Grid.ColumnSpan="2"
                  ColumnDefinitions="*,*,*"
                  Margin="0,24,0,0"
                  HeightRequest="42">

                <Label Text="DÉCOUVRIR"
                       Grid.Column="0"
                       FontSize="15"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Discover_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="MESSAGES"
                       Grid.Column="1"
                       FontSize="15"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Messages_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="STATS"
                       Grid.Column="2"
                       FontSize="15"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Stats_Tapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </Grid>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,24,20,28"
                                 Spacing="16">

                <Grid ColumnDefinitions="*,Auto"
                      Margin="0,0,0,2">

                    <VerticalStackLayout Spacing="4">
                        <Label Text="MON PROFIL"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#8581A6" />

                        <Label Text="Les recruteurs verront ces informations."
                               FontSize="13"
                               TextColor="#8B86A3" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="Modifier"
                            HeightRequest="38"
                            Padding="16,0"
                            BackgroundColor="#7C4DFF"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="13"
                            CornerRadius="12"
                            Clicked="EditProfile_Clicked" />
                </Grid>
                <Button Text="Paramètres"
                        HeightRequest="46"
                        BackgroundColor="White"
                        BorderColor="#DED8F5"
                        BorderWidth="1"
                        TextColor="#111827"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        Clicked="Settings_Clicked" />


                <!-- HERO PROFILE -->
                <Frame CornerRadius="24"
                       Padding="20"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16"
                                         HorizontalOptions="Center">

                        <Grid WidthRequest="112"
                              HeightRequest="112">

                            <Frame x:Name="profilePlaceholderFrame"
                                   WidthRequest="112"
                                   HeightRequest="112"
                                   CornerRadius="56"
                                   Padding="0"
                                   HasShadow="False"
                                   IsVisible="True">
                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                                        <GradientStop Color="#D34C88" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>

                                <Label x:Name="lblProfileInitials"
                                       Text="ME"
                                       FontSize="30"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <Frame x:Name="profilePhotoFrame"
                                   WidthRequest="112"
                                   HeightRequest="112"
                                   CornerRadius="56"
                                   Padding="0"
                                   HasShadow="False"
                                   IsClippedToBounds="True"
                                   IsVisible="False">
                                <Image x:Name="imgProfilePhoto"
                                       Aspect="AspectFill" />
                            </Frame>
                        </Grid>

                        <VerticalStackLayout Spacing="5"
                                             HorizontalOptions="Center">

                            <Label x:Name="lblFullName"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="Center" />

                            <Label x:Name="lblTitle"
                                   FontSize="15"
                                   TextColor="#7C4DFF"
                                   HorizontalTextAlignment="Center" />

                            <Label x:Name="lblLocation"
                                   FontSize="14"
                                   TextColor="#8581A6"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="Center">

                            <Frame BackgroundColor="#F0EAFE"
                                   CornerRadius="12"
                                   Padding="10,4"
                                   HasShadow="False">
                                <Label Text="Disponible"
                                       FontSize="12"
                                       TextColor="#7C4DFF" />
                            </Frame>

                            <Frame BackgroundColor="#F0EAFE"
                                   CornerRadius="12"
                                   Padding="10,4"
                                   HasShadow="False">
                                <Label Text="Profil actif"
                                       FontSize="12"
                                       TextColor="#7C4DFF" />
                            </Frame>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- ABOUT -->
                <Frame CornerRadius="20"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="10">
                        <Label Text="À propos"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label x:Name="lblAbout"
                               FontSize="14"
                               TextColor="#5F5A75"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Frame>

                <!-- CONTACT -->
                <Frame CornerRadius="20"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="14">

                        <Label Text="Informations"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <Label Text="Email"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />
                            <Label Grid.Column="1"
                                   x:Name="lblEmail"
                                   FontSize="14"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="End"
                                   LineBreakMode="TailTruncation" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="#EEEAF8" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <Label Text="Statut"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />
                            <Label Grid.Column="1"
                                   Text="Visible par les recruteurs"
                                   FontSize="14"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="End" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- COMPLETENESS -->
                <Frame CornerRadius="20"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="Complétude du profil"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Infos générales"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                            <Label Grid.Column="1"
                                   Text="100%"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                        </Grid>

                        <ProgressBar Progress="1"
                                     ProgressColor="#D34C88"
                                     BackgroundColor="#E7E2F5"
                                     HeightRequest="5" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Description"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                            <Label Grid.Column="1"
                                   Text="80%"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                        </Grid>

                        <ProgressBar Progress="0.8"
                                     ProgressColor="#D34C88"
                                     BackgroundColor="#E7E2F5"
                                     HeightRequest="5" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
