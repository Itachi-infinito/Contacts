<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Candidate.CandidateProfilePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F8F6FF">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="32,34,32,24" Spacing="18">

                <!-- HEADER -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Profil"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label Text="Votre vitrine auprès des recruteurs"
                               FontSize="14"
                               TextColor="#8B86A3" />
                    </VerticalStackLayout>

                    <Frame Grid.Column="1"
                           WidthRequest="52"
                           HeightRequest="52"
                           CornerRadius="26"
                           Padding="0"
                           HasShadow="False">
                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>

                        <Label x:Name="lblHeaderInitials"
                               Text="A"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="17"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>
                </Grid>

                <!-- PROFILE CARD -->
                <Frame CornerRadius="26"
                       Padding="22"
                       BackgroundColor="White"
                       BorderColor="#DED8F5"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="14" HorizontalOptions="Center">

                        <Grid WidthRequest="116" HeightRequest="116">
                            <Frame x:Name="profilePlaceholderFrame"
                                   WidthRequest="106"
                                   HeightRequest="106"
                                   CornerRadius="53"
                                   Padding="0"
                                   HasShadow="False"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                                        <GradientStop Color="#D34C88" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>

                                <Label x:Name="lblProfileInitials"
                                       Text="A"
                                       FontSize="36"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <Frame x:Name="profilePhotoFrame"
                                   WidthRequest="106"
                                   HeightRequest="106"
                                   CornerRadius="53"
                                   Padding="0"
                                   HasShadow="False"
                                   IsClippedToBounds="True"
                                   IsVisible="False"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                <Image x:Name="imgProfilePhoto" Aspect="AspectFill" />
                            </Frame>

                            <Frame WidthRequest="18"
                                   HeightRequest="18"
                                   CornerRadius="9"
                                   Padding="0"
                                   BackgroundColor="#52C58B"
                                   BorderColor="White"
                                   HasShadow="False"
                                   HorizontalOptions="End"
                                   VerticalOptions="End"
                                   Margin="0,0,16,16" />
                        </Grid>

                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="lblFullName"
                                   Text="Adel"
                                   FontSize="25"
                                   FontAttributes="Bold"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="Center" />

                            <Label x:Name="lblTitleLine"
                                   Text="Junior vendeur · Horeca"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#7C4DFF"
                                   HorizontalTextAlignment="Center" />

                            <Label x:Name="lblDistanceLine"
                                   Text="Nivelles · 12 km des offres"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8B86A3"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Frame Padding="12,5"
                                   CornerRadius="14"
                                   BackgroundColor="#F0EAFE"
                                   HasShadow="False">
                                <Label Text="Candidat"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#7C4DFF" />
                            </Frame>

                            <Frame Padding="12,5"
                                   CornerRadius="14"
                                   BackgroundColor="#DCFCE7"
                                   HasShadow="False">
                                <Label Text="• Actif"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#166534" />
                            </Frame>
                        </HorizontalStackLayout>

                        <Frame Padding="14,5"
                               CornerRadius="15"
                               BackgroundColor="#FCE7F3"
                               HasShadow="False">
                            <Label Text="● Open to work"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#9F295B" />
                        </Frame>

                        <Frame HeightRequest="56"
                               CornerRadius="28"
                               Padding="0"
                               HasShadow="False"
                               HorizontalOptions="Fill">
                            <Frame.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C4DFF" Offset="0.0" />
                                    <GradientStop Color="#D34C88" Offset="1.0" />
                                </LinearGradientBrush>
                            </Frame.Background>

                            <Grid>
                                <HorizontalStackLayout Spacing="10"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center">
                                    <Label Text="&#xE3C9;"
                                           FontFamily="MaterialIcons"
                                           FontSize="21"
                                           TextColor="White" />
                                    <Label Text="Modifier le profil"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                </HorizontalStackLayout>

                                <Button BackgroundColor="Transparent"
                                        Text=""
                                        Clicked="EditProfile_Clicked" />
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- COMPLETION -->
                <Frame CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#DED8F5"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Complétion du profil"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Label x:Name="lblCompletionPercent"
                                   Grid.Column="1"
                                   Text="65%"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#7C4DFF" />
                        </Grid>

                        <Label Text="Complétez votre profil pour attirer plus de recruteurs"
                               FontSize="13"
                               TextColor="#8B86A3"
                               LineBreakMode="WordWrap" />

                        <ProgressBar x:Name="profileCompletionProgress"
                                     Progress="0.65"
                                     ProgressColor="#D34C88"
                                     BackgroundColor="#EEEAF8"
                                     HeightRequest="6" />

                        <FlexLayout Direction="Row" Wrap="Wrap">
                            <Frame x:Name="photoStepChip" Padding="10,4" CornerRadius="12" BackgroundColor="#DCFCE7" HasShadow="False" Margin="0,0,8,8">
                                <Label x:Name="lblPhotoStep" Text="✓ Photo" FontSize="12" TextColor="#047857" />
                            </Frame>

                            <Frame x:Name="postStepChip" Padding="10,4" CornerRadius="12" BackgroundColor="#DCFCE7" HasShadow="False" Margin="0,0,8,8">
                                <Label x:Name="lblPostStep" Text="✓ Poste" FontSize="12" TextColor="#047857" />
                            </Frame>

                            <Frame x:Name="skillsStepChip" Padding="10,4" CornerRadius="12" BackgroundColor="#DCFCE7" HasShadow="False" Margin="0,0,8,8">
                                <Label x:Name="lblSkillsStep" Text="✓ Compétences" FontSize="12" TextColor="#047857" />
                            </Frame>

                            <Frame x:Name="experiencesStepChip" Padding="10,4" CornerRadius="12" BackgroundColor="#F0EAFE" HasShadow="False" Margin="0,0,8,8">
                                <Label x:Name="lblExperiencesStep" Text="+ Expériences" FontSize="12" TextColor="#7C4DFF" />
                            </Frame>

                            <Frame x:Name="salaryStepChip" Padding="10,4" CornerRadius="12" BackgroundColor="#F0EAFE" HasShadow="False" Margin="0,0,8,8">
                                <Label x:Name="lblSalaryStep" Text="+ Salaire" FontSize="12" TextColor="#7C4DFF" />
                            </Frame>

                            <Frame x:Name="cvStepChip" Padding="10,4" CornerRadius="12" BackgroundColor="#F0EAFE" HasShadow="False" Margin="0,0,8,8">
                                <Label x:Name="lblCvStep" Text="+ CV" FontSize="12" TextColor="#7C4DFF" />
                            </Frame>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- STATS -->
                <Label Text="Statistiques"
                       FontSize="19"
                       FontAttributes="Bold"
                       TextColor="#111827"
                       Margin="2,0,0,-4" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                    <Frame CornerRadius="18" Padding="16" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Frame WidthRequest="40" HeightRequest="40" CornerRadius="12" Padding="0" BackgroundColor="#F0EAFE" HasShadow="False" HorizontalOptions="Start">
                                <Label Text="&#xE8F4;" FontFamily="MaterialIcons" FontSize="22" TextColor="#7C4DFF" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            </Frame>
                            <Label x:Name="lblProfileViewsCount" Text="47" FontSize="24" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Vues du profil" FontSize="13" FontAttributes="Bold" TextColor="#8581A6" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1" CornerRadius="18" Padding="16" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Frame WidthRequest="40" HeightRequest="40" CornerRadius="12" Padding="0" BackgroundColor="#FCE7F3" HasShadow="False" HorizontalOptions="Start">
                                <Label Text="&#xE87D;" FontFamily="MaterialIcons" FontSize="22" TextColor="#D34C88" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            </Frame>
                            <Label x:Name="lblMatchesCount" Text="3" FontSize="24" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Matchs obtenus" FontSize="13" FontAttributes="Bold" TextColor="#8581A6" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" CornerRadius="18" Padding="16" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Frame WidthRequest="40" HeightRequest="40" CornerRadius="12" Padding="0" BackgroundColor="#DCFCE7" HasShadow="False" HorizontalOptions="Start">
                                <Label Text="&#xE0CA;" FontFamily="MaterialIcons" FontSize="22" TextColor="#059669" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            </Frame>
                            <Label x:Name="lblConversationsCount" Text="2" FontSize="24" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Conversations" FontSize="13" FontAttributes="Bold" TextColor="#8581A6" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" Grid.Column="1" CornerRadius="18" Padding="16" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Frame WidthRequest="40" HeightRequest="40" CornerRadius="12" Padding="0" BackgroundColor="#FEF3C7" HasShadow="False" HorizontalOptions="Start">
                                <Label Text="&#xE873;" FontFamily="MaterialIcons" FontSize="22" TextColor="#D97706" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            </Frame>
                            <Label x:Name="lblOffersSeenCount" Text="8" FontSize="24" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Offres vues" FontSize="13" FontAttributes="Bold" TextColor="#8581A6" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- SKILLS -->
                <Frame CornerRadius="22" Padding="18" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Compétences"
                               FontSize="19"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <FlexLayout x:Name="skillsLayout"
                                    Wrap="Wrap"
                                    Direction="Row"
                                    AlignItems="Start"
                                    JustifyContent="Start" />

                        <Label x:Name="lblNoSkills"
                               Text="Aucune compétence renseignée."
                               FontSize="13"
                               TextColor="#8B86A3"
                               IsVisible="False" />
                    </VerticalStackLayout>
                </Frame>

                <!-- EXPERIENCES -->
                <Frame CornerRadius="22" Padding="18" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Expériences"
                               FontSize="19"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <VerticalStackLayout x:Name="experiencesLayout" Spacing="14" />

                        <Label x:Name="lblNoExperiences"
                               Text="Aucune expérience renseignée."
                               FontSize="13"
                               TextColor="#8B86A3"
                               IsVisible="False" />
                    </VerticalStackLayout>
                </Frame>

                <!-- PREFERENCES -->
                <Frame CornerRadius="22" Padding="18" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Disponibilité &amp; Préférences"
                               FontSize="19"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                            <Frame CornerRadius="16" Padding="14" BackgroundColor="#FAF9FF" BorderColor="#EEEAF8" HasShadow="False">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Contrat" FontSize="12" TextColor="#8581A6" />
                                    <Label x:Name="lblDesiredContractType" Text="Non renseigné" FontSize="15" FontAttributes="Bold" TextColor="#111827" />
                                </VerticalStackLayout>
                            </Frame>

                            <Frame Grid.Column="1" CornerRadius="16" Padding="14" BackgroundColor="#FAF9FF" BorderColor="#EEEAF8" HasShadow="False">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Disponibilité" FontSize="12" TextColor="#8581A6" />
                                    <Label x:Name="lblAvailability" Text="Immédiate" FontSize="15" FontAttributes="Bold" TextColor="#111827" />
                                </VerticalStackLayout>
                            </Frame>

                            <Frame Grid.Row="1" CornerRadius="16" Padding="14" BackgroundColor="#FAF9FF" BorderColor="#EEEAF8" HasShadow="False">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Salaire souhaité" FontSize="12" TextColor="#8581A6" />
                                    <Label x:Name="lblDesiredSalary" Text="Non renseigné" FontSize="15" FontAttributes="Bold" TextColor="#111827" />
                                </VerticalStackLayout>
                            </Frame>

                            <Frame Grid.Row="1" Grid.Column="1" CornerRadius="16" Padding="14" BackgroundColor="#FAF9FF" BorderColor="#EEEAF8" HasShadow="False">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Mode de travail" FontSize="12" TextColor="#8581A6" />
                                    <Label x:Name="lblWorkMode" Text="Flexible" FontSize="15" FontAttributes="Bold" TextColor="#111827" />
                                </VerticalStackLayout>
                            </Frame>
                        </Grid>

                        <Frame CornerRadius="16" Padding="14" BackgroundColor="#FAF9FF" BorderColor="#EEEAF8" HasShadow="False">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Distance maximale"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#8581A6" />
                                <Label x:Name="lblMaxDistance"
                                       Grid.Column="1"
                                       Text="25 km"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#7C4DFF" />
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- ADVICE -->
                <Frame CornerRadius="22" Padding="20"
                       BackgroundColor="#F7EFFF"
                       BorderColor="#D8B4FE"
                       HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Frame WidthRequest="44" HeightRequest="44" CornerRadius="14"
                               Padding="0" BackgroundColor="White" HasShadow="False">
                            <Label Text="&#xE90F;"
                                   FontFamily="MaterialIcons"
                                   FontSize="22"
                                   TextColor="#D97706"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Conseil"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Label Text="Ajoutez vos expériences et importez votre CV pour augmenter votre compatibilité avec les offres."
                                   FontSize="15"
                                   TextColor="#4B2FBF"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <Button Text="Paramètres"
                        HeightRequest="52"
                        BackgroundColor="White"
                        BorderColor="#DED8F5"
                        BorderWidth="1"
                        TextColor="#7C4DFF"
                        FontAttributes="Bold"
                        CornerRadius="26"
                        Clicked="Settings_Clicked" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- BOTTOM NAV -->
        <Grid Grid.Row="1"
              BackgroundColor="White"
              Padding="18,8,18,18"
              ColumnDefinitions="*,*,*,*">

            <Grid Grid.Column="0">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="&#xE88A;" FontFamily="MaterialIcons" FontSize="25" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                    <Label Text="Accueil" FontSize="11" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <Button Text="" BackgroundColor="Transparent" Clicked="Home_Clicked" />
            </Grid>

            <Grid Grid.Column="1">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="&#xE8B6;" FontFamily="MaterialIcons" FontSize="25" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                    <Label Text="Découvrir" FontSize="11" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <Button Text="" BackgroundColor="Transparent" Clicked="Discover_Clicked" />
            </Grid>

            <Grid Grid.Column="2">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="&#xE0BF;"
                           FontFamily="MaterialIcons"
                           FontSize="25"
                           TextColor="#B0ABCE"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Messages" FontSize="11" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />

                </VerticalStackLayout>
                <Button Text="" BackgroundColor="Transparent" Clicked="Messages_Clicked" />
            </Grid>

            <Grid Grid.Column="3">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="&#xE7FD;" FontFamily="MaterialIcons" FontSize="25" TextColor="#7C4DFF" HorizontalTextAlignment="Center" />
                    <Label Text="Profil" FontSize="11" FontAttributes="Bold" TextColor="#7C4DFF" HorizontalTextAlignment="Center" />
                    <BoxView WidthRequest="4" HeightRequest="4" CornerRadius="2" Color="#7C4DFF" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
