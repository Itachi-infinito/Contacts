<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Candidate.EditCandidateProfilePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="18,24,24,0"
              RowDefinitions="Auto,Auto"
              ColumnDefinitions="Auto,*,Auto">

            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="34"
                    Padding="0"
                    HeightRequest="44"
                    WidthRequest="44"
                    BackgroundColor="Transparent"
                    TextColor="#111827"
                    Clicked="Cancel_Clicked" />

            <Label Grid.Column="1"
                   Text="Modifier le profil"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />

            <Frame Grid.Column="2"
                   HeightRequest="46"
                   WidthRequest="46"
                   CornerRadius="23"
                   Padding="0"
                   HasShadow="False"
                   VerticalOptions="Center">
                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label x:Name="lblHeaderInitials"
                       Text="ME"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="15"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>

            <Grid Grid.Row="1"
                  Grid.ColumnSpan="3"
                  ColumnDefinitions="*,*,*"
                  Margin="0,22,0,0"
                  HeightRequest="42">

                <Label Text="DÉCOUVRIR"
                       Grid.Column="0"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />

                <Label Text="MESSAGES"
                       Grid.Column="1"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />

                <Label Text="STATS"
                       Grid.Column="2"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Grid>
        </Grid>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,24,20,28"
                                 Spacing="16">

                <Frame CornerRadius="24"
                       Padding="20"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="14"
                                         HorizontalOptions="Center">

                        <Grid WidthRequest="112"
                              HeightRequest="112">

                            <Frame x:Name="photoPlaceholderFrame"
                                   WidthRequest="112"
                                   HeightRequest="112"
                                   CornerRadius="56"
                                   Padding="0"
                                   HasShadow="False">
                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                                        <GradientStop Color="#D34C88" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>

                                <Label x:Name="lblPhotoInitials"
                                       Text="ME"
                                       FontSize="30"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <Frame x:Name="photoImageFrame"
                                   WidthRequest="112"
                                   HeightRequest="112"
                                   CornerRadius="56"
                                   Padding="0"
                                   HasShadow="False"
                                   IsClippedToBounds="True"
                                   IsVisible="False">
                                <Image x:Name="imgCandidatePhoto"
                                       Aspect="AspectFill" />
                            </Frame>
                        </Grid>

                        <Button Text="Changer la photo"
                                HeightRequest="40"
                                Padding="18,0"
                                BackgroundColor="#F0EAFE"
                                TextColor="#7C4DFF"
                                FontAttributes="Bold"
                                FontSize="13"
                                CornerRadius="12"
                                Clicked="ChangePhoto_Clicked" />
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="24"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16">

                        <Label Text="Informations principales"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Nom complet"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryFullName"
                                       Placeholder="Ex: Adel Martin"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Titre professionnel"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryTitle"
                                       Placeholder="Ex: Développeur junior"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Localisation"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryLocation"
                                       Placeholder="Ex: Bruxelles"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Email"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryEmail"
                                       Placeholder="email@example.com"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent"
                                       Keyboard="Email" />
                            </Frame>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="24"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="À propos"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Frame BackgroundColor="#FAF9FF"
                               BorderColor="#EEEAF8"
                               CornerRadius="14"
                               Padding="14,10"
                               HasShadow="False">
                            <Editor x:Name="editorAbout"
                                    Placeholder="Présente ton profil, tes compétences et ce que tu recherches."
                                    PlaceholderColor="#A6A0C0"
                                    TextColor="#111827"
                                    BackgroundColor="Transparent"
                                    AutoSize="TextChanges"
                                    HeightRequest="130" />
                        </Frame>
                    </VerticalStackLayout>
                </Frame>
                <Frame CornerRadius="24"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16">

                        <Label Text="Expérience professionnelle"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label Text="Ajoute jusqu'à deux expériences visibles par les recruteurs."
                               FontSize="12"
                               TextColor="#8B86A3" />

                        <VerticalStackLayout Spacing="10">
                            <Label Text="Expérience 1"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryExperienceTitle1"
                                       Placeholder="Ex: Serveur polyvalent"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryExperienceCompany1"
                                       Placeholder="Ex: Brasserie Louise"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryExperiencePeriod1"
                                       Placeholder="Ex: 2023 - Aujourd'hui"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 Color="#EEEAF8" />

                        <VerticalStackLayout Spacing="10">
                            <Label Text="Expérience 2"
                                    FontSize="13"
                                    FontAttributes="Bold"
                                    TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryExperienceTitle2"
                                       Placeholder="Ex: Commis de salle"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryExperienceCompany2"
                                       Placeholder="Ex: Hôtel Central"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryExperiencePeriod2"
                                       Placeholder="Ex: 2021 - 2023"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>


                <Frame CornerRadius="24"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16">

                        <Label Text="Préférences de recherche"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <VerticalStackLayout Spacing="10">
                            <Label Text="Compétences horeca"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8">

                                <Frame BackgroundColor="#FAF9FF"
                                       BorderColor="#EEEAF8"
                                       CornerRadius="14"
                                       Padding="10,0"
                                       HasShadow="False">

                                    <Picker x:Name="skillPicker"
                                            Title="Choisir une compétence"
                                            TextColor="#111827"
                                            TitleColor="#A6A0C0" />
                                </Frame>

                                <Button Grid.Column="1"
                                        Text="+"
                                        WidthRequest="46"
                                        HeightRequest="46"
                                        BackgroundColor="#7C4DFF"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        CornerRadius="14"
                                        Clicked="AddSkill_Clicked" />
                            </Grid>

                            <FlexLayout x:Name="selectedSkillsLayout"
                                        Direction="Row"
                                        Wrap="Wrap"
                                        AlignItems="Center"
                                        JustifyContent="Start" />

                            <Label x:Name="lblSkillsEmpty"
                                   Text="Aucune compétence sélectionnée."
                                   FontSize="12"
                                   TextColor="#8B86A3" />
                        </VerticalStackLayout>


                        <VerticalStackLayout Spacing="7">
                            <Label Text="Contrat recherché"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryDesiredContractType"
                                       Placeholder="Ex: CDI, Stage, Full-time"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Niveau"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryExperienceLevel"
                                       Placeholder="Ex: Junior, Medior, Senior"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="7">
                                <Label Text="Salaire min"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#8581A6" />

                                <Frame BackgroundColor="#FAF9FF"
                                       BorderColor="#EEEAF8"
                                       CornerRadius="14"
                                       Padding="14,4"
                                       HasShadow="False">
                                    <Entry x:Name="entryDesiredSalaryMin"
                                           Placeholder="Ex: 2500"
                                           Keyboard="Numeric"
                                           PlaceholderColor="#A6A0C0"
                                           TextColor="#111827"
                                           BackgroundColor="Transparent" />
                                </Frame>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="7">
                                <Label Text="Salaire max"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#8581A6" />

                                <Frame BackgroundColor="#FAF9FF"
                                       BorderColor="#EEEAF8"
                                       CornerRadius="14"
                                       Padding="14,4"
                                       HasShadow="False">
                                    <Entry x:Name="entryDesiredSalaryMax"
                                           Placeholder="Ex: 4000"
                                           Keyboard="Numeric"
                                           PlaceholderColor="#A6A0C0"
                                           TextColor="#111827"
                                           BackgroundColor="Transparent" />
                                </Frame>
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Distance maximale"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryMaxDistanceKm"
                                       Placeholder="Ex: 25"
                                       Keyboard="Numeric"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>
                        <Button x:Name="btnUseCurrentLocation"
                                Text="Utiliser ma position actuelle"
                                HeightRequest="46"
                                BackgroundColor="#F0EAFE"
                                TextColor="#7C4DFF"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                Clicked="UseCurrentLocation_Clicked" />

                        <Label x:Name="lblCurrentCoordinates"
                               Text="Position non définie"
                               FontSize="12"
                               TextColor="#8B86A3"
                               HorizontalTextAlignment="Center" />


                    </VerticalStackLayout>
                </Frame>


                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,4,0,0">

                    <Button Grid.Column="0"
                            Text="Annuler"
                            HeightRequest="52"
                            BackgroundColor="White"
                            BorderColor="#DED8F5"
                            BorderWidth="1"
                            TextColor="#111827"
                            FontAttributes="Bold"
                            CornerRadius="14"
                            Clicked="Cancel_Clicked" />

                    <Button Grid.Column="1"
                            Text="Enregistrer"
                            HeightRequest="52"
                            BackgroundColor="#7C4DFF"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="14"
                            Clicked="Update_Clicked" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
