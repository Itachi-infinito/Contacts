<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Candidate.MatchesPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="28,26,28,0"
              RowDefinitions="Auto,Auto"
              ColumnDefinitions="*,Auto">

            <Label Text="SparkWork"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#7C4DFF"
                   VerticalOptions="Center" />

            <Frame Grid.Column="1"
                   HeightRequest="54"
                   WidthRequest="54"
                   CornerRadius="27"
                   Padding="0"
                   HasShadow="False"
                   HorizontalOptions="End"
                   VerticalOptions="Center">

                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Profile_Tapped" />
                </Frame.GestureRecognizers>

                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label Text="ME"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="16"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>

            <Grid Grid.Row="1"
                  Grid.ColumnSpan="2"
                  ColumnDefinitions="*,*,*"
                  Margin="0,24,0,0"
                  HeightRequest="42">

                <Label Text="DÉCOUVRIR"
                       Grid.Column="0"
                       FontSize="15"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Discover_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="MESSAGES"
                       Grid.Column="1"
                       FontSize="15"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Messages_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="STATS"
                       Grid.Column="2"
                       FontSize="15"
                       TextColor="#7C4DFF"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />

                <BoxView Grid.Column="2"
                         HeightRequest="3"
                         Color="#7C4DFF"
                         VerticalOptions="End"
                         Margin="14,0,14,0" />
            </Grid>
        </Grid>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="28,28,28,28"
                                 Spacing="24">

                <Label Text="CETTE SEMAINE"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#8B86A3" />

                <!-- STATS GRID -->
                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="14"
                      RowSpacing="14">

                    <Frame Grid.Row="0"
                           Grid.Column="0"
                           BackgroundColor="White"
                           CornerRadius="20"
                           Padding="16"
                           HasShadow="False"
                           BorderColor="#EEEAF8">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Profils vus"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                            <Label Text="47"
                                   FontSize="34"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Label Text="↑ +12 vs sem. dernière"
                                   FontSize="12"
                                   TextColor="#5BCDA4" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="0"
                           Grid.Column="1"
                           BackgroundColor="White"
                           CornerRadius="20"
                           Padding="16"
                           HasShadow="False"
                           BorderColor="#EEEAF8">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Matches"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                            <Label x:Name="lblMatchesCount"
                                   Text="0"
                                   FontSize="34"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Label Text="↑ nouveaux"
                                   FontSize="12"
                                   TextColor="#5BCDA4" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1"
                           Grid.Column="0"
                           BackgroundColor="White"
                           CornerRadius="20"
                           Padding="16"
                           HasShadow="False"
                           BorderColor="#EEEAF8">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Taux de match"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                            <Label Text="17%"
                                   FontSize="34"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Label Text="↑ +4 pts"
                                   FontSize="12"
                                   TextColor="#5BCDA4" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1"
                           Grid.Column="1"
                           BackgroundColor="White"
                           CornerRadius="20"
                           Padding="16"
                           HasShadow="False"
                           BorderColor="#EEEAF8">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Msgs envoyés"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                            <Label Text="23"
                                   FontSize="34"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Label Text="↓ -2 vs sem."
                                   FontSize="12"
                                   TextColor="#EF4D7A" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- PROFILE COMPLETION -->
                <Frame BackgroundColor="White"
                       CornerRadius="20"
                       Padding="18"
                       HasShadow="False"
                       BorderColor="#EEEAF8">

                    <VerticalStackLayout Spacing="12">

                        <Label Text="Complétude du profil"
                               FontSize="16"
                               TextColor="#8581A6" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Infos générales"
                                   FontSize="15"
                                   TextColor="#8581A6" />
                            <Label Grid.Column="1"
                                   Text="100%"
                                   FontSize="15"
                                   TextColor="#8581A6" />
                        </Grid>
                        <ProgressBar Progress="1"
                                     ProgressColor="#D34C88" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Expériences"
                                   FontSize="15"
                                   TextColor="#8581A6" />
                            <Label Grid.Column="1"
                                   Text="80%"
                                   FontSize="15"
                                   TextColor="#8581A6" />
                        </Grid>
                        <ProgressBar Progress="0.8"
                                     ProgressColor="#D34C88" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Compétences"
                                   FontSize="15"
                                   TextColor="#8581A6" />
                            <Label Grid.Column="1"
                                   Text="60%"
                                   FontSize="15"
                                   TextColor="#8581A6" />
                        </Grid>
                        <ProgressBar Progress="0.6"
                                     ProgressColor="#D34C88" />

                    </VerticalStackLayout>
                </Frame>

                <!-- RECENT MATCHES -->
                <Label Text="MATCHES RÉCENTS"
       FontSize="18"
       FontAttributes="Bold"
       TextColor="#8581A6"
       Margin="0,26,0,12" />

                <CollectionView x:Name="matchesCollection"
                SelectionMode="None"
                HeightRequest="200"
                HorizontalScrollBarVisibility="Never">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal"
                           ItemSpacing="12" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.EmptyView>
                        <Frame WidthRequest="300"
               HeightRequest="130"
               CornerRadius="18"
               Padding="18"
               BackgroundColor="White"
               BorderColor="#EEEAF8"
               HasShadow="False">
                            <VerticalStackLayout Spacing="6"
                                 VerticalOptions="Center">
                                <Label Text="Aucun match récent"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#111827" />
                                <Label Text="Tes nouveaux matchs apparaîtront ici."
                       FontSize="13"
                       TextColor="#8581A6" />
                            </VerticalStackLayout>
                        </Frame>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame WidthRequest="145"
                   HeightRequest="178"
                   CornerRadius="18"
                   Padding="12"
                   BackgroundColor="White"
                   BorderColor="#EEEAF8"
                   HasShadow="False">

                                <Grid RowDefinitions="Auto,Auto,Auto,*"
                      RowSpacing="5">

                                    <Frame Grid.Row="0"
                           WidthRequest="56"
                           HeightRequest="56"
                           CornerRadius="28"
                           Padding="0"
                           HasShadow="False"
                           HorizontalOptions="Center">

                                        <Frame.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                                <GradientStop Color="#D34C88" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Frame.Background>

                                        <Label Text="{Binding Initials}"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                                    </Frame>

                                    <Label Grid.Row="1"
                           Text="{Binding CompanyName}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="TailTruncation"
                           MaxLines="1" />

                                    <Label Grid.Row="2"
                           Text="{Binding JobTitle}"
                           FontSize="12"
                           TextColor="#8581A6"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="TailTruncation"
                           MaxLines="1" />

                                    <Button Grid.Row="3"
                            Text="Contacter"
                            HeightRequest="34"
                            Padding="0"
                            FontSize="13"
                            FontAttributes="Bold"
                            BackgroundColor="Transparent"
                            BorderColor="#DED8F5"
                            BorderWidth="1"
                            TextColor="#111827"
                            CornerRadius="10"
                            VerticalOptions="End"
                            Clicked="Contact_Clicked"
                            CommandParameter="{Binding .}" />

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="Match_Tapped"
                                              CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>


                <!-- RECENT ACTIVITY -->
                <Label Text="ACTIVITÉ RÉCENTE"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#8B86A3" />

                <VerticalStackLayout Spacing="12">

                    <Frame BackgroundColor="White"
                           CornerRadius="18"
                           Padding="16"
                           HasShadow="False"
                           BorderColor="#EEEAF8">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Frame WidthRequest="48"
                                   HeightRequest="48"
                                   CornerRadius="24"
                                   Padding="0"
                                   BackgroundColor="#EAFBF4"
                                   HasShadow="False">
                                <Label Text="🎯"
                                       FontSize="22"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="Nouveau match"
                                       FontSize="16"
                                       TextColor="#111827" />
                                <Label Text="Un recruteur a répondu à ton intérêt."
                                       FontSize="13"
                                       TextColor="#8581A6" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="2h"
                                   FontSize="13"
                                   TextColor="#8581A6"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>

                    <Frame BackgroundColor="White"
                           CornerRadius="18"
                           Padding="16"
                           HasShadow="False"
                           BorderColor="#EEEAF8">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Frame WidthRequest="48"
                                   HeightRequest="48"
                                   CornerRadius="24"
                                   Padding="0"
                                   BackgroundColor="#F0EAFE"
                                   HasShadow="False">
                                <Label Text="💬"
                                       FontSize="22"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="Message reçu"
                                       FontSize="16"
                                       TextColor="#111827" />
                                <Label Text="Une conversation est active."
                                       FontSize="13"
                                       TextColor="#8581A6" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="5h"
                                   FontSize="13"
                                   TextColor="#8581A6"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>

                    <Frame BackgroundColor="White"
                           CornerRadius="18"
                           Padding="16"
                           HasShadow="False"
                           BorderColor="#EEEAF8">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Frame WidthRequest="48"
                                   HeightRequest="48"
                                   CornerRadius="24"
                                   Padding="0"
                                   BackgroundColor="#FFF1F4"
                                   HasShadow="False">
                                <Label Text="👁"
                                       FontSize="22"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="Profil consulté"
                                       FontSize="16"
                                       TextColor="#111827" />
                                <Label Text="Bonne visibilité cette semaine."
                                       FontSize="13"
                                       TextColor="#8581A6" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="6h"
                                   FontSize="13"
                                   TextColor="#8581A6"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
