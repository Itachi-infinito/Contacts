<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Candidate.MatchesPage"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F9FFFD" Offset="0.0" />
            <GradientStop Color="#EAF8F5" Offset="0.4" />
            <GradientStop Color="#1ABC9C" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*"
          Padding="20,26,20,18">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              ColumnDefinitions="56,*,56"
              VerticalOptions="Center"
              Margin="0,0,0,18">

            <Button Grid.Column="0"
                    Text="☰"
                    FontSize="22"
                    BackgroundColor="Transparent"
                    TextColor="#0B1F1D"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="40"
                    Clicked="Menu_Clicked" />

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="4"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                    <Label Text="✦"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#1ABC9C" />
                    <Label Text="SparkWork"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#1ABC9C" />
                </HorizontalStackLayout>

                <Label Text="My Matches"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="#334A48"
                       HorizontalTextAlignment="Center" />

                <Label Text="Jobs that matched your profile"
                       FontSize="13"
                       TextColor="#5F7A75"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Label Grid.Column="2" />
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1">

            <Label x:Name="noMatchesLabel"
                   Text="No matches yet"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"
                   VerticalOptions="Center"
                   IsVisible="False" />

            <CollectionView x:Name="matchesCollection"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="16" />
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <Frame BackgroundColor="White"
                           BorderColor="#DCEDE7"
                           CornerRadius="22"
                           Padding="24"
                           HasShadow="True"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           WidthRequest="320">
                        <VerticalStackLayout Spacing="10"
                                             HorizontalOptions="Center">

                            <Label Text="✨"
                                   FontSize="38"
                                   HorizontalTextAlignment="Center" />

                            <Label Text="No matches yet"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#0B1F1D"
                                   HorizontalTextAlignment="Center" />

                            <Label Text="When a recruiter likes you back, your matched offers will appear here."
                                   FontSize="13"
                                   TextColor="#6A7A7A"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Frame>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>

                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItemView>
                                        <Grid WidthRequest="110"
                                              Margin="0,9,12,0"
                                              HorizontalOptions="End"
                                              VerticalOptions="Center">

                                            <Frame WidthRequest="70"
                                                   HeightRequest="70"
                                                   CornerRadius="35"
                                                   BackgroundColor="#EB4D47"
                                                   Padding="0"
                                                   HasShadow="False"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   BindingContext="{Binding .}"
                                                   Scale="0.96"
                                                   Loaded="SwipeBubble_Loaded">

                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="DeleteBubble_Tapped" />
                                                </Frame.GestureRecognizers>

                                                <Grid>
                                                    <Image Source="trash.png"
                                                           WidthRequest="60"
                                                           HeightRequest="60"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center"
                                                           Aspect="AspectFit" />
                                                </Grid>
                                            </Frame>
                                        </Grid>
                                    </SwipeItemView>
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Frame CornerRadius="20"
                                   Padding="15"
                                   Margin="0,0,0,16"
                                   BackgroundColor="White"
                                   HasShadow="True"
                                   Loaded="MatchCard_Loaded"
                                   Opacity="0"
                                   TranslationY="16"
                                   Scale="0.985">

                                <Grid RowDefinitions="Auto,Auto,Auto"
                                        ColumnDefinitions="*,Auto">

                                    <!-- Titre + société -->
                                    <VerticalStackLayout Grid.Row="0"
                                                         Grid.Column="0"
                                                         Spacing="4">
                                        <Label Text="{Binding JobTitle}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="#1ABC9C" />

                                        <Label Text="{Binding CompanyName}"
                                               FontSize="14"
                                               TextColor="Gray" />
                                    </VerticalStackLayout>

                                    <!-- Description -->
                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="Voir les détails de l'offre"
                                           FontSize="12"
                                           TextColor="Gray"
                                           Margin="0,10,0,10" />

                                    <!-- Bouton détail -->
                                    <Button Grid.Row="2"
                                            Grid.ColumnSpan="2"
                                            Text="Voir l'offre"
                                            BackgroundColor="#1ABC9C"
                                            TextColor="White"
                                            CornerRadius="10"
                                            Clicked="OnViewDetailsClicked"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </Frame>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>