<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.RecruiterHomePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#1ABC9C">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Label Text="Recruiter Home"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />

            <Label Text="Welcome to your recruiter space."
                   FontSize="16"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />

            <Button Text="Browse Candidates"
                    HeightRequest="55"
                    BackgroundColor="White"
                    TextColor="#1ABC9C"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    Clicked="BrowseCandidates_Clicked" />

            <Button Text="My Job Offers"
                    HeightRequest="55"
                    BackgroundColor="White"
                    TextColor="#1ABC9C"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    Clicked="JobOffers_Clicked" />
            <Button Text="Add Job Offer"
                    HeightRequest="55"
                    BackgroundColor="White"
                    TextColor="#1ABC9C"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    Clicked="AddJobOffer_Clicked" />
            <Button Text="Likes Received"
                    HeightRequest="55"
                    BackgroundColor="White"
                    TextColor="#1ABC9C"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    Clicked="LikesReceived_Clicked" />

            <Button Text="My Matches"
                    HeightRequest="55"
                    BackgroundColor="White"
                    TextColor="#1ABC9C"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    Clicked="Matches_Clicked" />

            <Button Text="Messages"
                    HeightRequest="55"
                    BackgroundColor="White"
                    TextColor="#1ABC9C"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    Clicked="Messages_Clicked" />

            <Button Text="My Profile"
                    HeightRequest="55"
                    BackgroundColor="White"
                    TextColor="#1ABC9C"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    Clicked="RecruiterProfile_Clicked" />

            <Button Text="Settings"
                    HeightRequest="55"
                    BackgroundColor="Transparent"
                    BorderColor="White"
                    BorderWidth="2"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    Clicked="Settings_Clicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>