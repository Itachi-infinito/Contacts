<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.RecruiterHomePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0"
                    BackgroundColor="White">
            <VerticalStackLayout Padding="20,32,20,24" Spacing="18">

                <!-- HEADER -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="lblGreeting"
                               Text="Bonjour"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#111827" />
                        <Label Text="Prêt à trouver votre prochain talent ?"
                               FontSize="13"
                               TextColor="#8B86A3" />
                    </VerticalStackLayout>

                    <Frame Grid.Column="1"
                           WidthRequest="52"
                           HeightRequest="52"
                           CornerRadius="26"
                           Padding="0"
                           HasShadow="False"
                           VerticalOptions="Center">
                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>
                        <Label x:Name="lblInitials"
                               Text="AL"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="16"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>
                </Grid>

                <!-- SEARCH BAR -->
                <Frame CornerRadius="18"
                       Padding="14,12"
                       BackgroundColor="#F8F6FF"
                       BorderColor="#DED8F5"
                       HasShadow="False">

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Text="⌕"
                               FontSize="18"
                               TextColor="#8B86A3"
                               VerticalTextAlignment="Center" />
                        <Label Grid.Column="1"
                               Text="Rechercher un candidat..."
                               FontSize="13"
                               TextColor="#A6A0C0"
                               VerticalTextAlignment="Center" />
                        <Button Grid.Column="2"
                                Text="Filtres"
                                HeightRequest="36"
                                Padding="14,0"
                                BackgroundColor="#F0EAFE"
                                TextColor="#7C4DFF"
                                FontAttributes="Bold"
                                FontSize="12"
                                CornerRadius="12" />

                    </Grid>
                </Frame>

                <!-- STATS -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Frame CornerRadius="18" Padding="16" BackgroundColor="#F8F6FF" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Candidats"
                                   FontSize="13"
                                   TextColor="#8581A6" />
                            <Label x:Name="lblCandidatesCount"
                                   Text="0"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Label Text="compatibles cette semaine"
                                   FontSize="11"
                                   TextColor="#7C4DFF" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1" CornerRadius="18" Padding="16" BackgroundColor="#F8F6FF" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Matchs"
                                   FontSize="13"
                                   TextColor="#8581A6" />
                            <Label x:Name="lblMatchesCount"
                                   Text="0"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Label Text="nouveaux échanges"
                                   FontSize="11"
                                   TextColor="#7C4DFF" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- CANDIDAT RECOMMANDÉ -->
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Candidat recommandé"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               VerticalTextAlignment="Center" />
                        <Frame Grid.Column="1"
                               BackgroundColor="#F0EAFE"
                            BorderColor="Transparent"
                            CornerRadius="12"
                            Padding="14,6"
                            HasShadow="False">

                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="BrowseCandidates_Tapped" />
                            </Frame.GestureRecognizers>
                            <Label Text="Voir"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#7C4DFF" />
                        </Frame>
                    </Grid>

                    <Frame CornerRadius="20"
                           Padding="16"
                           BackgroundColor="#F8F6FF"
                           BorderColor="#DED8F5"
                           HasShadow="False">

                        <VerticalStackLayout Spacing="10">

                            <!-- Name + score -->
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="lblRecommendedCandidateName"
                                       Text="Aucun candidat"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />
                                <Label Grid.Column="1"
                                       x:Name="lblRecommendedCandidateScore"
                                       Text=""
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#7C4DFF" />
                            </Grid>

                            <!-- Location · role · offre -->
                            <Label x:Name="lblRecommendedCandidateInfo"
                                   Text="Crée une offre pour obtenir une recommandation"
                                   FontSize="13"
                                   TextColor="#5F5A75" />

                            <!-- Skill chips (dynamic) -->
                            <FlexLayout x:Name="recommendedSkillsLayout"
                                        Direction="Row"
                                        Wrap="Wrap"
                                        AlignItems="Center"
                                        JustifyContent="Start" />

                            <!-- Progress bar -->
                            <Grid x:Name="recommendedProgressContainer"
                                  WidthRequest="260"
                                  HeightRequest="6"
                                  IsVisible="False">
                                <Frame BackgroundColor="#EEEAF8"
                                       CornerRadius="3"
                                       Padding="0"
                                       HasShadow="False" />
                                <Frame x:Name="recommendedProgressBar"
                                       WidthRequest="0"
                                       CornerRadius="3"
                                       Padding="0"
                                       HasShadow="False"
                                       HorizontalOptions="Start">
                                    <Frame.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#7C4DFF" Offset="0.0" />
                                            <GradientStop Color="#D34C88" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Frame.Background>
                                </Frame>
                            </Grid>

                            <!-- Voir le profil button -->
                            <Frame x:Name="viewProfileFrame"
                                   CornerRadius="16"
                                   Padding="0"
                                   HeightRequest="46"
                                   HasShadow="False"
                                   IsVisible="False">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="ViewRecommendedProfile_Tapped" />
                                </Frame.GestureRecognizers>
                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                                        <GradientStop Color="#D34C88" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>
                                <Label Text="Voir le profil"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <!-- POSTES ACTIFS -->
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Postes actifs"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               VerticalTextAlignment="Center" />
                        <Frame Grid.Column="1"
                               BackgroundColor="#F0EAFE"
                                BorderColor="Transparent"
                                CornerRadius="12"
                                Padding="14,6"
                                HasShadow="False">

                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="JobOffers_Tapped" />
                            </Frame.GestureRecognizers>
                            <Label Text="Tout voir"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#7C4DFF" />
                        </Frame>
                    </Grid>

                    <Frame CornerRadius="20"
                           Padding="16"
                           BackgroundColor="#F8F6FF"
                           BorderColor="#DED8F5"
                           HasShadow="False">

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Frame WidthRequest="44"
                                   HeightRequest="44"
                                   CornerRadius="12"
                                   Padding="0"
                                   BackgroundColor="#111827"
                                   HasShadow="False">
                                <Label x:Name="lblActiveOfferInitial"
                                       Text="?"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label x:Name="lblActiveOfferTitle"
                                       Text="Aucune offre active"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />
                                <Label x:Name="lblActiveOfferInfo"
                                       Text="Publie une offre pour commencer"
                                       FontSize="12"
                                       TextColor="#8B86A3" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   x:Name="lblActiveOfferCandidates"
                                   Text="0 profil"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#EF4444"
                                   VerticalTextAlignment="Center" />
                        </Grid>
                    </Frame>
                </VerticalStackLayout>

                <!-- BOTTOM ACTION BUTTONS -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Frame CornerRadius="16"
                           Padding="0"
                           HeightRequest="52"
                           HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="JobOffers_Tapped" />
                        </Frame.GestureRecognizers>
                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>
                        <Label Text="Mes offres"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="15"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>

                    <Frame Grid.Column="1"
                           CornerRadius="16"
                           Padding="0"
                           HeightRequest="52"
                           BackgroundColor="#F8F6FF" 
                           BorderColor="#DED8F5"
                           HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Matches_Tapped" />
                        </Frame.GestureRecognizers>
                        <Label Text="Matchs"
                               TextColor="#111827"
                               FontAttributes="Bold"
                               FontSize="15"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <!-- BOTTOM NAV -->
        <Grid Grid.Row="1"
              HeightRequest="78"
              BackgroundColor="White"
              Padding="4,8,4,10"
              ColumnDefinitions="*,*,*,*,*">

            <BoxView Grid.ColumnSpan="5"
                     HeightRequest="0.5"
                     Color="#E5E0F5"
                     VerticalOptions="Start" />

            <!-- Accueil actif -->
            <VerticalStackLayout Grid.Column="0"
                                 HorizontalOptions="Center"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <Label Text="&#xE88A;"
                       FontFamily="MaterialIcons"
                       FontSize="24"
                       TextColor="#7C4DFF"
                       HorizontalTextAlignment="Center" />
                <Label Text="Accueil"
                       FontSize="9"
                       TextColor="#7C4DFF"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
                <BoxView HeightRequest="4"
                         WidthRequest="4"
                         Color="#7C4DFF"
                         CornerRadius="2"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Découvrir -->
            <VerticalStackLayout Grid.Column="1"
                                 HorizontalOptions="Center"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Discover_Nav_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="&#xE8B6;"
                       FontFamily="MaterialIcons"
                       FontSize="24"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
                <Label Text="Découvrir"
                       FontSize="9"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Bouton + central -->
            <Border Grid.Column="2"
                    WidthRequest="46"
                    HeightRequest="46"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Margin="0,0,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="23" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="AddOffer_Nav_Tapped" />
                </Border.GestureRecognizers>
                <Label Text="+"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>

            <!-- Messages -->
            <VerticalStackLayout Grid.Column="3"
                                 HorizontalOptions="Center"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Messages_Nav_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="&#xE0BF;"
                       FontFamily="MaterialIcons"
                       FontSize="24"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
                <Label Text="Messages"
                       FontSize="9"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Profil -->
            <VerticalStackLayout Grid.Column="4"
                                 HorizontalOptions="Center"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Profile_Nav_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="&#xE7FD;"
                       FontFamily="MaterialIcons"
                       FontSize="24"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
                <Label Text="Profil"
                       FontSize="9"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

        </Grid>


    </Grid>
</ContentPage>