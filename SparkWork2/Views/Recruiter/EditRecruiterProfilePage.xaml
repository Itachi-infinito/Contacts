<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.EditRecruiterProfilePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="18,24,24,0"
              RowDefinitions="Auto,Auto"
              ColumnDefinitions="Auto,*,Auto">

            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="34"
                    Padding="0"
                    HeightRequest="44"
                    WidthRequest="44"
                    BackgroundColor="Transparent"
                    TextColor="#111827"
                    Clicked="Cancel_Clicked" />

            <Label Grid.Column="1"
                   Text="Modifier le profil"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />

            <Frame Grid.Column="2"
                   HeightRequest="46"
                   WidthRequest="46"
                   CornerRadius="23"
                   Padding="0"
                   HasShadow="False"
                   VerticalOptions="Center">
                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label x:Name="lblHeaderInitials"
                       Text="AL"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="15"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>

            <Grid Grid.Row="1"
                  Grid.ColumnSpan="3"
                  ColumnDefinitions="*,*,*"
                  Margin="0,22,0,0"
                  HeightRequest="42">

                <Label Text="DÉCOUVRIR"
                       Grid.Column="0"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />

                <Label Text="MESSAGES"
                       Grid.Column="1"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />

                <Label Text="STATS"
                       Grid.Column="2"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Grid>
        </Grid>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,24,20,28"
                                 Spacing="16">

                <!-- PHOTO -->
                <Frame CornerRadius="24"
                       Padding="20"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="14"
                                         HorizontalOptions="Center">

                        <Grid WidthRequest="112"
                              HeightRequest="112">

                            <Frame x:Name="photoPlaceholderFrame"
                                   WidthRequest="112"
                                   HeightRequest="112"
                                   CornerRadius="28"
                                   Padding="0"
                                   HasShadow="False">
                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                                        <GradientStop Color="#D34C88" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>

                                <Label x:Name="lblPhotoInitials"
                                       Text="AL"
                                       FontSize="30"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <Frame x:Name="photoImageFrame"
                                   WidthRequest="112"
                                   HeightRequest="112"
                                   CornerRadius="28"
                                   Padding="0"
                                   HasShadow="False"
                                   IsClippedToBounds="True"
                                   IsVisible="False">
                                <Image x:Name="imgCompanyPhoto"
                                       Aspect="AspectFill" />
                            </Frame>
                        </Grid>

                        <Button Text="Changer la photo"
                                HeightRequest="40"
                                Padding="18,0"
                                BackgroundColor="#F0EAFE"
                                TextColor="#7C4DFF"
                                FontAttributes="Bold"
                                FontSize="13"
                                CornerRadius="12"
                                Clicked="ChangePhoto_Clicked" />
                    </VerticalStackLayout>
                </Frame>

                <!-- MAIN INFO -->
                <Frame CornerRadius="24"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16">

                        <Label Text="Informations entreprise"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Nom de l'entreprise"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryCompanyName"
                                       Placeholder="Ex: Thales"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Secteur"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entrySector"
                                       Placeholder="Ex: Technologie"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Localisation"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryLocation"
                                       Placeholder="Ex: Bruxelles"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Email de contact"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryContactEmail"
                                       Placeholder="contact@example.com"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent"
                                       Keyboard="Email" />
                            </Frame>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- DESCRIPTION -->
                <Frame CornerRadius="24"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="Description"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Frame BackgroundColor="#FAF9FF"
                               BorderColor="#EEEAF8"
                               CornerRadius="14"
                               Padding="14,10"
                               HasShadow="False">
                            <Editor x:Name="editorDescription"
                                    Placeholder="Présente ton entreprise, ton équipe et le type de talents recherchés."
                                    PlaceholderColor="#A6A0C0"
                                    TextColor="#111827"
                                    BackgroundColor="Transparent"
                                    AutoSize="TextChanges"
                                    HeightRequest="130" />
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- ACTIONS -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,4,0,0">

                    <Button Grid.Column="0"
                            Text="Annuler"
                            HeightRequest="52"
                            BackgroundColor="White"
                            BorderColor="#DED8F5"
                            BorderWidth="1"
                            TextColor="#111827"
                            FontAttributes="Bold"
                            CornerRadius="14"
                            Clicked="Cancel_Clicked" />

                    <Button Grid.Column="1"
                            Text="Enregistrer"
                            HeightRequest="52"
                            BackgroundColor="#7C4DFF"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="14"
                            Clicked="Update_Clicked" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
