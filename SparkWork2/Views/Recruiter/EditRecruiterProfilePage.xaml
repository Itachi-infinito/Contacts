<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.EditRecruiterProfilePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,28,24,24"
                                 Spacing="18">

                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Profil entreprise"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label Text="Votre vitrine auprès des candidats"
                               FontSize="13"
                               TextColor="#8B86A3" />
                    </VerticalStackLayout>

                    <Frame Grid.Column="1"
                           WidthRequest="52"
                           HeightRequest="52"
                           CornerRadius="26"
                           Padding="0"
                           HasShadow="False">

                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>

                        <Label x:Name="lblHeaderInitials"
                               Text="AL"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="16"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>
                </Grid>

                <Frame CornerRadius="26"
                       Padding="20"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16"
                                         HorizontalOptions="Center">

                        <Grid WidthRequest="116"
                              HeightRequest="116">

                            <Frame x:Name="companyPlaceholderFrame"
                                   WidthRequest="116"
                                   HeightRequest="116"
                                   CornerRadius="30"
                                   Padding="0"
                                   HasShadow="False">

                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                                        <GradientStop Color="#D34C88" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>

                                <Label x:Name="lblCompanyInitials"
                                       Text="AL"
                                       FontSize="30"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <Frame x:Name="companyPhotoFrame"
                                   WidthRequest="116"
                                   HeightRequest="116"
                                   CornerRadius="30"
                                   Padding="0"
                                   HasShadow="False"
                                   IsClippedToBounds="True"
                                   IsVisible="False">

                                <Image x:Name="imgCompanyPhoto"
                                       Aspect="AspectFill" />
                            </Frame>
                        </Grid>

                        <VerticalStackLayout Spacing="5"
                                             HorizontalOptions="Center">

                            <Label x:Name="lblCompanyName"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="Center" />

                            <Label x:Name="lblSector"
                                   FontSize="15"
                                   TextColor="#7C4DFF"
                                   HorizontalTextAlignment="Center" />

                            <Label x:Name="lblLocation"
                                   FontSize="13"
                                   TextColor="#8581A6"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <Button Text="Modifier le profil"
                                HeightRequest="46"
                                Padding="22,0"
                                BackgroundColor="#7C4DFF"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="16"
                                Clicked="EditProfile_Clicked" />
                    </VerticalStackLayout>
                </Frame>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">

                    <Frame CornerRadius="18"
                           Padding="16"
                           BackgroundColor="White"
                           BorderColor="#EEEAF8"
                           HasShadow="False">

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Offres actives"
                                   FontSize="12"
                                   TextColor="#8581A6" />

                            <Label x:Name="lblOffersCount"
                                   Text="0"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Label Text="publiées"
                                   FontSize="11"
                                   TextColor="#10B981" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1"
                           CornerRadius="18"
                           Padding="16"
                           BackgroundColor="White"
                           BorderColor="#EEEAF8"
                           HasShadow="False">

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Matchs"
                                   FontSize="12"
                                   TextColor="#8581A6" />

                            <Label x:Name="lblMatchesCount"
                                   Text="0"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Label Text="conversations"
                                   FontSize="11"
                                   TextColor="#7C4DFF" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Frame CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="À propos"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label x:Name="lblDescription"
                               FontSize="14"
                               TextColor="#5F5A75"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="14">

                        <Label Text="Informations"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">

                            <Label Text="Email"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Label Grid.Column="1"
                                   x:Name="lblContactEmail"
                                   FontSize="14"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="End"
                                   LineBreakMode="TailTruncation" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="#EEEAF8" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">

                            <Label Text="Statut"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Label Grid.Column="1"
                                   Text="Visible par les candidats"
                                   FontSize="14"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="End" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Button Text="Paramètres"
                        HeightRequest="50"
                        BackgroundColor="White"
                        BorderColor="#DED8F5"
                        BorderWidth="1"
                        TextColor="#111827"
                        FontAttributes="Bold"
                        CornerRadius="16"
                        Clicked="Settings_Clicked" />
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              BackgroundColor="White"
              Padding="18,8,18,18"
              ColumnDefinitions="*,*,Auto,*,*">

            <Button Text="Accueil"
                    Grid.Column="0"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Home_Clicked" />

            <Button Grid.Column="1"
                    Text="Découvrir"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Discover_Clicked" />

            <Frame Grid.Column="2"
                   WidthRequest="50"
                   HeightRequest="50"
                   CornerRadius="25"
                   Padding="0"
                   BackgroundColor="#7C4DFF"
                   HasShadow="True"
                   Margin="8,0">

                <Frame.Shadow>
                    <Shadow Brush="#557C4DFF"
                            Offset="0,8"
                            Radius="18" />
                </Frame.Shadow>

                <Button Text="+"
                        FontSize="24"
                        FontAttributes="Bold"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        Clicked="AddOffer_Clicked" />
            </Frame>

            <Button Grid.Column="3"
                    Text="Messages"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Messages_Clicked" />

            <Button Grid.Column="4"
                    Text="Profil"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#7C4DFF" />
        </Grid>
    </Grid>
</ContentPage>
