<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.RecruiterSwipePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="16,28,20,10"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="10">

            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="32"
                    Padding="0"
                    HeightRequest="44"
                    WidthRequest="44"
                    BackgroundColor="Transparent"
                    TextColor="#111827"
                    Clicked="Back_Clicked" />

            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                <Label Text="Candidats"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#111827" />
                <Label Text="Profils compatibles avec vos offres"
                       FontSize="13"
                       TextColor="#8B86A3" />
            </VerticalStackLayout>

            <Frame Grid.Column="2"
                   HeightRequest="52"
                   WidthRequest="52"
                   CornerRadius="26"
                   Padding="0"
                   HasShadow="False"
                   VerticalOptions="Center">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Profile_Tapped" />
                </Frame.GestureRecognizers>
                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>
                <Label x:Name="lblHeaderInitials"
                       Text="AI"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="16"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>
        </Grid>

        <!-- CARD AREA -->
        <Grid Grid.Row="1">
            <ScrollView x:Name="cardScrollView" Padding="0,10,0,0">
                <VerticalStackLayout Spacing="14" HorizontalOptions="Center">

                    <!-- OFFER FILTER -->
                    <Border x:Name="offerFilterCard"
                            WidthRequest="344"
                            StrokeThickness="1"
                            Stroke="#E5E0F5"
                            BackgroundColor="#F8F6FF">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12"
                              Padding="14,10">

                            <Border WidthRequest="32"
                                    HeightRequest="32"
                                    BackgroundColor="#EEEDFE"
                                    StrokeThickness="0"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Label Text="&#xE152;"
                                       FontFamily="MaterialIcons"
                                       FontSize="17"
                                       TextColor="#7C4DFF"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="1"
                                                 VerticalOptions="Center">
                                <Label Text="Offre pour le matching"
                                       FontSize="10"
                                       TextColor="#8b82b0" />
                                <Picker x:Name="offerFilterPicker"
                                        Title="Toutes mes offres"
                                        ItemDisplayBinding="{Binding Title}"
                                        SelectedIndexChanged="OfferFilterPicker_SelectedIndexChanged"
                                        TextColor="#1a1a2e"
                                        TitleColor="#1a1a2e"
                                        FontAttributes="Bold"
                                        FontSize="13" />
                            </VerticalStackLayout>

                            <Border Grid.Column="2"
                                    BackgroundColor="#EEEDFE"
                                    StrokeThickness="0"
                                    VerticalOptions="Center"
                                    Padding="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Label Text="Toutes"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#534AB7"
                                       Padding="12,5"
                                       HorizontalTextAlignment="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="ClearOfferFilter_Clicked" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                        </Grid>
                    </Border>

                    <!-- CANDIDATE CARD -->
                    <Frame x:Name="candidateCard"
                           WidthRequest="344"
                           BackgroundColor="White"
                           CornerRadius="24"
                           Padding="0"
                           HasShadow="True"
                           IsClippedToBounds="True">
                        <Frame.Shadow>
                            <Shadow Brush="#30A78BFA" Offset="0,16" Radius="28" Opacity="1" />
                        </Frame.Shadow>
                        <Frame.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="Card_PanUpdated" />
                        </Frame.GestureRecognizers>

                        <Grid RowDefinitions="256,Auto,Auto">

                            <!-- IMAGE WITH GRADIENT -->
                            <Grid Grid.Row="0">
                                <Frame CornerRadius="0" Padding="0" HasShadow="False" IsClippedToBounds="True">
                                    <Grid>
                                        <Image x:Name="imgCandidate"
                                               Aspect="AspectFill"
                                               IsVisible="True" />

                                        <!-- Gradient overlay : transparent top → dark bottom -->
                                        <BoxView>
                                            <BoxView.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#007C4DFF" Offset="0.0" />
                                                    <GradientStop Color="#10000000" Offset="0.35" />
                                                    <GradientStop Color="#D0000000" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </BoxView.Background>
                                        </BoxView>

                                        <Grid x:Name="candidatePlaceholderIllustration" IsVisible="False" />

                                        <!-- Actif badge -->
                                        <Frame BackgroundColor="White"
                                               CornerRadius="16"
                                               Padding="10,5"
                                               HasShadow="False"
                                               HorizontalOptions="End"
                                               VerticalOptions="Start"
                                               Margin="0,14,14,0">
                                            <HorizontalStackLayout Spacing="5">
                                                <Ellipse WidthRequest="7"
                                                         HeightRequest="7"
                                                         Fill="#5ED0A0"
                                                         VerticalOptions="Center" />
                                                <Label Text="Actif"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="#374151" />
                                            </HorizontalStackLayout>
                                        </Frame>

                                        <!-- Name overlay on image -->
                                        <VerticalStackLayout Padding="18,0,18,20"
                                                             Spacing="4"
                                                             VerticalOptions="End">
                                            <Label x:Name="lblFullName"
                                                   FontSize="26"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   LineBreakMode="TailTruncation" />
                                            <Label x:Name="lblTitle"
                                                   FontSize="14"
                                                   TextColor="#E8E0FF"
                                                   LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>

                                        <!-- Swipe overlays -->
                                        <Label x:Name="lblLikeOverlay"
                                               Text="VALIDÉ ✓"
                                               FontSize="26"
                                               FontAttributes="Bold"
                                               TextColor="#10B981"
                                               Rotation="-15"
                                               Opacity="0"
                                               HorizontalOptions="Start"
                                               VerticalOptions="Start"
                                               Margin="20,30,0,0" />
                                        <Label x:Name="lblNopeOverlay"
                                               Text="PASSÉ ✗"
                                               FontSize="26"
                                               FontAttributes="Bold"
                                               TextColor="#EF4444"
                                               Rotation="15"
                                               Opacity="0"
                                               HorizontalOptions="End"
                                               VerticalOptions="Start"
                                               Margin="0,30,20,0" />
                                    </Grid>
                                </Frame>
                            </Grid>

                            <!-- CARD INFO -->
                            <VerticalStackLayout Grid.Row="1"
                                                 Padding="18,16,18,18"
                                                 Spacing="12">

                                <!-- Compatibility bar -->
                                <Frame x:Name="compatibilityBadge"
                                       BackgroundColor="Transparent"
                                       Padding="0"
                                       HasShadow="False"
                                       IsVisible="False">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                        <Label Text="Compatibilité"
                                               FontSize="13"
                                               TextColor="#8581A6"
                                               VerticalTextAlignment="Center" />
                                        <Grid Grid.Column="1"
                                              WidthRequest="118"
                                              HeightRequest="6"
                                              VerticalOptions="Center">

                                            <Frame BackgroundColor="#EEEAF8"
                                                   CornerRadius="3"
                                                   Padding="0"
                                                   HasShadow="False" />
                                            <Frame x:Name="compatibilityProgressBar"
                                                   WidthRequest="0"
                                                   CornerRadius="3"
                                                   Padding="0"
                                                   HasShadow="False"
                                                   HorizontalOptions="Start">
                                                <Frame.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                                                        <GradientStop Color="#D34C88" Offset="1.0" />
                                                    </LinearGradientBrush>
                                                </Frame.Background>
                                            </Frame>
                                        </Grid>
                                        <Label x:Name="lblCompatibility"
                                               Grid.Column="2"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="#7C4DFF"
                                               VerticalTextAlignment="Center" />
                                    </Grid>
                                </Frame>

                                <!-- Skill & contract badges -->
                                <FlexLayout x:Name="skillsBadgesLayout"
                                            Direction="Row"
                                            Wrap="Wrap"
                                            AlignItems="Center"
                                            JustifyContent="Start"
                                            IsVisible="False" />

                                <!-- Salary preference -->
                                <Label x:Name="lblCandidatePreferences"
                                       FontSize="13"
                                       TextColor="#5F5A75"
                                       IsVisible="False" />

                                <!-- Location + distance (combined) -->
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="📍"
                                           FontSize="13"
                                           TextColor="#8B86A3"
                                           VerticalTextAlignment="Center" />
                                    <Label x:Name="lblLocation"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#8581A6"
                                           VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <!-- EXPANDED DETAILS -->
                            <VerticalStackLayout x:Name="expandedDetailsSection"
                                                 Grid.Row="2"
                                                 IsVisible="False"
                                                 Opacity="0"
                                                 Padding="20,0,20,22"
                                                 Spacing="8">
                                <BoxView HeightRequest="1" Color="#EEEAF8" />
                                <Label Text="Détails du candidat"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />
                                <Label x:Name="lblDetailSkills" TextColor="#374151" IsVisible="False" />
                                <Label x:Name="lblDetailDesiredContractType" TextColor="#374151" IsVisible="False" />
                                <Label x:Name="lblDetailExperienceLevel" TextColor="#374151" IsVisible="False" />
                                <Label x:Name="lblDetailDesiredSalary" TextColor="#374151" IsVisible="False" />
                                <Label x:Name="lblDetailDistanceToOffer" TextColor="#374151" IsVisible="False" />
                                <Label x:Name="lblDetailCompatibility" TextColor="#7C4DFF" IsVisible="False" />

                                <VerticalStackLayout x:Name="aboutSection" Spacing="6">
                                    <Label Text="Profil"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                    <Label x:Name="lblAbout"
                                           FontSize="13"
                                           LineBreakMode="WordWrap"
                                           TextColor="#5F5A75" />
                                </VerticalStackLayout>

                                <VerticalStackLayout x:Name="experienceSection" Spacing="10" IsVisible="False">
                                    <BoxView HeightRequest="1" Color="#EEEAF8" Margin="0,4,0,0" />
                                    <Label Text="Expériences"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                    <VerticalStackLayout x:Name="experience1Layout" Spacing="2" IsVisible="False">
                                        <Label x:Name="lblExperienceTitle1" FontSize="13" FontAttributes="Bold" TextColor="#111827" />
                                        <Label x:Name="lblExperienceCompany1" FontSize="12" TextColor="#7C4DFF" />
                                        <Label x:Name="lblExperiencePeriod1" FontSize="11" TextColor="#8B86A3" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout x:Name="experience2Layout" Spacing="2" IsVisible="False">
                                        <Label x:Name="lblExperienceTitle2" FontSize="13" FontAttributes="Bold" TextColor="#111827" />
                                        <Label x:Name="lblExperienceCompany2" FontSize="12" TextColor="#7C4DFF" />
                                        <Label x:Name="lblExperiencePeriod2" FontSize="11" TextColor="#8B86A3" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>

                    <Label x:Name="lblSwipeHint"
                           Text="‹ Passer    •    Retenir ›"
                           FontSize="12"
                           TextColor="#B0ABCE"
                           HorizontalTextAlignment="Center" />

                </VerticalStackLayout>
            </ScrollView>

            <!-- EMPTY STATE -->
            <VerticalStackLayout x:Name="emptyStateSection"
                                 IsVisible="False"
                                 Spacing="20"
                                 Padding="32,0"
                                 HorizontalOptions="Fill"
                                 VerticalOptions="Center"
                                 BackgroundColor="White">

                <Grid WidthRequest="260"
                      HeightRequest="170"
                      HorizontalOptions="Center"
                      Margin="0,0,0,0">

                    <Border x:Name="emptyCardLeft"
                            WidthRequest="54"
                            HeightRequest="74"
                            StrokeThickness="0"
                            Rotation="-10"
                            HorizontalOptions="Start"
                            VerticalOptions="Start"
                            Margin="34,4,0,0"
                            Opacity="0.72">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#D8CCFF" Offset="0.0" />
                                <GradientStop Color="#A78BFA" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Border x:Name="emptyCardRight"
                            WidthRequest="54"
                            HeightRequest="74"
                            StrokeThickness="0"
                            Rotation="10"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="0,18,34,0"
                            Opacity="0.72">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FBCFE8" Offset="0.0" />
                                <GradientStop Color="#EC4899" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Ellipse WidthRequest="88"
                             HeightRequest="88"
                             Stroke="#CFC4FF"
                             StrokeThickness="1.5"
                             StrokeDashArray="6,4"
                             Fill="Transparent"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,0,0,4" />

                    <Border x:Name="emptyStateIcon"
                            WidthRequest="62"
                            HeightRequest="62"
                            StrokeThickness="0"
                            HorizontalOptions="Center"
                            VerticalOptions="End"
                            Margin="0,0,0,17">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="31" />
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>

                        <Label Text="✓"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Border>
                </Grid>



                <Label Text="Vous avez tout vu !" FontSize="22" FontAttributes="Bold"
                         TextColor="#111827" HorizontalTextAlignment="Center" />
                <Label x:Name="lblEmptyMessage"
                       Text="Revenez bientôt pour découvrir de nouveaux candidats compatibles avec vos offres."
                       FontSize="14" TextColor="#8B86A3" LineBreakMode="WordWrap"
                       HorizontalTextAlignment="Center" />

                <Frame CornerRadius="27" HeightRequest="54" Padding="0" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Reload_Tapped" />
                    </Frame.GestureRecognizers>
                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C4DFF" Offset="0.0" />
                            <GradientStop Color="#D34C88" Offset="1.0" />
                        </LinearGradientBrush>
                    </Frame.Background>
                    <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                        <Label Text="↺" FontSize="20" TextColor="White" VerticalTextAlignment="Center" />
                        <Label Text="Actualiser" FontSize="16" FontAttributes="Bold" TextColor="White"
                                VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>
                </Frame>

                <Label Text="• Nouveaux profils ajoutés chaque jour •"
                         FontSize="12" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- ACTION BUTTONS -->
        <Grid x:Name="actionsGrid"
              Grid.Row="2"
              ColumnDefinitions="*,Auto,*"
              ColumnSpacing="12"
              Padding="20,8,20,18">

            <!-- Passer -->
            <Border HeightRequest="52"
                    StrokeThickness="1.5"
                    Stroke="#F9D0E2"
                    BackgroundColor="White">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="26" />
                </Border.StrokeShape>
                <Button Text="✕  Passer"
                        BackgroundColor="Transparent"
                        TextColor="#D34C88"
                        FontSize="15"
                        FontAttributes="Bold"
                        Clicked="Reject_Clicked" />
            </Border>

            <!-- Favori -->
            <Border Grid.Column="1"
                    WidthRequest="54" HeightRequest="54"
                    StrokeThickness="1.5"
                    Stroke="#FEF3C7"
                    BackgroundColor="White">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="27" />
                </Border.StrokeShape>
                <Button Text="☆"
                        BackgroundColor="Transparent"
                        TextColor="#F59E0B"
                        FontSize="26"
                        FontAttributes="Bold"
                        Clicked="SuperLike_Clicked" />
            </Border>

            <!-- Retenir -->
            <Border Grid.Column="2"
                    HeightRequest="52"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="26" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Button Text="Retenir ✓"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold"
                        Clicked="Like_Clicked" />
            </Border>

            
        </Grid>

        <!-- BOTTOM NAV -->
        <Grid Grid.Row="3"
              HeightRequest="78"
              BackgroundColor="White"
              Padding="4,6,4,10"
              ColumnDefinitions="*,*,*,*,*">


            <BoxView Grid.ColumnSpan="5"
                    HeightRequest="0.5"
                    Color="#E5E0F5"
                    VerticalOptions="Start" />

            <!-- Accueil -->
            <VerticalStackLayout Grid.Column="0"
                                 HorizontalOptions="Center"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Home_Nav_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="&#xE88A;"
                       FontFamily="MaterialIcons"
                       FontSize="24"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
                <Label Text="Accueil"
                       FontSize="9"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Découvrir (actif) -->
            <VerticalStackLayout Grid.Column="1"
                                 HorizontalOptions="Center"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <Label Text="&#xE8B6;"
                       FontFamily="MaterialIcons"
                       FontSize="24"
                       TextColor="#7C4DFF"
                       HorizontalTextAlignment="Center" />
                <Label Text="Découvrir"
                       FontSize="9"
                       TextColor="#7C4DFF"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
                <BoxView HeightRequest="4"
                         WidthRequest="4"
                         Color="#7C4DFF"
                         CornerRadius="2"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Bouton + central -->
            <Border Grid.Column="2"
                    WidthRequest="46"
                    HeightRequest="46"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Margin="0,0,0,0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="AddOffer_Nav_Tapped" />
                </Border.GestureRecognizers>
                <Label Text="+"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />

            </Border>

            <!-- Messages -->
            <VerticalStackLayout Grid.Column="3"
                         HorizontalOptions="Center"
                         Spacing="2"
                         VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Messages_Nav_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="&#xE0BF;"
                       FontFamily="MaterialIcons"
                       FontSize="24"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
                <Label Text="Messages"
                       FontSize="9"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Profil -->
            <VerticalStackLayout Grid.Column="4"
                                 HorizontalOptions="Center"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Profile_Nav_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="&#xE7FD;"
                       FontFamily="MaterialIcons"
                       FontSize="24"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
                <Label Text="Profil"
                       FontSize="9"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>