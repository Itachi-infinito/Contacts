<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.RecruiterSwipePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="Auto,*,Auto">

        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="28,26,28,0"
              RowDefinitions="Auto,Auto"
              ColumnDefinitions="*,Auto">

            <Label Text="SparkWork"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#7C4DFF"
                   VerticalOptions="Center" />

            <ImageButton x:Name="btnHeaderExpandCollapse"
                         Grid.Column="1"
                         Source="arrow_down.png"
                         IsVisible="False"
                         BackgroundColor="Transparent"
                         Clicked="ToggleDetails_Clicked" />

            <Frame Grid.Column="1"
                   HeightRequest="54"
                   WidthRequest="54"
                   CornerRadius="27"
                   Padding="0"
                   HasShadow="False"
                   HorizontalOptions="End"
                   VerticalOptions="Center">

                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Profile_Tapped" />
                </Frame.GestureRecognizers>

                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label Text="AL"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="16"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>

            <Grid Grid.Row="1"
                  Grid.ColumnSpan="2"
                  ColumnDefinitions="*,*,*"
                  Margin="0,24,0,0"
                  HeightRequest="42">

                <Label Text="DÉCOUVRIR"
                       Grid.Column="0"
                       FontSize="15"
                       TextColor="#7C4DFF"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Discover_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="MESSAGES"
                       Grid.Column="1"
                       FontSize="15"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Messages_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="STATS"
                       Grid.Column="2"
                       FontSize="15"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Stats_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <BoxView Grid.Column="0"
                         HeightRequest="3"
                         Color="#7C4DFF"
                         VerticalOptions="End"
                         Margin="14,0,14,0" />
            </Grid>
        </Grid>

        <Grid Grid.Row="1">

            <ScrollView x:Name="cardScrollView"
                        Padding="0,64,0,0">

                <VerticalStackLayout Spacing="16"
                                     HorizontalOptions="Center">
                    <Frame x:Name="offerFilterCard"
                           WidthRequest="320"
                           CornerRadius="20"
                           Padding="14"
                           BackgroundColor="White"
                           BorderColor="#EEEAF8"
                           HasShadow="False">

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Offre de référence"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Picker x:Name="offerFilterPicker"
                                        Title="Toutes mes offres"
                                        ItemDisplayBinding="{Binding Title}"
                                        SelectedIndexChanged="OfferFilterPicker_SelectedIndexChanged"
                                        TextColor="#111827"
                                        TitleColor="#A6A0C0" />

                                <Button Grid.Column="1"
                                        Text="Toutes"
                                        HeightRequest="38"
                                        Padding="12,0"
                                        BackgroundColor="#F0EAFE"
                                        TextColor="#7C4DFF"
                                        FontAttributes="Bold"
                                        CornerRadius="12"
                                        Clicked="ClearOfferFilter_Clicked" />
                            </Grid>

                            <Label x:Name="lblOfferFilterHint"
                                   Text="Les candidats seront triés par compatibilité."
                                   FontSize="12"
                                   TextColor="#8B86A3" />
                        </VerticalStackLayout>
                    </Frame>


                    <Frame x:Name="candidateCard"
                           WidthRequest="320"
                           BackgroundColor="White"
                           CornerRadius="24"
                           Padding="0"
                           HasShadow="True"
                           IsClippedToBounds="True">

                        <Frame.Shadow>
                            <Shadow Brush="#25A78BFA"
                                    Offset="0,18"
                                    Radius="32"
                                    Opacity="1" />
                        </Frame.Shadow>

                        <Frame.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="Card_PanUpdated" />
                        </Frame.GestureRecognizers>

                        <Grid RowDefinitions="220,Auto,Auto">

                            <Grid Grid.Row="0">
                                <Frame CornerRadius="0"
                                       Padding="0"
                                       HasShadow="False"
                                       IsClippedToBounds="True">

                                    <Frame.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F7DA9F" Offset="0.0" />
                                            <GradientStop Color="#F0C76C" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Frame.Background>

                                    <Grid>
                                        <Image x:Name="imgCandidate"
                                               Aspect="AspectFill"
                                               Opacity="0"
                                               IsVisible="False" />

                                        <Grid x:Name="candidatePlaceholderIllustration">
                                            <Ellipse WidthRequest="84"
                                                     HeightRequest="104"
                                                     Fill="#E9A22F"
                                                     Opacity="0.85"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     Margin="0,-18,0,0" />

                                            <Ellipse WidthRequest="56"
                                                     HeightRequest="56"
                                                     Fill="White"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     Margin="0,-82,0,0" />

                                            <Ellipse WidthRequest="38"
                                                     HeightRequest="38"
                                                     Fill="#E9A22F"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     Margin="0,-82,0,0" />

                                            <Ellipse WidthRequest="116"
                                                     HeightRequest="76"
                                                     Fill="#EFC84E"
                                                     Opacity="0.8"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="End"
                                                     Margin="0,0,0,22" />
                                        </Grid>
                                    </Grid>
                                </Frame>

                                <Frame BackgroundColor="White"
                                       CornerRadius="16"
                                       Padding="8,3"
                                       HasShadow="False"
                                       HorizontalOptions="End"
                                       VerticalOptions="Start"
                                       Margin="0,16,14,0">
                                    <HorizontalStackLayout Spacing="4">
                                        <Ellipse WidthRequest="6"
                                                 HeightRequest="6"
                                                 Fill="#5ED0A0"
                                                 VerticalOptions="Center" />
                                        <Label Text="Actif"
                                               FontSize="12"
                                               TextColor="#7C4DFF" />
                                    </HorizontalStackLayout>
                                </Frame>

                                <Label x:Name="lblLikeOverlay"
                                       Text="LIKE"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="#10B981"
                                       Rotation="-15"
                                       Opacity="0"
                                       HorizontalOptions="Start"
                                       VerticalOptions="Start"
                                       Margin="22,32,0,0" />

                                <Label x:Name="lblNopeOverlay"
                                       Text="NOPE"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="#EF4444"
                                       Rotation="15"
                                       Opacity="0"
                                       HorizontalOptions="End"
                                       VerticalOptions="Start"
                                       Margin="0,32,22,0" />
                            </Grid>

                            <VerticalStackLayout Grid.Row="1"
                                                 Padding="20,16,20,26"
                                                 Spacing="7">

                                <Label x:Name="lblFullName"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />

                                <Label x:Name="lblTitle"
                                       FontSize="13"
                                       TextColor="#7D7898" />

                                <Label x:Name="lblLocation"
                                       IsVisible="False" />

                                <FlexLayout x:Name="skillsBadgesLayout"
                                            Direction="Row"
                                            Wrap="Wrap"
                                            AlignItems="Center"
                                            JustifyContent="Start"
                                            IsVisible="False" />
                                

                                <Label x:Name="lblCandidatePreferences"
                                       FontSize="13"
                                       TextColor="#111827"
                                       IsVisible="False" />
                                <Frame x:Name="compatibilityBadge"
                                       BackgroundColor="#F0EAFE"
                                       CornerRadius="14"
                                       Padding="10,5"
                                       HasShadow="False"
                                       HorizontalOptions="Start"
                                       IsVisible="False">

                                    <Label x:Name="lblCompatibility"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#7C4DFF" />
                                </Frame>

                                <Label x:Name="lblDistanceToOffer"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#7C4DFF"
                                       IsVisible="False" />


                            </VerticalStackLayout>

                            <VerticalStackLayout x:Name="expandedDetailsSection"
                                                 Grid.Row="2"
                                                 IsVisible="False"
                                                 Opacity="0"
                                                 Padding="20,0,20,22"
                                                 Spacing="8">

                                <BoxView HeightRequest="1"
                                         Color="#EEEAF8" />

                                <Label Text="Détails du candidat"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />

                                <Label x:Name="lblDetailFullName"
                                       TextColor="#374151" />

                                <Label x:Name="lblDetailTitle"
                                       TextColor="#374151" />

                                <Label x:Name="lblDetailLocation"
                                       TextColor="#374151" />
                                <Label x:Name="lblDetailSkills"
                                       TextColor="#374151"
                                       IsVisible="False" />

                                <Label x:Name="lblDetailDesiredContractType"
                                       TextColor="#374151"
                                       IsVisible="False" />

                                <Label x:Name="lblDetailExperienceLevel"
                                       TextColor="#374151"
                                       IsVisible="False" />

                                <Label x:Name="lblDetailDesiredSalary"
                                       TextColor="#374151"
                                       IsVisible="False" />
                                <Label x:Name="lblDetailDistanceToOffer"
                                       TextColor="#374151"
                                       IsVisible="False" />
                                <Label x:Name="lblDetailCompatibility"
                                       TextColor="#374151"
                                       IsVisible="False" />




                                <VerticalStackLayout x:Name="aboutSection"
                                                     Spacing="6">
                                    <Label Text="Profil"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />

                                    <Label x:Name="lblAbout"
                                           FontSize="13"
                                           LineBreakMode="WordWrap"
                                           TextColor="#5F5A75" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>

                    <Label x:Name="lblSwipeHint"
                           Text="← Passer    •    Liker →"
                           FontSize="12"
                           TextColor="#8B86A3"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </ScrollView>

            <VerticalStackLayout x:Name="emptyStateSection"
                                 IsVisible="False"
                                 Spacing="14"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">

                <Label x:Name="lblEmptyMessage"
                       Text="No more candidates right now."
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center" />

                <Button x:Name="btnRefreshCandidates"
                        Text="Refresh"
                        HeightRequest="42"
                        WidthRequest="136"
                        BackgroundColor="#7C4DFF"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        Clicked="Reload_Clicked" />
            </VerticalStackLayout>
        </Grid>

        <Grid x:Name="actionsGrid"
              Grid.Row="2"
              ColumnDefinitions="*,*,*"
              ColumnSpacing="20"
              Padding="80,0,80,36"
              HorizontalOptions="Fill">

            <Frame Grid.Column="0"
                   HeightRequest="58"
                   WidthRequest="58"
                   CornerRadius="10"
                   Padding="0"
                   BackgroundColor="White"
                   HasShadow="True"
                   HorizontalOptions="Center">
                <Frame.Shadow>
                    <Shadow Brush="#35EF4D7A"
                            Offset="0,10"
                            Radius="18" />
                </Frame.Shadow>
                <Button Text="×"
                        FontSize="24"
                        TextColor="#111827"
                        BackgroundColor="Transparent"
                        Clicked="Reject_Clicked" />
            </Frame>

            <Frame Grid.Column="1"
                   HeightRequest="58"
                   WidthRequest="64"
                   CornerRadius="10"
                   Padding="0"
                   BackgroundColor="White"
                   HasShadow="True"
                   HorizontalOptions="Center">
                <Frame.Shadow>
                    <Shadow Brush="#456FD6A5"
                            Offset="0,12"
                            Radius="22" />
                </Frame.Shadow>
                <Button Text="♥"
                        FontSize="22"
                        TextColor="#111827"
                        BackgroundColor="Transparent"
                        Clicked="Like_Clicked" />
            </Frame>

            <Frame Grid.Column="2"
                   HeightRequest="58"
                   WidthRequest="58"
                   CornerRadius="10"
                   Padding="0"
                   BackgroundColor="White"
                   HasShadow="True"
                   HorizontalOptions="Center">
                <Frame.Shadow>
                    <Shadow Brush="#357C4DFF"
                            Offset="0,10"
                            Radius="18" />
                </Frame.Shadow>
                <Button Text="★"
                        FontSize="22"
                        TextColor="#111827"
                        BackgroundColor="Transparent" />
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
