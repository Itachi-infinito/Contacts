<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.RecruiterProfilePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0" BackgroundColor="#F8F6FF">
            <VerticalStackLayout Padding="28,34,28,24" Spacing="18">

                <!-- HEADER -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Profil"
                               FontSize="30"
                               FontAttributes="Bold"
                               TextColor="#111827" />
                        <Label Text="Votre vitrine auprès des candidats"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#8B86A3" />
                    </VerticalStackLayout>

                    <Frame Grid.Column="1"
                           WidthRequest="54"
                           HeightRequest="54"
                           CornerRadius="27"
                           Padding="0"
                           HasShadow="False">
                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>
                        <Label x:Name="lblHeaderInitials"
                               Text="M"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="18"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>
                </Grid>

                <!-- HERO PROFILE -->
                <Frame CornerRadius="26"
                       Padding="22"
                       BackgroundColor="White"
                       BorderColor="#DED8F5"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16" HorizontalOptions="Center">

                        <Grid WidthRequest="116" HeightRequest="116">
                            <Frame x:Name="companyPlaceholderFrame"
                                   WidthRequest="108"
                                   HeightRequest="108"
                                   CornerRadius="30"
                                   Padding="0"
                                   HasShadow="False"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                                        <GradientStop Color="#D34C88" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>
                                <Label x:Name="lblCompanyInitials"
                                       Text="M"
                                       FontSize="40"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <Frame x:Name="companyPhotoFrame"
                                   WidthRequest="108"
                                   HeightRequest="108"
                                   CornerRadius="30"
                                   Padding="0"
                                   HasShadow="False"
                                   IsClippedToBounds="True"
                                   IsVisible="False"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                <Image x:Name="imgCompanyPhoto" Aspect="AspectFill" />
                            </Frame>

                            <Ellipse WidthRequest="20"
                                     HeightRequest="20"
                                     Fill="#5ED0A0"
                                     Stroke="White"
                                     StrokeThickness="3"
                                     HorizontalOptions="End"
                                     VerticalOptions="End"
                                     Margin="0,0,6,14" />
                        </Grid>

                        <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                            <Label x:Name="lblCompanyName"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="Center" />
                            <Label x:Name="lblSector"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#7C4DFF"
                                   HorizontalTextAlignment="Center" />
                            <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="&#xE0C8;"
                                       FontFamily="MaterialIcons"
                                       FontSize="16"
                                       TextColor="#8B86A3" />
                                <Label x:Name="lblLocation"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#8B86A3" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <FlexLayout Direction="Row"
                                    Wrap="Wrap"
                                    JustifyContent="Center"
                                    AlignItems="Center">
                            <Frame BackgroundColor="#F0EAFE" CornerRadius="14" Padding="14,5" HasShadow="False" Margin="4">
                                <Label Text="Recruteur" FontSize="14" FontAttributes="Bold" TextColor="#5F4ACB" />
                            </Frame>
                            <Frame BackgroundColor="#DCFCE7" CornerRadius="14" Padding="14,5" HasShadow="False" Margin="4">
                                <Label Text="• Profil actif" FontSize="14" FontAttributes="Bold" TextColor="#166534" />
                            </Frame>
                            <Frame BackgroundColor="#FEF3C7" CornerRadius="14" Padding="14,5" HasShadow="False" Margin="4">
                                <Label Text="✓ Vérifié" FontSize="14" FontAttributes="Bold" TextColor="#B45309" />
                            </Frame>
                        </FlexLayout>

                        <Frame HeightRequest="54"
                               CornerRadius="27"
                               Padding="0"
                               HasShadow="False"
                               HorizontalOptions="Fill">
                            <Frame.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C4DFF" Offset="0.0" />
                                    <GradientStop Color="#D34C88" Offset="1.0" />
                                </LinearGradientBrush>
                            </Frame.Background>

                            <Grid>
                                <HorizontalStackLayout Spacing="10"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center">
                                    <Label Text="&#xE3C9;"
                                           FontFamily="MaterialIcons"
                                           FontSize="21"
                                           TextColor="White"
                                           VerticalTextAlignment="Center" />

                                    <Label Text="Modifier le profil"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>

                                <Button BackgroundColor="Transparent"
                                        Text=""
                                        Clicked="EditProfile_Clicked" />
                            </Grid>
                        </Frame>

                    </VerticalStackLayout>
                </Frame>

                <!-- COMPLETION -->
                <Frame CornerRadius="22" Padding="20" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Complétion du profil" FontSize="18" FontAttributes="Bold" TextColor="#111827" />
                            <Label x:Name="lblProfileCompletionPercent" Grid.Column="1" Text="0%" FontSize="20" FontAttributes="Bold" TextColor="#7C4DFF" />
                        </Grid>
                        <Label Text="Complétez votre profil pour attirer plus de candidats"
                               FontSize="14"
                               TextColor="#8B86A3" />
                        <ProgressBar x:Name="profileCompletionProgress"
                             Progress="0"
                             ProgressColor="#D34C88"
                             BackgroundColor="#EEEAF8"
                             HeightRequest="7" />
                        <FlexLayout Direction="Row" Wrap="Wrap">
                            <Frame BackgroundColor="#DCFCE7" CornerRadius="13" Padding="10,4" HasShadow="False" Margin="3">
                                <Label x:Name="lblPhotoChip" Text="✓ Photo" FontSize="12" TextColor="#166534" />
                            </Frame>
                            <Frame BackgroundColor="#DCFCE7" CornerRadius="13" Padding="10,4" HasShadow="False" Margin="3">
                                <Label x:Name="lblSectorChip" Text="✓ Secteur" FontSize="12" TextColor="#166534" />
                            </Frame>
                            <Frame BackgroundColor="#DCFCE7" CornerRadius="13" Padding="10,4" HasShadow="False" Margin="3">
                                <Label x:Name="lblLocationChip" Text="✓ Localisation" FontSize="12" TextColor="#166534" />
                            </Frame>
                            <Frame BackgroundColor="#F0EAFE" CornerRadius="13" Padding="10,4" HasShadow="False" Margin="3">
                                <Label x:Name="lblDescriptionChip" Text="+ Description" FontSize="12" TextColor="#7C4DFF" />
                            </Frame>
                            <Frame BackgroundColor="#F0EAFE" CornerRadius="13" Padding="10,4" HasShadow="False" Margin="3">
                                <Label x:Name="lblOffersChip" Text="+ Offres" FontSize="12" TextColor="#7C4DFF" />
                            </Frame>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- STATS -->
                <Label Text="Statistiques" FontSize="20" FontAttributes="Bold" TextColor="#111827" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                    <Frame CornerRadius="18" Padding="18" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Frame WidthRequest="44" HeightRequest="44" CornerRadius="12" Padding="0" BackgroundColor="#F0EAFE" HasShadow="False">
                                <Label Text="&#xE8F4;" FontFamily="MaterialIcons" FontSize="24" TextColor="#7C4DFF" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            </Frame>
                            <Label x:Name="lblProfileViewsCount" Text="0" FontSize="26" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Vues du profil" FontSize="13" TextColor="#8B86A3" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1" CornerRadius="18" Padding="18" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Frame WidthRequest="44" HeightRequest="44" CornerRadius="12" Padding="0" BackgroundColor="#FCE7F3" HasShadow="False">
                                <Label Text="&#xE87D;" FontFamily="MaterialIcons" FontSize="24" TextColor="#D34C88" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            </Frame>
                            <Label x:Name="lblMatchesCount" Text="0" FontSize="26" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Matchs" FontSize="13" TextColor="#8B86A3" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" CornerRadius="18" Padding="18" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Frame WidthRequest="44" HeightRequest="44" CornerRadius="12" Padding="0" BackgroundColor="#DCFCE7" HasShadow="False">
                                <Label Text="&#xE0BF;" FontFamily="MaterialIcons" FontSize="24" TextColor="#16A34A" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            </Frame>
                            <Label x:Name="lblConversationsCount" Text="0" FontSize="26" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Conversations" FontSize="13" TextColor="#8B86A3" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" Grid.Column="1" CornerRadius="18" Padding="18" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Frame WidthRequest="44" HeightRequest="44" CornerRadius="12" Padding="0" BackgroundColor="#FEF3C7" HasShadow="False">
                                <Label Text="&#xE873;" FontFamily="MaterialIcons" FontSize="24" TextColor="#D97706" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            </Frame>
                            <Label x:Name="lblOffersCount" Text="0" FontSize="26" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Offres publiées" FontSize="13" TextColor="#8B86A3" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- QUICK ACTIONS -->
                <Label Text="Actions rapides" FontSize="20" FontAttributes="Bold" TextColor="#111827" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                    <Frame CornerRadius="18" Padding="18" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="EditProfile_Tapped" />
                        </Frame.GestureRecognizers>
                        <HorizontalStackLayout Spacing="14">
                            <Label Text="&#xE3C9;" FontFamily="MaterialIcons" FontSize="28" TextColor="#7C4DFF" />
                            <Label Text="Modifier&#10;le profil" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                        </HorizontalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1" CornerRadius="18" Padding="18" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="AddOffer_Nav_Tapped" />
                        </Frame.GestureRecognizers>
                        <HorizontalStackLayout Spacing="14">
                            <Label Text="&#xE145;" FontFamily="MaterialIcons" FontSize="28" TextColor="#D34C88" />
                            <Label Text="Ajouter&#10;une offre" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                        </HorizontalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" CornerRadius="18" Padding="18" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Discover_Nav_Tapped" />
                        </Frame.GestureRecognizers>
                        <HorizontalStackLayout Spacing="14">
                            <Label Text="&#xE7EF;" FontFamily="MaterialIcons" FontSize="28" TextColor="#16A34A" />
                            <Label Text="Voir&#10;candidats" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                        </HorizontalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" Grid.Column="1" CornerRadius="18" Padding="18" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ShareProfile_Tapped" />
                        </Frame.GestureRecognizers>
                        <HorizontalStackLayout Spacing="14">
                            <Label Text="&#xE80D;" FontFamily="MaterialIcons" FontSize="28" TextColor="#D97706" />
                            <Label Text="Partager" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                        </HorizontalStackLayout>
                    </Frame>
                </Grid>

                <!-- STATUS -->
                <Frame CornerRadius="22" Padding="20" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Statut du compte" FontSize="18" FontAttributes="Bold" TextColor="#111827" />
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Ellipse WidthRequest="10" HeightRequest="10" Fill="#5ED0A0" />
                            <Label Grid.Column="1" Text="Visible par les candidats" FontSize="15" TextColor="#5F5A75" />
                            <Label Grid.Column="2" Text="Actif" FontSize="14" FontAttributes="Bold" TextColor="#16A34A" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#EEEAF8" />
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Ellipse WidthRequest="10" HeightRequest="10" Fill="#7C4DFF" />
                            <Label Grid.Column="1" Text="Profil actif" FontSize="15" TextColor="#5F5A75" />
                            <Label Grid.Column="2" Text="Activé" FontSize="14" FontAttributes="Bold" TextColor="#7C4DFF" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#EEEAF8" />
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Ellipse WidthRequest="10" HeightRequest="10" Fill="#D97706" />
                            <Label Grid.Column="1" Text="Email vérifié" FontSize="15" TextColor="#5F5A75" />
                            <Label Grid.Column="2" Text="✓ Vérifié" FontSize="14" FontAttributes="Bold" TextColor="#D97706" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- CONSEIL -->
                <Frame CornerRadius="22" Padding="20" BackgroundColor="#F7EFFF" BorderColor="#D8B4FE" HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Frame WidthRequest="44" HeightRequest="44" CornerRadius="14" Padding="0" BackgroundColor="White" HasShadow="False">
                            <Label Text="💡" FontSize="22" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Conseil" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Ajoutez une description détaillée pour augmenter vos chances d'obtenir des matchs. Les profils complets reçoivent 3× plus de candidatures."
                           FontSize="16"
                           LineBreakMode="WordWrap"
                           TextColor="#5F4ACB" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- DESCRIPTION -->
                <Frame CornerRadius="22" Padding="20" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Description" FontSize="18" FontAttributes="Bold" TextColor="#111827" />
                        <Label x:Name="lblDescription" FontSize="15" TextColor="#5F5A75" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Frame>

                <!-- INFORMATIONS -->
                <Frame CornerRadius="22" Padding="20" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Informations" FontSize="18" FontAttributes="Bold" TextColor="#111827" />
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Text="Email" FontSize="15" TextColor="#7C4DFF" />
                            <Label x:Name="lblContactEmail" Grid.Column="1" FontSize="15" FontAttributes="Bold" TextColor="#111827" HorizontalTextAlignment="End" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#EEEAF8" />
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Text="Statut" FontSize="15" TextColor="#7C4DFF" />
                            <Label Grid.Column="1" Text="Visible par les candidats" FontSize="15" FontAttributes="Bold" TextColor="#111827" HorizontalTextAlignment="End" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Text="Mes offres"
                            HeightRequest="52"
                            BackgroundColor="White"
                            BorderColor="#DED8F5"
                            BorderWidth="1"
                            TextColor="#5F5A75"
                            FontAttributes="Bold"
                            CornerRadius="16"
                            Clicked="Offers_Clicked" />
                    <Button Grid.Column="1"
                            Text="Paramètres"
                            HeightRequest="52"
                            BackgroundColor="#F0EAFE"
                            TextColor="#5F4ACB"
                            FontAttributes="Bold"
                            CornerRadius="16"
                            Clicked="Settings_Clicked" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>


        <!-- BOTTOM NAV -->
        <Grid Grid.Row="1"
              HeightRequest="78"
              BackgroundColor="White"
              Padding="4,8,4,10"
              ColumnDefinitions="*,*,*,*,*">

            <BoxView Grid.ColumnSpan="5"
                     HeightRequest="0.5"
                     Color="#E5E0F5"
                     VerticalOptions="Start" />

            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2" VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Home_Nav_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="&#xE88A;" FontFamily="MaterialIcons" FontSize="24" TextColor="#b0a8cc" HorizontalTextAlignment="Center" />
                <Label Text="Accueil" FontSize="9" TextColor="#b0a8cc" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2" VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Discover_Nav_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="&#xE8B6;" FontFamily="MaterialIcons" FontSize="24" TextColor="#b0a8cc" HorizontalTextAlignment="Center" />
                <Label Text="Découvrir" FontSize="9" TextColor="#b0a8cc" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Border Grid.Column="2"
                    WidthRequest="46"
                    HeightRequest="46"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="23" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="AddOffer_Nav_Tapped" />
                </Border.GestureRecognizers>
                <Label Text="+"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>

            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="2" VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Messages_Nav_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="&#xE0BF;" FontFamily="MaterialIcons" FontSize="24" TextColor="#b0a8cc" HorizontalTextAlignment="Center" />
                <Label Text="Messages" FontSize="9" TextColor="#b0a8cc" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="2" VerticalOptions="Center">
                <Label Text="&#xE7FD;" FontFamily="MaterialIcons" FontSize="24" TextColor="#7C4DFF" HorizontalTextAlignment="Center" />
                <Label Text="Profil" FontSize="9" TextColor="#7C4DFF" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                <BoxView HeightRequest="4" WidthRequest="4" Color="#7C4DFF" CornerRadius="2" HorizontalOptions="Center" />
            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>
