<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.RecruiterProfilePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F9FFFD" Offset="0.0" />
            <GradientStop Color="#EAF8F5" Offset="0.40" />
            <GradientStop Color="#1ABC9C" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <Grid Padding="20,26,20,24"
              RowDefinitions="Auto,*">

            <!-- HEADER -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="Auto,*,Auto"
                  VerticalOptions="Center"
                  Margin="0,0,0,16">

                <!-- Menu -->
                <Label Grid.Column="0"
                       Text="☰"
                       FontSize="26"
                       TextColor="#0B1F1D"
                       VerticalOptions="Center"
                       HorizontalOptions="Start">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Menu_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <!-- Centre -->
                <VerticalStackLayout Grid.Column="1"
                                     Spacing="4"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">

                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Spacing="6">
                        <Label Text="✦"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#1ABC9C" />

                        <Label Text="SparkWork"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#1ABC9C" />
                    </HorizontalStackLayout>

                    <Label Text="Recruiter Profile"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="#0B1F1D"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Spacer for true centering -->
                <Label Grid.Column="2"
                       WidthRequest="30" />
            </Grid>

            <!-- CONTENT -->
            <VerticalStackLayout Grid.Row="1"
                                 Spacing="16">

                <!-- Main card -->
                <Frame BackgroundColor="#FFFFFF"
                       BorderColor="#DCEDE7"
                       CornerRadius="22"
                       Padding="22"
                       HasShadow="True">

                    <VerticalStackLayout Spacing="18">

                        <VerticalStackLayout Spacing="4"
                                             HorizontalOptions="Center">
                            <Frame BackgroundColor="#E8FFFA"
                                   BorderColor="#BFECE2"
                                   CornerRadius="26"
                                   Padding="14,8"
                                   HasShadow="False"
                                   HorizontalOptions="Center">
                                <Label Text="Recruiter"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#15967D" />
                            </Frame>

                            <Label x:Name="lblCompanyName"
                                   Text="Company Name"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="#0B1F1D"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 Color="#E7F1EE" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="14"
                              RowDefinitions="Auto,Auto">
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 Spacing="10">

                                <Frame WidthRequest="120"
                                       HeightRequest="120"
                                       CornerRadius="20"
                                       Padding="0"
                                       BackgroundColor="White"
                                       BorderColor="#DCEDE7"
                                       HasShadow="True"
                                       HorizontalOptions="Center">

                                    <Image x:Name="imgCompanyPhoto"
                                           Source="dotnet_bot.png"
                                           Aspect="AspectFill" />
                                </Frame>
                            </VerticalStackLayout>

                            <!-- Sector -->
                            <Frame Grid.Row="0"
                                   Grid.Column="0"
                                   BackgroundColor="#F9FFFD"
                                   BorderColor="#DCEDE7"
                                   CornerRadius="16"
                                   Padding="14"
                                   HasShadow="False">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Sector"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#1ABC9C" />
                                    <Label x:Name="lblSector"
                                           FontSize="16"
                                           TextColor="#0B1F1D" />
                                </VerticalStackLayout>
                            </Frame>

                            <!-- Location -->
                            <Frame Grid.Row="0"
                                   Grid.Column="1"
                                   BackgroundColor="#F9FFFD"
                                   BorderColor="#DCEDE7"
                                   CornerRadius="16"
                                   Padding="14"
                                   HasShadow="False">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Location"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#1ABC9C" />
                                    <Label x:Name="lblLocation"
                                           FontSize="16"
                                           TextColor="#0B1F1D" />
                                </VerticalStackLayout>
                            </Frame>

                            <!-- Contact Email -->
                            <Frame Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   BackgroundColor="#F9FFFD"
                                   BorderColor="#DCEDE7"
                                   CornerRadius="16"
                                   Padding="14"
                                   HasShadow="False"
                                   Margin="0,14,0,0">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Contact Email"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#1ABC9C" />
                                    <Label x:Name="lblContactEmail"
                                           FontSize="16"
                                           TextColor="#0B1F1D" />
                                </VerticalStackLayout>
                            </Frame>
                        </Grid>

                        <Frame BackgroundColor="#F9FFFD"
                               BorderColor="#DCEDE7"
                               CornerRadius="16"
                               Padding="16"
                               HasShadow="False">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Description"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#1ABC9C" />
                                <Label x:Name="lblDescription"
                                       FontSize="15"
                                       TextColor="#334A48"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- Action button -->
                <Button Text="Edit Profile"
                        HeightRequest="54"
                        BackgroundColor="#1ABC9C"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        Clicked="EditProfile_Clicked" />
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>