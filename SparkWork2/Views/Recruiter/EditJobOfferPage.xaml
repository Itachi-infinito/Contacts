<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.EditJobOfferPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="18,24,24,0"
              RowDefinitions="Auto,Auto"
              ColumnDefinitions="Auto,*,Auto">

            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="34"
                    Padding="0"
                    HeightRequest="44"
                    WidthRequest="44"
                    BackgroundColor="Transparent"
                    TextColor="#111827"
                    Clicked="Cancel_Clicked" />

            <Label Grid.Column="1"
                   Text="Modifier l'offre"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />

            <Frame Grid.Column="2"
                   HeightRequest="46"
                   WidthRequest="46"
                   CornerRadius="23"
                   Padding="0"
                   HasShadow="False"
                   VerticalOptions="Center">
                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label Text="AL"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="15"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>

            <Grid Grid.Row="1"
                  Grid.ColumnSpan="3"
                  ColumnDefinitions="*,*,*"
                  Margin="0,22,0,0"
                  HeightRequest="42">

                <Label Text="DÉCOUVRIR"
                       Grid.Column="0"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />

                <Label Text="MESSAGES"
                       Grid.Column="1"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />

                <Label Text="STATS"
                       Grid.Column="2"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Grid>
        </Grid>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,24,20,28"
                                 Spacing="16">

                <VerticalStackLayout Spacing="4">
                    <Label Text="MODIFIER L'OPPORTUNITÉ"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#8581A6" />

                    <Label Text="Les modifications seront visibles par les candidats."
                           FontSize="13"
                           TextColor="#8B86A3" />
                </VerticalStackLayout>

                <Frame CornerRadius="24"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16">

                        <Label Text="Informations principales"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Titre du poste"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryTitle"
                                       Placeholder="Ex: Développeur junior"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Entreprise"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryCompany"
                                       Placeholder="Ex: Thales"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Localisation"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryLocation"
                                       Placeholder="Ex: Bruxelles"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <Button x:Name="btnUseOfferLocation"
                                Text="Utiliser ma position pour cette offre"
                                HeightRequest="46"
                                BackgroundColor="#F0EAFE"
                                TextColor="#7C4DFF"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                Clicked="UseOfferLocation_Clicked" />

                        <Label x:Name="lblOfferCoordinates"
                               Text="Position de l'offre non définie"
                               FontSize="12"
                               TextColor="#8B86A3"
                               HorizontalTextAlignment="Center" />

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Type de contrat"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />


                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryContractType"
                                       Placeholder="Ex: Full-time, CDI, Stage"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Address -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Adresse"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryAddress"
                                       Placeholder="Ex: Avenue Louise 100"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Salary -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Salaire min"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#8581A6" />

                                <Frame BackgroundColor="#FAF9FF"
                                       BorderColor="#EEEAF8"
                                       CornerRadius="14"
                                       Padding="14,4"
                                       HasShadow="False">
                                    <Entry x:Name="entrySalaryMin"
                                           Placeholder="Ex: 2800"
                                           Keyboard="Numeric"
                                           PlaceholderColor="#A6A0C0"
                                           TextColor="#111827"
                                           BackgroundColor="Transparent" />
                                </Frame>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label Text="Salaire max"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#8581A6" />

                                <Frame BackgroundColor="#FAF9FF"
                                       BorderColor="#EEEAF8"
                                       CornerRadius="14"
                                       Padding="14,4"
                                       HasShadow="False">
                                    <Entry x:Name="entrySalaryMax"
                                           Placeholder="Ex: 3800"
                                           Keyboard="Numeric"
                                           PlaceholderColor="#A6A0C0"
                                           TextColor="#111827"
                                           BackgroundColor="Transparent" />
                                </Frame>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Level -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Niveau recherché"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryLevel"
                                       Placeholder="Ex: Junior, Medior, Senior"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Remote mode -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Mode de travail"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryRemoteMode"
                                       Placeholder="Ex: Sur site, Hybride, Remote"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Frame>
                <Frame CornerRadius="24"
                        Padding="18"
                        BackgroundColor="White"
                        BorderColor="#EEEAF8"
                        HasShadow="False">

                    <VerticalStackLayout Spacing="16">
                        <Label Text="Compétences"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Compétences obligatoires"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryRequiredSkills"
                                       Placeholder="Ex: C#, SQL, MAUI"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Compétences bonus"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryNiceToHaveSkills"
                                       Placeholder="Ex: Azure, API, Git"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <Label Text="Sépare les compétences par des virgules."
                               FontSize="12"
                               TextColor="#8B86A3" />
                    </VerticalStackLayout>
                </Frame>


                <Frame CornerRadius="24"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="Description"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Frame BackgroundColor="#FAF9FF"
                               BorderColor="#EEEAF8"
                               CornerRadius="14"
                               Padding="14,10"
                               HasShadow="False">
                            <Editor x:Name="editorDescription"
                                    Placeholder="Décris le rôle, les missions, les attentes et le profil recherché."
                                    PlaceholderColor="#A6A0C0"
                                    TextColor="#111827"
                                    BackgroundColor="Transparent"
                                    AutoSize="TextChanges"
                                    HeightRequest="150" />
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,4,0,0">

                    <Button Grid.Column="0"
                            Text="Annuler"
                            HeightRequest="52"
                            BackgroundColor="White"
                            BorderColor="#DED8F5"
                            BorderWidth="1"
                            TextColor="#111827"
                            FontAttributes="Bold"
                            CornerRadius="14"
                            Clicked="Cancel_Clicked" />

                    <Button Grid.Column="1"
                            Text="Enregistrer"
                            HeightRequest="52"
                            BackgroundColor="#7C4DFF"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="14"
                            Clicked="Update_Clicked" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
