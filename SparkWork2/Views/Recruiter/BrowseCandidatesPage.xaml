<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.BrowseCandidatesPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#1ABC9C">

    <Grid Padding="20" RowDefinitions="Auto,Auto,*">

        <Label Grid.Row="0"
               Text="Browse Candidates"
               FontSize="30"
               FontAttributes="Bold"
               TextColor="White"
               HorizontalTextAlignment="Center"
               Margin="0,20,0,20" />

        <Label Grid.Row="1"
               x:Name="noCandidatesLabel"
               Text="No candidates available"
               TextColor="White"
               HorizontalTextAlignment="Center"
               Margin="0,10,0,10"
               IsVisible="False" />

        <CollectionView Grid.Row="2"
                        x:Name="candidatesCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="White"
                           CornerRadius="16"
                           Padding="15"
                           Margin="0,0,0,15"
                           HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Candidate_Tapped"
                          CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding FullName}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#1ABC9C" />

                            <Label Text="{Binding Title}"
                                   FontSize="14"
                                   TextColor="Black" />

                            <Label Text="{Binding Location}"
                                   FontSize="14"
                                   TextColor="Gray" />

                            <Label Text="{Binding About}"
                                   FontSize="13"
                                   TextColor="Black"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="3" />

                            <Button Text="{Binding LikeButtonText}"
                                    BackgroundColor="#1ABC9C"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    CornerRadius="12"
                                    Clicked="LikeCandidate_Clicked"
                                    CommandParameter="{Binding .}"
                                    IsEnabled="{Binding IsAlreadyLiked, Converter={StaticResource InverseBoolConverter}}" />
                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>