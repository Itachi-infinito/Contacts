<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.CandidateDetailPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F9FFFD" Offset="0.0" />
            <GradientStop Color="#EAF8F5" Offset="0.40" />
            <GradientStop Color="#1ABC9C" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*"
          Padding="20,26,20,18">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto"
              RowSpacing="12"
              Margin="0,0,0,14">

            <Grid Grid.Row="0"
                  ColumnDefinitions="Auto,*,Auto"
                  VerticalOptions="Center">

                <!-- Back -->
                <Label Grid.Column="0"
                       Text="←"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="#0B1F1D"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Back_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Grid.Column="1" />

              
                
            </Grid>

            <VerticalStackLayout Grid.Row="1"
                                 Spacing="4"
                                 HorizontalOptions="Center">

                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="6">
                    <Label Text="✦"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#1ABC9C" />

                    <Label Text="SparkWork"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#1ABC9C" />
                </HorizontalStackLayout>

                <Label x:Name="lblFullName"
                       Text="Candidate"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="#0B1F1D"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16">

                <Frame BackgroundColor="#FFFFFF"
                       BorderColor="#DCEDE7"
                       CornerRadius="22"
                       Padding="22"
                       HasShadow="True">

                    <VerticalStackLayout Spacing="16">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Title"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#1ABC9C" />
                            <Label x:Name="lblTitle"
                                   FontSize="17"
                                   TextColor="#0B1F1D" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 Color="#E7F1EE" />

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Location"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#1ABC9C" />
                            <Label x:Name="lblLocation"
                                   FontSize="17"
                                   TextColor="#0B1F1D" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 Color="#E7F1EE" />

                        <VerticalStackLayout Spacing="6">
                            <Label Text="About"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#1ABC9C" />
                            <Label x:Name="lblAbout"
                                   FontSize="15"
                                   TextColor="#334A48"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 Color="#E7F1EE" />

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Email"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#1ABC9C" />
                            <Label x:Name="lblEmail"
                                   FontSize="16"
                                   TextColor="#0B1F1D" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>


            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>