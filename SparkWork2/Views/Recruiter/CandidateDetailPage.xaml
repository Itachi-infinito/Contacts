<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.CandidateDetailPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="18,24,24,0"
              RowDefinitions="Auto,Auto"
              ColumnDefinitions="Auto,*,Auto">

            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="34"
                    Padding="0"
                    HeightRequest="44"
                    WidthRequest="44"
                    BackgroundColor="Transparent"
                    TextColor="#111827"
                    Clicked="Back_Clicked" />

            <Label Grid.Column="1"
                   Text="Détail candidat"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />

            <Frame Grid.Column="2"
                   HeightRequest="46"
                   WidthRequest="46"
                   CornerRadius="23"
                   Padding="0"
                   HasShadow="False"
                   VerticalOptions="Center">
                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label Text="AL"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="15"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>

            <Grid Grid.Row="1"
                  Grid.ColumnSpan="3"
                  ColumnDefinitions="*,*,*"
                  Margin="0,22,0,0"
                  HeightRequest="42">

                <Label Text="DÉCOUVRIR"
                       Grid.Column="0"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Discover_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="MESSAGES"
                       Grid.Column="1"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Messages_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="STATS"
                       Grid.Column="2"
                       FontSize="14"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Stats_Tapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </Grid>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,24,20,28"
                                 Spacing="16">

                <!-- HERO -->
                <Frame CornerRadius="26"
                       Padding="20"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16"
                                         HorizontalOptions="Center">

                        <Grid WidthRequest="112"
                              HeightRequest="112">

                            <Frame x:Name="candidatePlaceholderFrame"
                                   WidthRequest="112"
                                   HeightRequest="112"
                                   CornerRadius="56"
                                   Padding="0"
                                   HasShadow="False"
                                   IsVisible="True">
                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                                        <GradientStop Color="#D34C88" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>

                                <Label x:Name="lblCandidateInitials"
                                       Text="?"
                                       FontSize="30"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <Frame x:Name="candidatePhotoFrame"
                                   WidthRequest="112"
                                   HeightRequest="112"
                                   CornerRadius="56"
                                   Padding="0"
                                   HasShadow="False"
                                   IsClippedToBounds="True"
                                   IsVisible="False">
                                <Image x:Name="imgCandidatePhoto"
                                       Aspect="AspectFill" />
                            </Frame>
                        </Grid>

                        <VerticalStackLayout Spacing="5"
                                             HorizontalOptions="Center">

                            <Label x:Name="lblFullName"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="Center" />

                            <Label x:Name="lblTitle"
                                   FontSize="15"
                                   TextColor="#7C4DFF"
                                   HorizontalTextAlignment="Center" />

                            <Label x:Name="lblLocation"
                                   FontSize="14"
                                   TextColor="#8581A6"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="Center">

                            <Frame BackgroundColor="#F0EAFE"
                                   CornerRadius="12"
                                   Padding="10,4"
                                   HasShadow="False">
                                <Label Text="Candidat"
                                       FontSize="12"
                                       TextColor="#7C4DFF" />
                            </Frame>

                            <Frame BackgroundColor="#F0EAFE"
                                   CornerRadius="12"
                                   Padding="10,4"
                                   HasShadow="False">
                                <Label Text="Profil actif"
                                       FontSize="12"
                                       TextColor="#7C4DFF" />
                            </Frame>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- ABOUT -->
                <Frame CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="10">
                        <Label Text="À propos"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label x:Name="lblAbout"
                               FontSize="14"
                               TextColor="#5F5A75"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Frame>

                <!-- CONTACT -->
                <Frame CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="14">
                        <Label Text="Informations"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <Label Text="Email"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Label Grid.Column="1"
                                   x:Name="lblEmail"
                                   FontSize="14"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="End"
                                   LineBreakMode="TailTruncation" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- ACTION -->
                <Frame CornerRadius="22"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="14">
                        <Label Text="Entrer en contact"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label Text="Ouvre une conversation avec ce candidat si un match existe déjà."
                               FontSize="13"
                               TextColor="#8581A6"
                               LineBreakMode="WordWrap" />

                        <Button Text="Contacter"
                                HeightRequest="52"
                                BackgroundColor="#7C4DFF"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                Clicked="Contact_Clicked" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
