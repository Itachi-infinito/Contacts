<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.RecruiterMatchesPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F8F6FF">

    <ScrollView>
        <VerticalStackLayout Padding="28,34,28,28" Spacing="16">

            <!-- HEADER -->
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                <Button Text="‹"
                        WidthRequest="42"
                        HeightRequest="42"
                        FontSize="28"
                        Padding="0"
                        BackgroundColor="White"
                        BorderColor="#DED8F5"
                        BorderWidth="1"
                        TextColor="#7C3AED"
                        CornerRadius="21"
                        Clicked="Back_Clicked" />

                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                    <Label Text="Mes matchs"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Candidats qui vous ont retenu"
                           FontSize="13"
                           TextColor="#8B86A3"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Frame Grid.Column="2"
                       WidthRequest="54"
                       HeightRequest="54"
                       CornerRadius="27"
                       Padding="0"
                       HasShadow="False"
                       VerticalOptions="Center">
                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C4DFF" Offset="0.0" />
                            <GradientStop Color="#D34C88" Offset="1.0" />
                        </LinearGradientBrush>
                    </Frame.Background>
                    <Label x:Name="lblHeaderInitials"
                           Text="M"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="18"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Frame>
            </Grid>

            <!-- TABS -->
            <Frame CornerRadius="14"
                   Padding="4"
                   BackgroundColor="White"
                   BorderColor="#DED8F5"
                   HasShadow="False">

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">

                    <Frame Grid.Column="0"
                           CornerRadius="11"
                           Padding="0"
                           HeightRequest="44"
                           HasShadow="False">
                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>

                        <HorizontalStackLayout HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               Spacing="8">
                            <Label Text="Tous"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="White" />
                            <Frame CornerRadius="10"
                                   Padding="6,2"
                                   BackgroundColor="White"
                                   HasShadow="False">
                                <Label x:Name="lblTabAllCount"
                                       Text="0"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#7C4DFF" />
                            </Frame>
                        </HorizontalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1"
                           CornerRadius="11"
                           Padding="0"
                           HeightRequest="44"
                           BackgroundColor="Transparent"
                           HasShadow="False">
                        <HorizontalStackLayout HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               Spacing="8">
                            <Label Text="Nouveaux"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#8B86A3" />
                            <Frame CornerRadius="10"
                                   Padding="6,2"
                                   BackgroundColor="#F0EAFE"
                                   HasShadow="False">
                                <Label x:Name="lblTabNewCount"
                                       Text="0"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#7C4DFF" />
                            </Frame>
                        </HorizontalStackLayout>
                    </Frame>

                    <Frame Grid.Column="2"
                           CornerRadius="11"
                           Padding="0"
                           HeightRequest="44"
                           BackgroundColor="Transparent"
                           HasShadow="False">
                        <Label Text="En cours"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#8B86A3"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>
                </Grid>
            </Frame>

            <!-- STATS -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <Frame CornerRadius="16" Padding="14" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label x:Name="lblTotalMatchesValue" Text="0" FontSize="24" FontAttributes="Bold" TextColor="#D4B8F8" HorizontalTextAlignment="Center" />
                        <Label Text="Total&#10;matchs" FontSize="12" TextColor="#8B86A3" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1" CornerRadius="16" Padding="14" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label x:Name="lblNewMatchesValue" Text="0" FontSize="24" FontAttributes="Bold" TextColor="#D4B8F8" HorizontalTextAlignment="Center" />
                        <Label Text="Nouveau" FontSize="12" TextColor="#8B86A3" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="2" CornerRadius="16" Padding="14" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label x:Name="lblInDiscussionValue" Text="0" FontSize="24" FontAttributes="Bold" TextColor="#D4B8F8" HorizontalTextAlignment="Center" />
                        <Label Text="En&#10;discussion" FontSize="12" TextColor="#8B86A3" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- MATCHES -->
            <VerticalStackLayout x:Name="matchesSection" Spacing="14" IsVisible="False">
                <Label Text="Candidats matchés"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#111827" />

                <VerticalStackLayout x:Name="matchesCardsLayout"
                                     Spacing="14"
                                     BindableLayout.ItemsSource="{Binding .}">

                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame CornerRadius="22"
                                   Padding="16"
                                   BackgroundColor="White"
                                   BorderColor="{Binding CardBorderColor}"
                                   HasShadow="False">

                                <VerticalStackLayout Spacing="12">

                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Grid WidthRequest="54" HeightRequest="54">
                                            <Frame WidthRequest="54"
                                                   HeightRequest="54"
                                                   CornerRadius="27"
                                                   Padding="0"
                                                   BackgroundColor="{Binding AvatarColor}"
                                                   HasShadow="False">
                                                <Label Text="{Binding Initials}"
                                                       FontSize="20"
                                                       FontAttributes="Bold"
                                                       TextColor="White"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Frame>

                                            <Ellipse WidthRequest="14"
                                                     HeightRequest="14"
                                                     Fill="#5ED0A0"
                                                     Stroke="White"
                                                     StrokeThickness="2"
                                                     HorizontalOptions="End"
                                                     VerticalOptions="End" />
                                        </Grid>

                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding CandidateName}"
                                                       FontSize="17"
                                                       FontAttributes="Bold"
                                                       TextColor="#111827"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1" />

                                                <Frame IsVisible="{Binding IsNew}"
                                                       CornerRadius="10"
                                                       Padding="8,2"
                                                       HasShadow="False">
                                                    <Frame.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#7C4DFF" Offset="0.0" />
                                                            <GradientStop Color="#D34C88" Offset="1.0" />
                                                        </LinearGradientBrush>
                                                    </Frame.Background>
                                                    <Label Text="Nouveau"
                                                           FontSize="10"
                                                           FontAttributes="Bold"
                                                           TextColor="White" />
                                                </Frame>
                                            </HorizontalStackLayout>

                                            <Label Text="{Binding RoleLine}"
                                                   FontSize="12"
                                                   TextColor="#8B86A3"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding CompatibilityScoreText}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="#7C4DFF"
                                                   HorizontalTextAlignment="End" />
                                            <Label Text="{Binding TimeText}"
                                                   FontSize="12"
                                                   TextColor="#8B86A3"
                                                   HorizontalTextAlignment="End" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <!-- COMPATIBILITY -->
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Label Text="Compatibilité"
                                               FontSize="12"
                                               TextColor="#8B86A3"
                                               VerticalTextAlignment="Center" />

                                        <Grid Grid.Column="1"
                                              WidthRequest="170"
                                              HeightRequest="6"
                                              VerticalOptions="Center">
                                            <Frame BackgroundColor="#F0EAFE"
                                                   CornerRadius="3"
                                                   Padding="0"
                                                   HasShadow="False" />

                                            <Frame WidthRequest="{Binding CompatibilityProgressWidth}"
                                                   CornerRadius="3"
                                                   Padding="0"
                                                   HasShadow="False"
                                                   HorizontalOptions="Start">
                                                <Frame.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                                                        <GradientStop Color="#D34C88" Offset="1.0" />
                                                    </LinearGradientBrush>
                                                </Frame.Background>
                                            </Frame>
                                        </Grid>
                                    </Grid>

                                    <!-- TAGS -->
                                    <FlexLayout Direction="Row"
                                                Wrap="Wrap"
                                                BindableLayout.ItemsSource="{Binding Skills}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Frame BackgroundColor="#FAF9FF"
                                                       BorderColor="#CFC4FF"
                                                       CornerRadius="13"
                                                       Padding="12,5"
                                                       HasShadow="False"
                                                       Margin="0,0,8,6">
                                                    <Label Text="{Binding .}"
                                                           FontSize="12"
                                                           TextColor="#5F4ACB" />
                                                </Frame>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </FlexLayout>

                                    <Frame BackgroundColor="#FEF3C7"
                                           BorderColor="#F6D98B"
                                           CornerRadius="13"
                                           Padding="12,5"
                                           HasShadow="False"
                                           HorizontalOptions="Start">
                                        <Label Text="{Binding OfferTag}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="#92400E" />
                                    </Frame>

                                    <!-- ACTIONS -->
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                        <Frame HeightRequest="50"
                                               CornerRadius="25"
                                               Padding="0"
                                               HasShadow="False">
                                            <Frame.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#7C4DFF" Offset="0.0" />
                                                    <GradientStop Color="#D34C88" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Frame.Background>

                                            <Grid>
                                                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                                                    <Label Text="&#xE0BF;" FontFamily="MaterialIcons" FontSize="20" TextColor="White" />
                                                    <Label Text="Message" FontSize="15" FontAttributes="Bold" TextColor="White" />
                                                </HorizontalStackLayout>

                                                <Button BackgroundColor="Transparent"
                                                        Text=""
                                                        Clicked="Contact_Clicked"
                                                        CommandParameter="{Binding .}" />
                                            </Grid>
                                        </Frame>

                                        <Button Grid.Column="1"
                                                Text="♙  Voir profil"
                                                HeightRequest="50"
                                                BackgroundColor="#EEEDFE"
                                                TextColor="#5F4ACB"
                                                FontAttributes="Bold"
                                                FontSize="15"
                                                CornerRadius="25"
                                                Clicked="Candidate_Clicked"
                                                CommandParameter="{Binding .}" />
                                    </Grid>

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- EMPTY STATE -->
            <VerticalStackLayout x:Name="emptyStateLayout"
                                 IsVisible="False"
                                 Spacing="18"
                                 HorizontalOptions="Fill"
                                 VerticalOptions="Center"
                                 Margin="0,34,0,0">

                <Grid WidthRequest="210" HeightRequest="170" HorizontalOptions="Center">
                    <Ellipse WidthRequest="122" HeightRequest="122" Fill="#F0EAFE" Opacity="0.82" HorizontalOptions="Center" VerticalOptions="Center" />
                    <Ellipse WidthRequest="142" HeightRequest="142" Stroke="#CFC4FF" StrokeThickness="1.6" StrokeDashArray="6,5" Fill="Transparent" HorizontalOptions="Center" VerticalOptions="Center" />

                    <Frame WidthRequest="72" HeightRequest="72" CornerRadius="36" Padding="0" BackgroundColor="White" HasShadow="True" HorizontalOptions="Center" VerticalOptions="Center">
                        <Frame.Shadow>
                            <Shadow Brush="#18000000" Offset="0,10" Radius="18" Opacity="1" />
                        </Frame.Shadow>
                        <Label Text="♡" FontSize="42" TextColor="#B13CC7" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                    </Frame>
                </Grid>

                <Label Text="Aucun match pour l'instant"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#111827"
                       HorizontalTextAlignment="Center" />

                <Label Text="Swipez des candidats et attendez qu'ils vous retiennent pour créer un match mutuel."
                       WidthRequest="300"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="#8B86A3"
                       LineBreakMode="WordWrap"
                       HorizontalTextAlignment="Center" />

                <Frame HeightRequest="58"
                       CornerRadius="29"
                       Padding="0"
                       HasShadow="True"
                       Margin="20,8,20,0"
                       HorizontalOptions="Fill">
                    <Frame.Shadow>
                        <Shadow Brush="#307C4DFF" Offset="0,10" Radius="18" Opacity="1" />
                    </Frame.Shadow>
                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C4DFF" Offset="0.0" />
                            <GradientStop Color="#D34C88" Offset="1.0" />
                        </LinearGradientBrush>
                    </Frame.Background>

                    <Grid>
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="&#xE8B6;" FontFamily="MaterialIcons" FontSize="22" TextColor="White" />
                            <Label Text="Découvrir des candidats" FontSize="17" FontAttributes="Bold" TextColor="White" />
                        </HorizontalStackLayout>
                        <Button BackgroundColor="Transparent" Text="" Clicked="DiscoverCandidates_Clicked" />
                    </Grid>
                </Frame>

                <Frame CornerRadius="22"
                       Padding="20"
                       BackgroundColor="#F7EFFF"
                       BorderColor="#D8B4FE"
                       HasShadow="False"
                       Margin="0,28,0,0">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Frame WidthRequest="44" HeightRequest="44" CornerRadius="14" Padding="0" BackgroundColor="White" HasShadow="False">
                            <Label Text="💡" FontSize="22" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Conseil" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Un match se crée quand vous et le candidat vous retenez mutuellement. Swipez plus pour augmenter vos chances !"
                                   FontSize="15"
                                   TextColor="#5F4ACB"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
