<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.RecruiterMatchesPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="28,26,28,0"
              RowDefinitions="Auto,Auto"
              ColumnDefinitions="*,Auto">

            <Label Text="SparkWork"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#7C4DFF"
                   VerticalOptions="Center" />

            <Frame Grid.Column="1"
                   HeightRequest="54"
                   WidthRequest="54"
                   CornerRadius="27"
                   Padding="0"
                   HasShadow="False"
                   HorizontalOptions="End"
                   VerticalOptions="Center">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Profile_Tapped" />
                </Frame.GestureRecognizers>

                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label Text="AL"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="16"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>

            <Grid Grid.Row="1"
                  Grid.ColumnSpan="2"
                  ColumnDefinitions="*,*,*"
                  Margin="0,24,0,0"
                  HeightRequest="42">

                <Label Text="DÉCOUVRIR"
                       Grid.Column="0"
                       FontSize="15"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Discover_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="MESSAGES"
                       Grid.Column="1"
                       FontSize="15"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Messages_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="STATS"
                       Grid.Column="2"
                       FontSize="15"
                       TextColor="#7C4DFF"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />

                <BoxView Grid.Column="2"
                         HeightRequest="3"
                         Color="#7C4DFF"
                         VerticalOptions="End"
                         Margin="14,0,14,0" />
            </Grid>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,24,20,28"
                                 Spacing="0">

                <Label Text="CETTE SEMAINE"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#8581A6"
                       Margin="0,0,0,16" />

                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="14"
                      RowSpacing="14">

                    <Frame Grid.Row="0"
                           Grid.Column="0"
                           CornerRadius="18"
                           Padding="14"
                           BackgroundColor="White"
                           BorderColor="#EEEAF8"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Profils vus"
                                   FontSize="13"
                                   TextColor="#8581A6" />
                            <Label Text="47"
                                   FontSize="30"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Label Text="↑ +12 vs sem. dernière"
                                   FontSize="11"
                                   TextColor="#49C390" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="0"
                           Grid.Column="1"
                           CornerRadius="18"
                           Padding="14"
                           BackgroundColor="White"
                           BorderColor="#EEEAF8"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Matches"
                                   FontSize="13"
                                   TextColor="#8581A6" />
                            <Label x:Name="lblMatchesCount"
                                   Text="0"
                                   FontSize="30"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Label x:Name="lblNewMatchesText"
                                   Text="0 nouveaux"
                                   FontSize="11"
                                   TextColor="#49C390" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1"
                           Grid.Column="0"
                           CornerRadius="18"
                           Padding="14"
                           BackgroundColor="White"
                           BorderColor="#EEEAF8"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Candidats likés"
                                   FontSize="13"
                                   TextColor="#8581A6" />
                            <Label Text="18"
                                   FontSize="30"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Label Text="↑ +5 cette semaine"
                                   FontSize="11"
                                   TextColor="#49C390" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1"
                           Grid.Column="1"
                           CornerRadius="18"
                           Padding="14"
                           BackgroundColor="White"
                           BorderColor="#EEEAF8"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Msgs envoyés"
                                   FontSize="13"
                                   TextColor="#8581A6" />
                            <Label Text="23"
                                   FontSize="30"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Label Text="↓ -2 vs sem."
                                   FontSize="11"
                                   TextColor="#EF4D7A" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Frame CornerRadius="18"
                       Padding="16"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False"
                       Margin="0,22,0,0">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="Performance recruteur"
                               FontSize="15"
                               TextColor="#8581A6" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Profil entreprise"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                            <Label Grid.Column="1"
                                   Text="100%"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                        </Grid>
                        <ProgressBar Progress="1"
                                     ProgressColor="#D34C88"
                                     BackgroundColor="#E7E2F5"
                                     HeightRequest="5" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Offre active"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                            <Label Grid.Column="1"
                                   Text="80%"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                        </Grid>
                        <ProgressBar Progress="0.8"
                                     ProgressColor="#D34C88"
                                     BackgroundColor="#E7E2F5"
                                     HeightRequest="5" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Réactivité"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                            <Label Grid.Column="1"
                                   Text="60%"
                                   FontSize="14"
                                   TextColor="#8581A6" />
                        </Grid>
                        <ProgressBar Progress="0.6"
                                     ProgressColor="#D34C88"
                                     BackgroundColor="#E7E2F5"
                                     HeightRequest="5" />
                    </VerticalStackLayout>
                </Frame>

                <Label Text="MATCHES RÉCENTS"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#8581A6"
                       Margin="0,26,0,12" />

                <CollectionView x:Name="matchesCollection"
                                SelectionMode="None"
                                HeightRequest="200"
                                HorizontalScrollBarVisibility="Never">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal"
                                           ItemSpacing="12" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.EmptyView>
                        <Frame WidthRequest="300"
                               HeightRequest="130"
                               CornerRadius="18"
                               Padding="18"
                               BackgroundColor="White"
                               BorderColor="#EEEAF8"
                               HasShadow="False">
                            <VerticalStackLayout Spacing="6"
                                                 VerticalOptions="Center">
                                <Label Text="Aucun match récent"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />
                                <Label Text="Tes candidats matchés apparaîtront ici."
                                       FontSize="13"
                                       TextColor="#8581A6" />
                            </VerticalStackLayout>
                        </Frame>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame WidthRequest="145"
                                   HeightRequest="178"
                                   CornerRadius="18"
                                   Padding="12"
                                   BackgroundColor="White"
                                   BorderColor="#EEEAF8"
                                   HasShadow="False">

                                <Grid RowDefinitions="Auto,Auto,Auto,*"
                                      RowSpacing="5">

                                    <Frame Grid.Row="0"
                                           WidthRequest="56"
                                           HeightRequest="56"
                                           CornerRadius="28"
                                           Padding="0"
                                           HasShadow="False"
                                           HorizontalOptions="Center">
                                        <Frame.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                                <GradientStop Color="#D34C88" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Frame.Background>

                                        <Label Text="{Binding Initials}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="White"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Frame>

                                    <Label Grid.Row="1"
                                           Text="{Binding CandidateName}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#111827"
                                           HorizontalTextAlignment="Center"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1" />

                                    <Label Grid.Row="2"
                                           Text="{Binding JobTitle}"
                                           FontSize="12"
                                           TextColor="#8581A6"
                                           HorizontalTextAlignment="Center"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1" />

                                    <Grid Grid.Row="3"
                                          ColumnDefinitions="*,*"
                                          ColumnSpacing="6"
                                          VerticalOptions="End">

                                        <Button Grid.Column="0"
                                                Text="Profil"
                                                HeightRequest="34"
                                                Padding="0"
                                                FontSize="12"
                                                FontAttributes="Bold"
                                                BackgroundColor="Transparent"
                                                BorderColor="#DED8F5"
                                                BorderWidth="1"
                                                TextColor="#111827"
                                                CornerRadius="10"
                                                Clicked="Candidate_Clicked"
                                                CommandParameter="{Binding .}" />

                                        <Button Grid.Column="1"
                                                Text="Message"
                                                HeightRequest="34"
                                                Padding="0"
                                                FontSize="12"
                                                FontAttributes="Bold"
                                                BackgroundColor="#7C4DFF"
                                                TextColor="White"
                                                CornerRadius="10"
                                                Clicked="Contact_Clicked"
                                                CommandParameter="{Binding .}" />
                                    </Grid>


                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="Match_Tapped"
                                                              CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="ACTIVITÉ RÉCENTE"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#8581A6"
                       Margin="0,18,0,12" />

                <VerticalStackLayout Spacing="12">

                    <Frame CornerRadius="18"
                           Padding="14"
                           BackgroundColor="White"
                           BorderColor="#EEEAF8"
                           HasShadow="False">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Frame WidthRequest="46"
                                   HeightRequest="46"
                                   CornerRadius="23"
                                   Padding="0"
                                   BackgroundColor="#E9FFF7"
                                   HasShadow="False">
                                <Label Text="🎯"
                                       FontSize="20"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="Nouveau match"
                                       FontSize="15"
                                       TextColor="#111827" />
                                <Label Text="Un candidat a répondu à ton intérêt."
                                       FontSize="12"
                                       TextColor="#8581A6" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="2h"
                                   FontSize="12"
                                   TextColor="#8581A6"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>

                    <Frame CornerRadius="18"
                           Padding="14"
                           BackgroundColor="White"
                           BorderColor="#EEEAF8"
                           HasShadow="False">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Frame WidthRequest="46"
                                   HeightRequest="46"
                                   CornerRadius="23"
                                   Padding="0"
                                   BackgroundColor="#F0EAFE"
                                   HasShadow="False">
                                <Label Text="💬"
                                       FontSize="20"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="Message reçu"
                                       FontSize="15"
                                       TextColor="#111827" />
                                <Label Text="Une conversation est active."
                                       FontSize="12"
                                       TextColor="#8581A6" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="5h"
                                   FontSize="12"
                                   TextColor="#8581A6"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
