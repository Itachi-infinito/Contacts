<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.RecruiterJobOffersPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto,*"
              RowSpacing="18"
              Padding="24,28,24,16">

            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto">

                <VerticalStackLayout Spacing="4">
                    <Label Text="Mes offres"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <Label x:Name="lblOfferCount"
                           Text="0 offre publiée"
                           FontSize="13"
                           TextColor="#8B86A3" />
                </VerticalStackLayout>

                <Frame Grid.Column="1"
                       WidthRequest="52"
                       HeightRequest="52"
                       CornerRadius="26"
                       Padding="0"
                       HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Profile_Tapped" />

                    </Frame.GestureRecognizers>

                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C4DFF" Offset="0.0" />
                            <GradientStop Color="#D34C88" Offset="1.0" />
                        </LinearGradientBrush>
                    </Frame.Background>

                    <Label Text="AL"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="16"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Frame>
            </Grid>

            <Frame Grid.Row="1"
                   CornerRadius="18"
                   Padding="14"
                   BackgroundColor="White"
                   BorderColor="#EEEAF8"
                   HasShadow="False">

                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="10">

                    <Label Text="⌕"
                           FontSize="18"
                           TextColor="#8B86A3"
                           VerticalTextAlignment="Center" />

                    <Label Grid.Column="1"
                           Text="Gérer vos postes horeca actifs"
                           FontSize="13"
                           TextColor="#A6A0C0"
                           VerticalTextAlignment="Center" />

                    <Button Grid.Column="2"
                            Text="Créer"
                            HeightRequest="36"
                            Padding="12,0"
                            BackgroundColor="#F0EAFE"
                            TextColor="#7C4DFF"
                            FontAttributes="Bold"
                            FontSize="12"
                            CornerRadius="12"
                            Clicked="CreateOffer_Clicked" />
                </Grid>
            </Frame>

            <CollectionView Grid.Row="2"
                            x:Name="jobOffersCollection"
                            SelectionMode="None">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                                       ItemSpacing="14" />
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <Frame BackgroundColor="White"
                           BorderColor="#EEEAF8"
                           CornerRadius="24"
                           Padding="24"
                           HasShadow="False"
                           HorizontalOptions="Fill"
                           VerticalOptions="Center">

                        <VerticalStackLayout Spacing="12"
                                             HorizontalOptions="Center">

                            <Frame WidthRequest="76"
                                   HeightRequest="76"
                                   CornerRadius="24"
                                   Padding="0"
                                   BackgroundColor="#F0EAFE"
                                   HasShadow="False">

                                <Label Text="+"
                                       FontSize="36"
                                       FontAttributes="Bold"
                                       TextColor="#7C4DFF"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <Label Text="Aucune offre"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="Center" />

                            <Label Text="Crée votre première offre pour commencer à recevoir des candidats."
                                   FontSize="13"
                                   TextColor="#8581A6"
                                   HorizontalTextAlignment="Center" />

                            <Button Text="Créer une offre"
                                    HeightRequest="44"
                                    Padding="18,0"
                                    BackgroundColor="#7C4DFF"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    CornerRadius="14"
                                    Clicked="CreateOffer_Clicked" />
                        </VerticalStackLayout>
                    </Frame>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>

                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItemView>
                                        <Grid WidthRequest="128"
                                              ColumnDefinitions="*,*"
                                              ColumnSpacing="10"
                                              VerticalOptions="Center">

                                            <Frame Grid.Column="0"
                                                   WidthRequest="50"
                                                   HeightRequest="50"
                                                   CornerRadius="25"
                                                   Padding="0"
                                                   BackgroundColor="#F0EAFE"
                                                   HasShadow="False"
                                                   BindingContext="{Binding .}"
                                                   Scale="0.96"
                                                   Loaded="SwipeBubble_Loaded">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="EditBubble_Tapped" />
                                                </Frame.GestureRecognizers>

                                                <Label Text="✎"
                                                       FontSize="20"
                                                       TextColor="#7C4DFF"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Frame>

                                            <Frame Grid.Column="1"
                                                   WidthRequest="50"
                                                   HeightRequest="50"
                                                   CornerRadius="25"
                                                   Padding="0"
                                                   BackgroundColor="#FFF1F4"
                                                   HasShadow="False"
                                                   BindingContext="{Binding .}"
                                                   Scale="0.96"
                                                   Loaded="SwipeBubble_Loaded">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="DeleteBubble_Tapped" />
                                                </Frame.GestureRecognizers>

                                                <Label Text="×"
                                                       FontSize="24"
                                                       TextColor="#EF4D7A"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Frame>
                                        </Grid>
                                    </SwipeItemView>
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Frame BackgroundColor="White"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="24"
                                   Padding="16"
                                   HasShadow="False"
                                   Loaded="JobOfferCard_Loaded"
                                   Opacity="0"
                                   TranslationY="16"
                                   Scale="0.985">

                                <VerticalStackLayout Spacing="14">

                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10">

                                        <VerticalStackLayout Spacing="5">
                                            <Label Text="{Binding Title}"
                                                   FontSize="20"
                                                   FontAttributes="Bold"
                                                   TextColor="#111827"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1" />

                                            <Label Text="{Binding CompanyName}"
                                                   FontSize="14"
                                                   TextColor="#7C4DFF"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1" />

                                            <Label Text="{Binding Location}"
                                                   FontSize="13"
                                                   TextColor="#8581A6"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1" />
                                        </VerticalStackLayout>

                                        <Frame Grid.Column="1"
                                               BackgroundColor="#F0EAFE"
                                               CornerRadius="12"
                                               Padding="10,4"
                                               HasShadow="False"
                                               VerticalOptions="Start">

                                            <Label Text="Actif"
                                                   FontSize="12"
                                                   TextColor="#7C4DFF" />
                                        </Frame>
                                    </Grid>

                                    <HorizontalStackLayout Spacing="8">
                                        <Frame BackgroundColor="#F0EAFE"
                                               CornerRadius="12"
                                               Padding="10,4"
                                               HasShadow="False">
                                            <Label Text="{Binding ContractType}"
                                                   FontSize="12"
                                                   TextColor="#7C4DFF" />
                                        </Frame>

                                        <Frame BackgroundColor="#F0EAFE"
                                               CornerRadius="12"
                                               Padding="10,4"
                                               HasShadow="False"
                                               IsVisible="{Binding HasLevel}">
                                            <Label Text="{Binding Level}"
                                                   FontSize="12"
                                                   TextColor="#7C4DFF" />
                                        </Frame>

                                        <Frame BackgroundColor="#F0EAFE"
                                               CornerRadius="12"
                                               Padding="10,4"
                                               HasShadow="False"
                                               IsVisible="{Binding HasRemoteMode}">
                                            <Label Text="{Binding RemoteMode}"
                                                   FontSize="12"
                                                   TextColor="#7C4DFF" />
                                        </Frame>
                                    </HorizontalStackLayout>

                                    <Label Text="{Binding SalaryDisplay}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#111827"
                                           IsVisible="{Binding HasSalary}" />

                                    <Frame BackgroundColor="#FAF9FF"
                                           BorderColor="#EEEAF8"
                                           CornerRadius="16"
                                           Padding="12"
                                           HasShadow="False"
                                           IsVisible="{Binding HasRequiredSkills}">

                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="Compétences recherchées"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="#8581A6" />

                                            <Label Text="{Binding RequiredSkills}"
                                                   FontSize="13"
                                                   TextColor="#5F5A75"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </Frame>

                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="10">

                                        <Button Text="Modifier"
                                                HeightRequest="40"
                                                BackgroundColor="#7C4DFF"
                                                TextColor="White"
                                                FontAttributes="Bold"
                                                CornerRadius="13"
                                                Clicked="Edit_Clicked"
                                                CommandParameter="{Binding .}" />

                                        <Button Grid.Column="1"
                                                Text="Supprimer"
                                                HeightRequest="40"
                                                BackgroundColor="White"
                                                BorderColor="#F3C8D4"
                                                BorderWidth="1"
                                                TextColor="#EF4D7A"
                                                FontAttributes="Bold"
                                                CornerRadius="13"
                                                Clicked="Delete_Clicked"
                                                CommandParameter="{Binding .}" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Frame>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <Grid Grid.Row="1"
              BackgroundColor="White"
              Padding="18,8,18,18"
              ColumnDefinitions="*,*,Auto,*,*">

            <Button Text="Accueil"
                    Grid.Column="0"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Home_Clicked" />

            <Button Grid.Column="1"
                    Text="Découvrir"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Discover_Button_Clicked" />

            <Frame Grid.Column="2"
                   WidthRequest="50"
                   HeightRequest="50"
                   CornerRadius="25"
                   Padding="0"
                   BackgroundColor="#7C4DFF"
                   HasShadow="True"
                   Margin="8,0">
                <Frame.Shadow>
                    <Shadow Brush="#557C4DFF"
                            Offset="0,8"
                            Radius="18" />
                </Frame.Shadow>

                <Button Text="+"
                        FontSize="24"
                        FontAttributes="Bold"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        Clicked="CreateOffer_Clicked" />
            </Frame>

            <Button Grid.Column="3"
                    Text="Messages"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Messages_Button_Clicked" />

            <Button Grid.Column="4"
                    Text="Profil"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Profile_Clicked" />
        </Grid>
    </Grid>
</ContentPage>
