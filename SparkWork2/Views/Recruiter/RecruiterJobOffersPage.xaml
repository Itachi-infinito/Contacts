<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Recruiter.RecruiterJobOffersPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F8F6FF">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto,Auto,*"
              RowSpacing="16"
              Padding="28,34,28,0"
              BackgroundColor="#F8F6FF">

            <!-- HEADER -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto">

                <VerticalStackLayout Spacing="4">
                    <Label Text="Mes offres"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <Label x:Name="lblOfferCount"
                           Text="Aucune offre publiée"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#8B86A3" />
                </VerticalStackLayout>

                <Frame Grid.Column="1"
                       WidthRequest="54"
                       HeightRequest="54"
                       CornerRadius="27"
                       Padding="0"
                       HasShadow="False"
                       VerticalOptions="Center">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Profile_Tapped" />
                    </Frame.GestureRecognizers>

                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C4DFF" Offset="0.0" />
                            <GradientStop Color="#D34C88" Offset="1.0" />
                        </LinearGradientBrush>
                    </Frame.Background>

                    <Label x:Name="lblHeaderInitials"
                           Text="AL"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="17"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Frame>
            </Grid>

            <!-- SEARCH / CREATE -->
            <Frame Grid.Row="1"
                   CornerRadius="18"
                   Padding="14"
                   BackgroundColor="White"
                   BorderColor="#DED8F5"
                   HasShadow="False">

                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12">

                    <Label Text="&#xE8B6;"
                           FontFamily="MaterialIcons"
                           FontSize="22"
                           TextColor="#8B86A3"
                           VerticalTextAlignment="Center" />

                    <Label Grid.Column="1"
                           Text="Gérer vos postes actifs..."
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#B0ABCE"
                           VerticalTextAlignment="Center"
                           LineBreakMode="TailTruncation" />

                    <Frame Grid.Column="2"
                           HeightRequest="44"
                           CornerRadius="14"
                           Padding="0"
                           HasShadow="False"
                           VerticalOptions="Center">
                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>

                        <Grid Padding="16,0">
                            <HorizontalStackLayout Spacing="7"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                <Label Text="+"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       VerticalTextAlignment="Center" />
                                <Label Text="Créer"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>

                            <Button BackgroundColor="Transparent"
                                    Text=""
                                    Clicked="CreateOffer_Clicked" />
                        </Grid>
                    </Frame>
                </Grid>
            </Frame>

            <!-- MINI STATS -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="12">

                <Frame CornerRadius="16"
                       Padding="14"
                       BackgroundColor="White"
                       BorderColor="#DED8F5"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="4"
                                         HorizontalOptions="Center">
                        <Label x:Name="lblActiveOffersCount"
                               Text="0"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#7C4DFF"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Offre active"
                               FontSize="12"
                               TextColor="#8B86A3"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1"
                       CornerRadius="16"
                       Padding="14"
                       BackgroundColor="White"
                       BorderColor="#DED8F5"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="4"
                                         HorizontalOptions="Center">
                        <Label x:Name="lblCandidatesSeenCount"
                               Text="0"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#A78BFA"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Candidats vus"
                               FontSize="12"
                               TextColor="#8B86A3"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="2"
                       CornerRadius="16"
                       Padding="14"
                       BackgroundColor="White"
                       BorderColor="#DED8F5"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="4"
                                         HorizontalOptions="Center">
                        <Label x:Name="lblTotalMatchesCount"
                               Text="0"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#D34C88"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Matchs total"
                               FontSize="12"
                               TextColor="#8B86A3"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- CONTENT / EMPTY -->
            <Grid Grid.Row="3">

                <!-- OFFERS CONTENT -->
                <Grid x:Name="offersContent"
                      RowDefinitions="Auto,*"
                      RowSpacing="12"
                      IsVisible="False">

                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto"
                          Margin="4,2,4,0">
                        <Label Text="Offres publiées"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#8B86A3"
                               VerticalTextAlignment="Center" />

                        <Frame Grid.Column="1"
                               BackgroundColor="#F0EAFE"
                               CornerRadius="14"
                               Padding="14,6"
                               HasShadow="False">
                            <Label Text="Tout voir"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#7C4DFF" />
                        </Frame>
                    </Grid>

                    <CollectionView Grid.Row="1"
                                    x:Name="jobOffersCollection"
                                    SelectionMode="None">

                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical"
                                               ItemSpacing="14" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <SwipeView>

                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItemView>
                                                <Grid WidthRequest="128"
                                                      ColumnDefinitions="*,*"
                                                      ColumnSpacing="10"
                                                      VerticalOptions="Center">

                                                    <Frame Grid.Column="0"
                                                           WidthRequest="50"
                                                           HeightRequest="50"
                                                           CornerRadius="25"
                                                           Padding="0"
                                                           BackgroundColor="#F0EAFE"
                                                           HasShadow="False"
                                                           BindingContext="{Binding .}"
                                                           Scale="0.96"
                                                           Loaded="SwipeBubble_Loaded">
                                                        <Frame.GestureRecognizers>
                                                            <TapGestureRecognizer Tapped="EditBubble_Tapped" />
                                                        </Frame.GestureRecognizers>

                                                        <Label Text="✎"
                                                               FontSize="20"
                                                               TextColor="#7C4DFF"
                                                               HorizontalTextAlignment="Center"
                                                               VerticalTextAlignment="Center" />
                                                    </Frame>

                                                    <Frame Grid.Column="1"
                                                           WidthRequest="50"
                                                           HeightRequest="50"
                                                           CornerRadius="25"
                                                           Padding="0"
                                                           BackgroundColor="#FFF1F4"
                                                           HasShadow="False"
                                                           BindingContext="{Binding .}"
                                                           Scale="0.96"
                                                           Loaded="SwipeBubble_Loaded">
                                                        <Frame.GestureRecognizers>
                                                            <TapGestureRecognizer Tapped="DeleteBubble_Tapped" />
                                                        </Frame.GestureRecognizers>

                                                        <Label Text="×"
                                                               FontSize="24"
                                                               TextColor="#EF4444"
                                                               HorizontalTextAlignment="Center"
                                                               VerticalTextAlignment="Center" />
                                                    </Frame>
                                                </Grid>
                                            </SwipeItemView>
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <Frame BackgroundColor="White"
                                           BorderColor="#DED8F5"
                                           CornerRadius="24"
                                           Padding="20"
                                           HasShadow="False"
                                           Loaded="JobOfferCard_Loaded"
                                           Opacity="{Binding CardOpacity}"
                                           TranslationY="16"
                                           Scale="0.985">

                                        <VerticalStackLayout Spacing="14">

                                            <!-- TITLE -->
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="10">

                                                <VerticalStackLayout Spacing="3">
                                                    <Label Text="{Binding Title}"
                                                           FontSize="22"
                                                           FontAttributes="Bold"
                                                           TextColor="#111827"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1" />

                                                    <Label Text="{Binding CompanyName}"
                                                           FontSize="14"
                                                           FontAttributes="Bold"
                                                           TextColor="#7C4DFF"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1" />

                                                    <HorizontalStackLayout Spacing="4">
                                                        <Label Text="&#xE0C8;"
                                                               FontFamily="MaterialIcons"
                                                               FontSize="15"
                                                               TextColor="#8B86A3" />
                                                        <Label Text="{Binding Location}"
                                                               FontSize="14"
                                                               FontAttributes="Bold"
                                                               TextColor="#8B86A3"
                                                               LineBreakMode="TailTruncation"
                                                               MaxLines="1" />
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>

                                                <Frame Grid.Column="1"
                                                       CornerRadius="14"
                                                       Padding="12,5"
                                                       HasShadow="False"
                                                       VerticalOptions="Start"
                                                       BackgroundColor="#DCFCE7">
                                                    <Frame.Triggers>
                                                        <DataTrigger TargetType="Frame"
                                                                     Binding="{Binding IsPaused}"
                                                                     Value="True">
                                                            <Setter Property="BackgroundColor"
                                                                    Value="#FEF3C7" />
                                                        </DataTrigger>
                                                    </Frame.Triggers>

                                                    <Label Text="{Binding StatusText}"
                                                           FontSize="12"
                                                           FontAttributes="Bold"
                                                           TextColor="#166534">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label"
                                                                         Binding="{Binding IsPaused}"
                                                                         Value="True">
                                                                <Setter Property="TextColor"
                                                                        Value="#92400E" />
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                </Frame>
                                            </Grid>

                                            <!-- TAGS -->
                                            <FlexLayout Direction="Row"
                                                        Wrap="Wrap"
                                                        AlignItems="Center"
                                                        JustifyContent="Start">

                                                <Frame BackgroundColor="#FAF9FF"
                                                       BorderColor="#CFC4FF"
                                                       CornerRadius="13"
                                                       Padding="12,5"
                                                       HasShadow="False"
                                                       Margin="0,0,8,6">
                                                    <Label Text="{Binding ContractType}"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="#5F4ACB" />
                                                </Frame>

                                                <Frame BackgroundColor="#FAF9FF"
                                                       BorderColor="#CFC4FF"
                                                       CornerRadius="13"
                                                       Padding="12,5"
                                                       HasShadow="False"
                                                       Margin="0,0,8,6"
                                                       IsVisible="{Binding HasLevel}">
                                                    <Label Text="{Binding Level}"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="#5F4ACB" />
                                                </Frame>

                                                <Frame BackgroundColor="#FAF9FF"
                                                       BorderColor="#CFC4FF"
                                                       CornerRadius="13"
                                                       Padding="12,5"
                                                       HasShadow="False"
                                                       Margin="0,0,8,6"
                                                       IsVisible="{Binding HasRemoteMode}">
                                                    <Label Text="{Binding RemoteMode}"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="#5F4ACB" />
                                                </Frame>
                                            </FlexLayout>

                                            <!-- SALARY -->
                                            <HorizontalStackLayout Spacing="8"
                                                                   IsVisible="{Binding HasSalary}">
                                                <Label Text="$"
                                                       FontSize="18"
                                                       FontAttributes="Bold"
                                                       TextColor="#7C4DFF"
                                                       VerticalTextAlignment="Center" />

                                                <Label Text="{Binding SalaryDisplay}"
                                                       FontSize="17"
                                                       FontAttributes="Bold"
                                                       TextColor="#111827"
                                                       VerticalTextAlignment="Center" />
                                            </HorizontalStackLayout>

                                            <!-- SKILLS -->
                                            <Frame BackgroundColor="#FAF9FF"
                                                   BorderColor="#DED8F5"
                                                   CornerRadius="16"
                                                   Padding="14"
                                                   HasShadow="False"
                                                   IsVisible="{Binding HasRequiredSkills}">

                                                <VerticalStackLayout Spacing="8">
                                                    <Label Text="COMPÉTENCES RECHERCHÉES"
                                                           FontSize="12"
                                                           FontAttributes="Bold"
                                                           TextColor="#8581A6" />

                                                    <FlexLayout Direction="Row"
                                                                Wrap="Wrap"
                                                                BindableLayout.ItemsSource="{Binding RequiredSkillItems}">
                                                        <BindableLayout.ItemTemplate>
                                                            <DataTemplate>
                                                                <Frame BackgroundColor="#F0EAFE"
                                                                       CornerRadius="12"
                                                                       Padding="10,4"
                                                                       HasShadow="False"
                                                                       Margin="0,0,8,6">
                                                                    <Label Text="{Binding .}"
                                                                           FontSize="12"
                                                                           TextColor="#5F4ACB" />
                                                                </Frame>
                                                            </DataTemplate>
                                                        </BindableLayout.ItemTemplate>
                                                    </FlexLayout>
                                                </VerticalStackLayout>
                                            </Frame>

                                            <!-- OFFER STATS -->
                                            <Grid ColumnDefinitions="*,*,*"
                                                  ColumnSpacing="10">

                                                <Frame CornerRadius="12"
                                                       Padding="10"
                                                       BackgroundColor="#FAF9FF"
                                                       BorderColor="#DED8F5"
                                                       HasShadow="False">
                                                    <VerticalStackLayout Spacing="2"
                                                                         HorizontalOptions="Center">
                                                        <Label Text="{Binding ViewsCount}"
                                                               FontSize="18"
                                                               FontAttributes="Bold"
                                                               TextColor="#111827"
                                                               HorizontalTextAlignment="Center" />
                                                        <Label Text="Vues"
                                                               FontSize="12"
                                                               TextColor="#8B86A3"
                                                               HorizontalTextAlignment="Center" />
                                                    </VerticalStackLayout>
                                                </Frame>

                                                <Frame Grid.Column="1"
                                                       CornerRadius="12"
                                                       Padding="10"
                                                       BackgroundColor="#FAF9FF"
                                                       BorderColor="#DED8F5"
                                                       HasShadow="False">
                                                    <VerticalStackLayout Spacing="2"
                                                                         HorizontalOptions="Center">
                                                        <Label Text="{Binding MatchesCount}"
                                                               FontSize="18"
                                                               FontAttributes="Bold"
                                                               TextColor="#7C4DFF"
                                                               HorizontalTextAlignment="Center" />
                                                        <Label Text="Matchs"
                                                               FontSize="12"
                                                               TextColor="#8B86A3"
                                                               HorizontalTextAlignment="Center" />
                                                    </VerticalStackLayout>
                                                </Frame>

                                                <Frame Grid.Column="2"
                                                       CornerRadius="12"
                                                       Padding="10"
                                                       BackgroundColor="#FAF9FF"
                                                       BorderColor="#DED8F5"
                                                       HasShadow="False">
                                                    <VerticalStackLayout Spacing="2"
                                                                         HorizontalOptions="Center">
                                                        <Label Text="{Binding RetainedCount}"
                                                               FontSize="18"
                                                               FontAttributes="Bold"
                                                               TextColor="#D34C88"
                                                               HorizontalTextAlignment="Center" />
                                                        <Label Text="Retenus"
                                                               FontSize="12"
                                                               TextColor="#8B86A3"
                                                               HorizontalTextAlignment="Center" />
                                                    </VerticalStackLayout>
                                                </Frame>
                                            </Grid>

                                            <!-- ACTIONS -->
                                            <Grid ColumnDefinitions="*,*"
                                                  ColumnSpacing="12">

                                                <Frame CornerRadius="24"
                                                       HeightRequest="50"
                                                       Padding="0"
                                                       HasShadow="False">
                                                    <Frame.Background>
                                                        <LinearGradientBrush StartPoint="0,0"
                                                                             EndPoint="1,1">
                                                            <GradientStop Color="#7C4DFF"
                                                                          Offset="0.0" />
                                                            <GradientStop Color="#D34C88"
                                                                          Offset="1.0" />
                                                        </LinearGradientBrush>
                                                    </Frame.Background>

                                                    <Grid>
                                                        <HorizontalStackLayout Spacing="8"
                                                                               HorizontalOptions="Center"
                                                                               VerticalOptions="Center">
                                                            <Label Text="{Binding PrimaryActionIcon}"
                                                                   FontSize="18"
                                                                   TextColor="White"
                                                                   VerticalTextAlignment="Center" />
                                                            <Label Text="{Binding PrimaryActionText}"
                                                                   FontSize="16"
                                                                   FontAttributes="Bold"
                                                                   TextColor="White"
                                                                   VerticalTextAlignment="Center" />
                                                        </HorizontalStackLayout>

                                                        <Button BackgroundColor="Transparent"
                                                                Text=""
                                                                Clicked="Edit_Clicked"
                                                                CommandParameter="{Binding .}" />
                                                    </Grid>
                                                </Frame>

                                                <Button Grid.Column="1"
                                                        Text="🗑  Supprimer"
                                                        HeightRequest="50"
                                                        BackgroundColor="White"
                                                        BorderColor="#F3C8D4"
                                                        BorderWidth="1.5"
                                                        TextColor="#EF4444"
                                                        FontAttributes="Bold"
                                                        FontSize="15"
                                                        CornerRadius="24"
                                                        Clicked="Delete_Clicked"
                                                        CommandParameter="{Binding .}" />
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Frame>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <CollectionView.Footer>
                            <VerticalStackLayout Padding="0,14,0,28"
                                                 Spacing="16">

                                <!-- CONSEIL -->
                                <Frame CornerRadius="22"
                                       Padding="20"
                                       BackgroundColor="#F7EFFF"
                                       BorderColor="#D8B4FE"
                                       HasShadow="False">
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="14">
                                        <Frame WidthRequest="44"
                                               HeightRequest="44"
                                               CornerRadius="14"
                                               Padding="0"
                                               BackgroundColor="White"
                                               HasShadow="False">
                                            <Label Text="💡"
                                                   FontSize="22"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center" />
                                        </Frame>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="4">
                                            <Label Text="Conseil"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="#111827" />

                                            <Label Text="Les offres avec des compétences définies et une description complète reçoivent 3× plus de candidats compatibles."
                                                   FontSize="15"
                                                   TextColor="#5F4ACB"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </VerticalStackLayout>
                        </CollectionView.Footer>
                    </CollectionView>
                </Grid>

                <!-- EMPTY STATE -->
                <VerticalStackLayout x:Name="emptyStateLayout"
                                     IsVisible="False"
                                     Spacing="18"
                                     HorizontalOptions="Fill"
                                     VerticalOptions="Center"
                                     Margin="0,8,0,18">

                    <Grid WidthRequest="250"
                          HeightRequest="210"
                          HorizontalOptions="Center">

                        <Ellipse WidthRequest="142"
                                 HeightRequest="142"
                                 Fill="#F0EAFE"
                                 Opacity="0.78"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center" />

                        <Ellipse WidthRequest="166"
                                 HeightRequest="166"
                                 Stroke="#CFC4FF"
                                 StrokeThickness="1.6"
                                 StrokeDashArray="6,5"
                                 Fill="Transparent"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center" />

                        <Border WidthRequest="58"
                                HeightRequest="78"
                                StrokeThickness="0"
                                Rotation="-14"
                                Opacity="0.55"
                                HorizontalOptions="Start"
                                VerticalOptions="Start"
                                Margin="58,28,0,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#D8CCFF"
                                                  Offset="0.0" />
                                    <GradientStop Color="#A78BFA"
                                                  Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <Border WidthRequest="58"
                                HeightRequest="78"
                                StrokeThickness="0"
                                Rotation="14"
                                Opacity="0.55"
                                HorizontalOptions="End"
                                VerticalOptions="Start"
                                Margin="0,44,54,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#FBCFE8"
                                                  Offset="0.0" />
                                    <GradientStop Color="#EC4899"
                                                  Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <Frame WidthRequest="76"
                               HeightRequest="76"
                               CornerRadius="38"
                               Padding="0"
                               BackgroundColor="White"
                               HasShadow="True"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
                            <Frame.Shadow>
                                <Shadow Brush="#18000000"
                                        Offset="0,10"
                                        Radius="18"
                                        Opacity="1" />
                            </Frame.Shadow>

                            <Label Text="&#xE873;"
                                   FontFamily="MaterialIcons"
                                   FontSize="36"
                                   TextColor="#B13CC7"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>
                    </Grid>

                    <VerticalStackLayout Spacing="10"
                                         HorizontalOptions="Center">
                        <Label Text="Aucune offre publiée"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               HorizontalTextAlignment="Center" />

                        <Label Text="Créez votre première offre pour commencer à recevoir des candidats compatibles avec votre profil."
                               WidthRequest="310"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#8B86A3"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <Frame HeightRequest="62"
                           CornerRadius="31"
                           Padding="0"
                           HasShadow="True"
                           Margin="20,12,20,0"
                           HorizontalOptions="Fill">
                        <Frame.Shadow>
                            <Shadow Brush="#307C4DFF"
                                    Offset="0,10"
                                    Radius="18"
                                    Opacity="1" />
                        </Frame.Shadow>

                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,1">
                                <GradientStop Color="#7C4DFF"
                                              Offset="0.0" />
                                <GradientStop Color="#D34C88"
                                              Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>

                        <Grid>
                            <HorizontalStackLayout Spacing="10"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                <Label Text="+"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label Text="Créer ma première offre"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                            </HorizontalStackLayout>

                            <Button BackgroundColor="Transparent"
                                    Text=""
                                    Clicked="CreateOffer_Clicked" />
                        </Grid>
                    </Frame>

                    <Label Text="• Visible par les candidats dès la publication •"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#B0ABCE"
                           HorizontalTextAlignment="Center" />

                    <Frame CornerRadius="22"
                           Padding="20"
                           BackgroundColor="#F7EFFF"
                           BorderColor="#D8B4FE"
                           HasShadow="False"
                           Margin="0,12,0,0">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Frame WidthRequest="44"
                                   HeightRequest="44"
                                   CornerRadius="14"
                                   Padding="0"
                                   BackgroundColor="White"
                                   HasShadow="False">
                                <Label Text="💡"
                                       FontSize="22"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4">
                                <Label Text="Conseil"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />

                                <Label Text="Les offres complètes avec compétences et description reçoivent 3× plus de candidats compatibles."
                                       FontSize="15"
                                       TextColor="#5F4ACB"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- BOTTOM NAV -->
        <Grid Grid.Row="1"
              HeightRequest="78"
              BackgroundColor="White"
              Padding="4,8,4,10"
              ColumnDefinitions="*,*,*,*,*">

            <BoxView Grid.ColumnSpan="5"
                     HeightRequest="0.5"
                     Color="#E5E0F5"
                     VerticalOptions="Start" />

            <!-- Accueil -->
            <Grid Grid.Column="0">
                <VerticalStackLayout HorizontalOptions="Center"
                                     Spacing="2"
                                     VerticalOptions="Center">
                    <Label Text="&#xE88A;"
                           FontFamily="MaterialIcons"
                           FontSize="24"
                           TextColor="#b0a8cc"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Accueil"
                           FontSize="9"
                           TextColor="#b0a8cc"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Button BackgroundColor="Transparent"
                        Text=""
                        Clicked="Home_Clicked" />
            </Grid>

            <!-- Découvrir -->
            <Grid Grid.Column="1">
                <VerticalStackLayout HorizontalOptions="Center"
                                     Spacing="2"
                                     VerticalOptions="Center">
                    <Label Text="&#xE8B6;"
                           FontFamily="MaterialIcons"
                           FontSize="24"
                           TextColor="#b0a8cc"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Découvrir"
                           FontSize="9"
                           TextColor="#b0a8cc"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Button BackgroundColor="Transparent"
                        Text=""
                        Clicked="Discover_Button_Clicked" />
            </Grid>

            <!-- Plus -->
            <Border Grid.Column="2"
                    WidthRequest="50"
                    HeightRequest="50"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Margin="0,-2,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#7C4DFF"
                                      Offset="0.0" />
                        <GradientStop Color="#D34C88"
                                      Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Label Text="+"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />

                    <Button BackgroundColor="Transparent"
                            Text=""
                            Clicked="CreateOffer_Clicked" />
                </Grid>
            </Border>

            <!-- Messages -->
            <Grid Grid.Column="3">
                <VerticalStackLayout HorizontalOptions="Center"
                                     Spacing="2"
                                     VerticalOptions="Center">
                    <Label Text="&#xE0BF;"
                           FontFamily="MaterialIcons"
                           FontSize="24"
                           TextColor="#b0a8cc"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Messages"
                           FontSize="9"
                           TextColor="#b0a8cc"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Button BackgroundColor="Transparent"
                        Text=""
                        Clicked="Messages_Button_Clicked" />
            </Grid>

            <!-- Profil -->
            <Grid Grid.Column="4">
                <VerticalStackLayout HorizontalOptions="Center"
                                     Spacing="2"
                                     VerticalOptions="Center">
                    <Label Text="&#xE7FD;"
                           FontFamily="MaterialIcons"
                           FontSize="24"
                           TextColor="#b0a8cc"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Profil"
                           FontSize="9"
                           TextColor="#b0a8cc"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Button BackgroundColor="Transparent"
                        Text=""
                        Clicked="Profile_Clicked" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
