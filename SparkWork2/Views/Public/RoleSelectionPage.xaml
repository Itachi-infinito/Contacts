<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Public.RoleSelectionPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid Padding="24">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.0" />
                <GradientStop Color="#F7F5FC" Offset="0.48" />
                <GradientStop Color="#EDE7FF" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid RowDefinitions="Auto,*">

            <Button Grid.Row="0"
                    Text="‹"
                    FontSize="34"
                    Padding="0"
                    HeightRequest="44"
                    WidthRequest="44"
                    BackgroundColor="Transparent"
                    TextColor="#111827"
                    HorizontalOptions="Start"
                    Clicked="Back_Clicked" />

            <VerticalStackLayout Grid.Row="1"
                                 VerticalOptions="Center"
                                 Spacing="22">

                <VerticalStackLayout Spacing="8">
                    <Label Text="Choisis ton rôle"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           HorizontalTextAlignment="Center" />

                    <Label Text="Ton expérience SparkWork dépend de ce choix."
                           FontSize="14"
                           TextColor="#8581A6"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Frame BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       CornerRadius="26"
                       Padding="20"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16">

                        <Frame WidthRequest="72"
                               HeightRequest="72"
                               CornerRadius="24"
                               Padding="0"
                               HasShadow="False"
                               HorizontalOptions="Center">
                            <Frame.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C4DFF" Offset="0.0" />
                                    <GradientStop Color="#D34C88" Offset="1.0" />
                                </LinearGradientBrush>
                            </Frame.Background>

                            <Label Text="ME"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Je suis candidat"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="Center" />

                            <Label Text="Je cherche des opportunités et je veux matcher avec des recruteurs."
                                   FontSize="14"
                                   TextColor="#8581A6"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <Button Text="Continuer comme candidat"
                                HeightRequest="52"
                                BackgroundColor="#7C4DFF"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                Clicked="Candidate_Clicked" />
                    </VerticalStackLayout>
                </Frame>

                <Frame BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       CornerRadius="26"
                       Padding="20"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16">

                        <Frame WidthRequest="72"
                               HeightRequest="72"
                               CornerRadius="24"
                               Padding="0"
                               HasShadow="False"
                               HorizontalOptions="Center">
                            <Frame.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C4DFF" Offset="0.0" />
                                    <GradientStop Color="#D34C88" Offset="1.0" />
                                </LinearGradientBrush>
                            </Frame.Background>

                            <Label Text="HR"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Je suis recruteur"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="Center" />

                            <Label Text="Je publie des offres et je découvre des candidats qualifiés."
                                   FontSize="14"
                                   TextColor="#8581A6"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <Button Text="Continuer comme recruteur"
                                HeightRequest="52"
                                BackgroundColor="#F0EAFE"
                                TextColor="#7C4DFF"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                Clicked="Recruiter_Clicked" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
