<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Public.LoginPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid Padding="24">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.0" />
                <GradientStop Color="#F7F5FC" Offset="0.48" />
                <GradientStop Color="#EDE7FF" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid RowDefinitions="Auto,*">

            <Button Grid.Row="0"
                    Text="‹"
                    FontSize="34"
                    Padding="0"
                    HeightRequest="44"
                    WidthRequest="44"
                    BackgroundColor="Transparent"
                    TextColor="#111827"
                    HorizontalOptions="Start"
                    Clicked="Back_Clicked" />

            <VerticalStackLayout Grid.Row="1"
                                 VerticalOptions="Center"
                                 Spacing="22">

                <VerticalStackLayout Spacing="10"
                                     HorizontalOptions="Center">

                    <Frame WidthRequest="76"
                           HeightRequest="76"
                           CornerRadius="24"
                           Padding="0"
                           HasShadow="False"
                           HorizontalOptions="Center">

                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>

                        <Label Text="✦"
                               FontSize="34"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>

                    <Label Text="Connexion"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           HorizontalTextAlignment="Center" />

                    <Label Text="Retrouve tes opportunités et tes conversations."
                           FontSize="14"
                           TextColor="#8581A6"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Frame BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       CornerRadius="26"
                       Padding="22"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16">

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Email"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryEmail"
                                       Placeholder="email@example.com"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       Keyboard="Email"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Mot de passe"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />

                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryPassword"
                                       Placeholder="Mot de passe"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       IsPassword="True"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <Button Text="Se connecter"
                                HeightRequest="54"
                                BackgroundColor="#7C4DFF"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                Clicked="Login_Clicked" />

                        <Label Text="Mot de passe oublié ?"
                               FontSize="13"
                               TextColor="#8581A6"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Label HorizontalTextAlignment="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Pas encore de compte ? "
                                  TextColor="#8581A6" />
                            <Span Text="Créer un compte"
                                  TextColor="#7C4DFF"
                                  FontAttributes="Bold" />
                        </FormattedString>
                    </Label.FormattedText>

                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="SignUp_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
