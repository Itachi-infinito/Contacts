<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Public.RegisterCandidatePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="Auto,*"
          Padding="24,24,24,0">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.0" />
                <GradientStop Color="#F7F5FC" Offset="0.48" />
                <GradientStop Color="#EDE7FF" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto">

            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="34"
                    Padding="0"
                    HeightRequest="44"
                    WidthRequest="44"
                    BackgroundColor="Transparent"
                    TextColor="#111827"
                    Clicked="OnBackClicked" />

            <Label Grid.Column="1"
                   Text="Inscription candidat"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />

            <Frame Grid.Column="2"
                   HeightRequest="46"
                   WidthRequest="46"
                   CornerRadius="23"
                   Padding="0"
                   HasShadow="False">
                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label x:Name="lblHeaderInitials"
                       Text="ME"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="15"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="0,24,0,28"
                                 Spacing="16">

                <VerticalStackLayout Spacing="4">
                    <Label Text="CRÉER TON PROFIL"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#8581A6" />

                    <Label Text="Ces informations aideront les recruteurs à te découvrir."
                           FontSize="13"
                           TextColor="#8B86A3" />
                </VerticalStackLayout>

                <Frame CornerRadius="24"
                       Padding="20"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="14"
                                         HorizontalOptions="Center">

                        <Grid WidthRequest="112"
                              HeightRequest="112">

                            <Frame x:Name="photoPlaceholderFrame"
                                   WidthRequest="112"
                                   HeightRequest="112"
                                   CornerRadius="56"
                                   Padding="0"
                                   HasShadow="False">
                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                                        <GradientStop Color="#D34C88" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>

                                <Label x:Name="lblPhotoInitials"
                                       Text="ME"
                                       FontSize="30"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <Frame x:Name="photoImageFrame"
                                   WidthRequest="112"
                                   HeightRequest="112"
                                   CornerRadius="56"
                                   Padding="0"
                                   HasShadow="False"
                                   IsClippedToBounds="True"
                                   IsVisible="False">
                                <Image x:Name="imgCandidatePhoto"
                                       Aspect="AspectFill" />
                            </Frame>
                        </Grid>

                        <Button Text="Choisir une photo"
                                HeightRequest="40"
                                Padding="18,0"
                                BackgroundColor="#F0EAFE"
                                TextColor="#7C4DFF"
                                FontAttributes="Bold"
                                FontSize="13"
                                CornerRadius="12"
                                Clicked="ChoosePhoto_Clicked" />
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="24"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16">

                        <Label Text="Informations de connexion"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Nom complet"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />
                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryFullName"
                                       Placeholder="Ex: Marc Dupont"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       TextChanged="FullName_TextChanged"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Email"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />
                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryEmail"
                                       Placeholder="email@example.com"
                                       PlaceholderColor="#A6A0C0"
                                       Keyboard="Email"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Mot de passe"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />
                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryPassword"
                                       Placeholder="Minimum 4 caractères"
                                       PlaceholderColor="#A6A0C0"
                                       IsPassword="True"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Confirmer le mot de passe"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />
                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryConfirmPassword"
                                       Placeholder="Confirme ton mot de passe"
                                       PlaceholderColor="#A6A0C0"
                                       IsPassword="True"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="24"
                       Padding="18"
                       BackgroundColor="White"
                       BorderColor="#EEEAF8"
                       HasShadow="False">

                    <VerticalStackLayout Spacing="16">

                        <Label Text="Profil candidat"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Titre"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />
                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryTitle"
                                       Placeholder="Ex: Développeur junior"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="Localisation"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />
                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,4"
                                   HasShadow="False">
                                <Entry x:Name="entryLocation"
                                       Placeholder="Ex: Bruxelles"
                                       PlaceholderColor="#A6A0C0"
                                       TextColor="#111827"
                                       BackgroundColor="Transparent" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="À propos"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8581A6" />
                            <Frame BackgroundColor="#FAF9FF"
                                   BorderColor="#EEEAF8"
                                   CornerRadius="14"
                                   Padding="14,10"
                                   HasShadow="False">
                                <Editor x:Name="editorAbout"
                                        Placeholder="Présente ton profil en quelques lignes."
                                        PlaceholderColor="#A6A0C0"
                                        TextColor="#111827"
                                        BackgroundColor="Transparent"
                                        AutoSize="TextChanges"
                                        HeightRequest="120" />
                            </Frame>
                        </VerticalStackLayout>

                        <Button Text="Créer mon compte"
                                HeightRequest="54"
                                BackgroundColor="#7C4DFF"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                Clicked="CreateAccount_Clicked" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
