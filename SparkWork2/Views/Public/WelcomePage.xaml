<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Public.WelcomePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid Padding="24">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.0" />
                <GradientStop Color="#F7F5FC" Offset="0.48" />
                <GradientStop Color="#EDE7FF" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <VerticalStackLayout VerticalOptions="Center"
                             Spacing="24">

            <VerticalStackLayout Spacing="12"
                                 HorizontalOptions="Center">

                <Frame WidthRequest="92"
                       HeightRequest="92"
                       CornerRadius="30"
                       Padding="0"
                       HasShadow="False"
                       HorizontalOptions="Center">

                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C4DFF" Offset="0.0" />
                            <GradientStop Color="#D34C88" Offset="1.0" />
                        </LinearGradientBrush>
                    </Frame.Background>

                    <Label Text="✦"
                           FontSize="42"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Frame>

                <Label Text="SparkWork"
                       FontSize="44"
                       FontAttributes="Bold"
                       TextColor="#111827"
                       HorizontalTextAlignment="Center" />

                <Label Text="Match with jobs and talents"
                       FontSize="16"
                       TextColor="#8581A6"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Frame BackgroundColor="White"
                   BorderColor="#EEEAF8"
                   CornerRadius="26"
                   Padding="22"
                   HasShadow="False"
                   Margin="0,8,0,0">

                <VerticalStackLayout Spacing="18">

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Bienvenue"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               HorizontalTextAlignment="Center" />

                        <Label Text="Connecte candidats et recruteurs autour des bonnes opportunités."
                               FontSize="14"
                               TextColor="#8581A6"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <Button Text="Se connecter"
                            HeightRequest="54"
                            BackgroundColor="#7C4DFF"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="14"
                            Clicked="Login_Clicked" />

                    <Button Text="Créer un compte"
                            HeightRequest="54"
                            BackgroundColor="#F0EAFE"
                            TextColor="#7C4DFF"
                            FontAttributes="Bold"
                            CornerRadius="14"
                            Clicked="Register_Clicked" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </Grid>
</ContentPage>
