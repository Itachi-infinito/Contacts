<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Shared.ConversationDetailPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="20,28,20,14"
              ColumnDefinitions="Auto,Auto,*,Auto"
              ColumnSpacing="12">

            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="32"
                    Padding="0"
                    WidthRequest="42"
                    HeightRequest="42"
                    BackgroundColor="Transparent"
                    TextColor="#111827"
                    Clicked="Back_Clicked" />

            <Frame Grid.Column="1"
                   WidthRequest="46"
                   HeightRequest="46"
                   CornerRadius="23"
                   Padding="0"
                   HasShadow="False"
                   VerticalOptions="Center">

                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label x:Name="lblParticipantInitials"
                       Text="?"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>

            <VerticalStackLayout Grid.Column="2"
                                 Spacing="2"
                                 VerticalOptions="Center">

                <Label x:Name="lblConversationTitle"
                       Text="Conversation"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#111827"
                       LineBreakMode="TailTruncation"
                       MaxLines="1" />

                <Label Text="Conversation SparkWork"
                       FontSize="12"
                       TextColor="#8B86A3" />
            </VerticalStackLayout>

            <Frame Grid.Column="3"
                   WidthRequest="36"
                   HeightRequest="36"
                   CornerRadius="18"
                   Padding="0"
                   BackgroundColor="#F0EAFE"
                   HasShadow="False"
                   VerticalOptions="Center">

                <Label Text="⋯"
                       FontSize="20"
                       TextColor="#7C4DFF"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>
        </Grid>

        <!-- MESSAGES -->
        <CollectionView Grid.Row="1"
                        x:Name="conversationCollection"
                        SelectionMode="None"
                        Margin="18,8,18,8">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical"
                                   ItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="12"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">

                    <Frame WidthRequest="76"
                           HeightRequest="76"
                           CornerRadius="38"
                           Padding="0"
                           BackgroundColor="#F0EAFE"
                           HasShadow="False">

                        <Label Text="✉"
                               FontSize="34"
                               TextColor="#7C4DFF"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>

                    <Label Text="Aucun message"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           HorizontalTextAlignment="Center" />

                    <Label Text="Démarre la conversation."
                           FontSize="13"
                           TextColor="#8581A6"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="0,2">

                        <!-- RECEIVED -->
                        <Frame BackgroundColor="#FAF9FF"
                               BorderColor="#EEEAF8"
                               CornerRadius="18"
                               Padding="13,10"
                               HasShadow="False"
                               HorizontalOptions="Start"
                               MaximumWidthRequest="285"
                               IsVisible="False">

                            <Frame.Triggers>
                                <DataTrigger TargetType="Frame"
                                             Binding="{Binding IsMine}"
                                             Value="False">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </Frame.Triggers>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding SenderName}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#7C4DFF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />

                                <Label Text="{Binding Content}"
                                       FontSize="14"
                                       TextColor="#111827"
                                       LineBreakMode="WordWrap" />

                                <Label Text="{Binding SentAt, StringFormat='{0:HH:mm}'}"
                                       FontSize="10"
                                       TextColor="#8B86A3"
                                       HorizontalTextAlignment="End" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- SENT -->
                        <Frame CornerRadius="18"
                               Padding="13,10"
                               HasShadow="False"
                               HorizontalOptions="End"
                               MaximumWidthRequest="285"
                               IsVisible="False">

                            <Frame.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C4DFF" Offset="0.0" />
                                    <GradientStop Color="#D34C88" Offset="1.0" />
                                </LinearGradientBrush>
                            </Frame.Background>

                            <Frame.Triggers>
                                <DataTrigger TargetType="Frame"
                                             Binding="{Binding IsMine}"
                                             Value="True">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </Frame.Triggers>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding Content}"
                                       FontSize="14"
                                       TextColor="White"
                                       LineBreakMode="WordWrap" />

                                <Label Text="{Binding SentAt, StringFormat='{0:HH:mm}'}"
                                       FontSize="10"
                                       TextColor="#F4EFFF"
                                       HorizontalTextAlignment="End" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- INPUT -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="10"
              Padding="18,10,18,18"
              BackgroundColor="White">

            <Frame Grid.Column="0"
                   BackgroundColor="#FAF9FF"
                   CornerRadius="18"
                   Padding="14,5"
                   HasShadow="False"
                   BorderColor="#EEEAF8">

                <Entry x:Name="editorNewMessage"
                       Placeholder="Écrire un message..."
                       PlaceholderColor="#A6A0C0"
                       TextColor="#111827"
                       BackgroundColor="Transparent"
                       ReturnType="Send"
                       Completed="Message_Completed"
                       VerticalOptions="Center" />
            </Frame>

            <Frame Grid.Column="1"
                   WidthRequest="52"
                   HeightRequest="52"
                   CornerRadius="26"
                   Padding="0"
                   HasShadow="True"
                   VerticalOptions="Center">

                <Frame.Shadow>
                    <Shadow Brush="#557C4DFF"
                            Offset="0,8"
                            Radius="18" />
                </Frame.Shadow>

                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Button x:Name="btnSend"
                        Text="➤"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontAttributes="Bold"
                        Clicked="Send_Clicked" />
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
