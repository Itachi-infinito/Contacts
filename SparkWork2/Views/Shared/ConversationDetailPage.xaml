<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Shared.ConversationDetailPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F9FFFD" Offset="0.0" />
            <GradientStop Color="#EAF8F5" Offset="0.40" />
            <GradientStop Color="#1ABC9C" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="20,26,20,14">

        <!-- HEADER -->
        <Grid Grid.Row="0" HeightRequest="60">

            <!-- Bouton back (gauche absolu) -->
            <Label Text="←"
           FontSize="16"
           FontAttributes="Bold"
           TextColor="#0B1F1D"
           VerticalOptions="Center"
           HorizontalOptions="Start"
           Margin="10,0,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Back_Tapped" />
                </Label.GestureRecognizers>
            </Label>

            <!-- Centre VRAIMENT centré -->
            <VerticalStackLayout
        HorizontalOptions="Center"
        VerticalOptions="Center"
        Spacing="2">

                <Label Text="✦ SparkWork"
               FontSize="14"
               FontAttributes="Bold"
               TextColor="#1ABC9C"
               HorizontalTextAlignment="Center"/>

                <Label x:Name="lblConversationTitle"
               Text="adel"
               FontSize="22"
               FontAttributes="Bold"
               TextColor="#0B1F1D"
               HorizontalTextAlignment="Center"/>

            </VerticalStackLayout>

        </Grid>

        <!-- MESSAGES -->
        <CollectionView Grid.Row="1"
                        x:Name="conversationCollection"
                        SelectionMode="None"
                        Margin="0,0,0,10">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="0,6">

                        <!-- Message reçu -->
                        <Frame BackgroundColor="White"
                               CornerRadius="18"
                               Padding="12"
                               HasShadow="True"
                               HorizontalOptions="Start"
                               MaximumWidthRequest="260"
                               IsVisible="False">

                            <Frame.Triggers>
                                <DataTrigger TargetType="Frame"
                                             Binding="{Binding IsMine}"
                                             Value="False">
                                    <Setter Property="IsVisible"
                                            Value="True" />
                                </DataTrigger>
                            </Frame.Triggers>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding SenderName}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#1ABC9C" />

                                <Label Text="{Binding Content}"
                                       FontSize="14"
                                       TextColor="#0B1F1D" />

                                <Label Text="{Binding SentAt, StringFormat='{0:HH:mm}'}"
                                       FontSize="11"
                                       TextColor="#8A9A98"
                                       HorizontalTextAlignment="End" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Message envoyé -->
                        <Frame BackgroundColor="#DFF8F3"
                               CornerRadius="18"
                               Padding="12"
                               HasShadow="False"
                               HorizontalOptions="End"
                               MaximumWidthRequest="260"
                               IsVisible="False">

                            <Frame.Triggers>
                                <DataTrigger TargetType="Frame"
                                             Binding="{Binding IsMine}"
                                             Value="True">
                                    <Setter Property="IsVisible"
                                            Value="True" />
                                </DataTrigger>
                            </Frame.Triggers>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Content}"
                                       FontSize="14"
                                       TextColor="#0B1F1D"
                                       HorizontalTextAlignment="End" />

                                <Label Text="{Binding SentAt, StringFormat='{0:HH:mm}'}"
                                       FontSize="11"
                                       TextColor="#6B8F8A"
                                       HorizontalTextAlignment="End" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- INPUT -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="10"
              VerticalOptions="End">

            <Frame Grid.Column="0"
                   BackgroundColor="White"
                   BorderColor="#DCEDE7"
                   CornerRadius="22"
                   Padding="12,8"
                   HasShadow="True">

                <Entry x:Name="editorNewMessage"
                       Placeholder="Write a message..."
                       PlaceholderColor="#9AA9A7"
                       TextColor="#0B1F1D"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center" />
            </Frame>

            <Button Grid.Column="1"
                    Text="➤"
                    FontSize="18"
                    HeightRequest="50"
                    WidthRequest="50"
                    CornerRadius="25"
                    BackgroundColor="#1ABC9C"
                    TextColor="White"
                    FontAttributes="Bold"
                    Clicked="Send_Clicked" />
        </Grid>
    </Grid>
</ContentPage>