<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Shared.ConversationDetailPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="22,26,22,16"
              ColumnDefinitions="Auto,*,Auto">

            <Label Grid.Column="0"
                   Text="←"
                   FontSize="24"
                   TextColor="#111827"
                   VerticalOptions="Center"
                   HorizontalOptions="Start">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Back_Tapped" />
                </Label.GestureRecognizers>
            </Label>

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">

                <Label Text="SparkWork"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#7C4DFF"
                       HorizontalTextAlignment="Center" />

                <Label x:Name="lblConversationTitle"
                       Text="Conversation"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#111827"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Frame Grid.Column="2"
                   WidthRequest="44"
                   HeightRequest="44"
                   CornerRadius="22"
                   Padding="0"
                   HasShadow="False"
                   VerticalOptions="Center">
                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label Text="●"
                       FontSize="16"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>
        </Grid>

        <!-- MESSAGES -->
        <CollectionView Grid.Row="1"
                        x:Name="conversationCollection"
                        SelectionMode="None"
                        Margin="18,18,18,10">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical"
                                   ItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="0,2">

                        <!-- MESSAGE RECU -->
                        <Frame BackgroundColor="White"
                               CornerRadius="18"
                               Padding="12,10"
                               HasShadow="False"
                               HorizontalOptions="Start"
                               MaximumWidthRequest="270"
                               IsVisible="False">

                            <Frame.Triggers>
                                <DataTrigger TargetType="Frame"
                                             Binding="{Binding IsMine}"
                                             Value="False">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </Frame.Triggers>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding SenderName}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#7C4DFF" />

                                <Label Text="{Binding Content}"
                                       FontSize="14"
                                       TextColor="#111827"
                                       LineBreakMode="WordWrap" />

                                <Label Text="{Binding SentAt, StringFormat='{0:HH:mm}'}"
                                       FontSize="10"
                                       TextColor="#8B86A3"
                                       HorizontalTextAlignment="End" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- MESSAGE ENVOYE -->
                        <Frame CornerRadius="18"
                               Padding="12,10"
                               HasShadow="False"
                               HorizontalOptions="End"
                               MaximumWidthRequest="270"
                               IsVisible="False">

                            <Frame.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C4DFF" Offset="0.0" />
                                    <GradientStop Color="#D34C88" Offset="1.0" />
                                </LinearGradientBrush>
                            </Frame.Background>

                            <Frame.Triggers>
                                <DataTrigger TargetType="Frame"
                                             Binding="{Binding IsMine}"
                                             Value="True">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </Frame.Triggers>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Content}"
                                       FontSize="14"
                                       TextColor="White"
                                       LineBreakMode="WordWrap" />

                                <Label Text="{Binding SentAt, StringFormat='{0:HH:mm}'}"
                                       FontSize="10"
                                       TextColor="#F4EFFF"
                                       HorizontalTextAlignment="End" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- INPUT -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="10"
              Padding="18,8,18,18"
              BackgroundColor="#F7F5FC">

            <Frame Grid.Column="0"
                   BackgroundColor="White"
                   CornerRadius="18"
                   Padding="14,6"
                   HasShadow="True">
                <Frame.Shadow>
                    <Shadow Brush="#22000000"
                            Offset="0,8"
                            Radius="18" />
                </Frame.Shadow>

                <Entry x:Name="editorNewMessage"
                       Placeholder="Write a message..."
                       PlaceholderColor="#8B86A3"
                       TextColor="#111827"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center" />
            </Frame>

            <Frame Grid.Column="1"
                   WidthRequest="52"
                   HeightRequest="52"
                   CornerRadius="26"
                   Padding="0"
                   HasShadow="True"
                   VerticalOptions="Center">
                <Frame.Shadow>
                    <Shadow Brush="#457C4DFF"
                            Offset="0,10"
                            Radius="20" />
                </Frame.Shadow>

                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Button Text="➤"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontAttributes="Bold"
                        Clicked="Send_Clicked" />
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
