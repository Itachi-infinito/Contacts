<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Shared.SettingsPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F8F6FF">

    <ScrollView>
        <VerticalStackLayout Padding="28,34,28,28" Spacing="16">

            <!-- HEADER -->
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                <Button Text="‹"
                        WidthRequest="44"
                        HeightRequest="44"
                        FontSize="30"
                        Padding="0"
                        BackgroundColor="White"
                        BorderColor="#DED8F5"
                        BorderWidth="1"
                        TextColor="#7C4DFF"
                        CornerRadius="22"
                        Clicked="Back_Clicked" />

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="Paramètres"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Gérez votre compte et vos préférences"
                           FontSize="13"
                           TextColor="#8B86A3"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Frame Grid.Column="2"
                       WidthRequest="54"
                       HeightRequest="54"
                       CornerRadius="27"
                       Padding="0"
                       HasShadow="False">
                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C4DFF" Offset="0.0" />
                            <GradientStop Color="#D34C88" Offset="1.0" />
                        </LinearGradientBrush>
                    </Frame.Background>
                    <Label x:Name="lblHeaderInitials"
                           Text="ME"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="17"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Frame>
            </Grid>

            <!-- ACCOUNT INTRO -->
            <VerticalStackLayout Spacing="6">
                <Label Text="MON COMPTE"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#7C4DFF" />
                <Label Text="Gère ta session et les préférences de ton compte."
                       FontSize="15"
                       TextColor="#8B86A3" />
            </VerticalStackLayout>

            <!-- ACCOUNT CARD -->
            <Frame CornerRadius="24"
                   Padding="18"
                   BackgroundColor="White"
                   BorderColor="#DED8F5"
                   HasShadow="False">

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Frame WidthRequest="62"
                           HeightRequest="62"
                           CornerRadius="31"
                           Padding="0"
                           HasShadow="False"
                           VerticalOptions="Center">
                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>

                        <Label x:Name="lblAccountInitials"
                               Text="ME"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>

                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                        <Label x:Name="lblCurrentUser"
                               Text="Utilisateur"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label x:Name="lblCurrentRole"
                               Text="Recruteur · Actif"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#7C4DFF" />
                    </VerticalStackLayout>

                    <Frame Grid.Column="2"
                           WidthRequest="44"
                           HeightRequest="44"
                           CornerRadius="22"
                           Padding="0"
                           BackgroundColor="#F0EAFE"
                           HasShadow="False"
                           VerticalOptions="Center">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="EditProfile_Tapped" />
                        </Frame.GestureRecognizers>
                        <Label Text="&#xE3C9;"
                               FontFamily="MaterialIcons"
                               FontSize="22"
                               TextColor="#7C4DFF"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Frame>
                </Grid>
            </Frame>

            <!-- PREFERENCES -->
            <Frame CornerRadius="24" Padding="0" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                <VerticalStackLayout Spacing="0">

                    <Grid Padding="18" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Frame WidthRequest="42" HeightRequest="42" CornerRadius="13" Padding="0" BackgroundColor="#F0EAFE" HasShadow="False">
                            <Label Text="&#xE7F4;" FontFamily="MaterialIcons" FontSize="23" TextColor="#7C4DFF"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <Label Grid.Column="1" Text="Préférences" FontSize="20" FontAttributes="Bold"
                               TextColor="#111827" VerticalTextAlignment="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EEEAF8" />

                    <Grid Padding="18,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Frame WidthRequest="42" HeightRequest="42" CornerRadius="13" Padding="0" BackgroundColor="#F0EAFE" HasShadow="False">
                            <Label Text="&#xE7F4;" FontFamily="MaterialIcons" FontSize="22" TextColor="#7C4DFF"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Notifications" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Recevoir les alertes de match et de message." FontSize="13" TextColor="#8B86A3" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="2" IsToggled="True" OnColor="#D34C88" ThumbColor="White" VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EEEAF8" />

                    <Grid Padding="18,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Frame WidthRequest="42" HeightRequest="42" CornerRadius="13" Padding="0" BackgroundColor="#DCFCE7" HasShadow="False">
                            <Label Text="&#xE8F4;" FontFamily="MaterialIcons" FontSize="22" TextColor="#16A34A"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Profil visible" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Autoriser l'affichage dans la découverte." FontSize="13" TextColor="#8B86A3" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="2" IsToggled="True" OnColor="#D34C88" ThumbColor="White" VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EEEAF8" />

                    <Grid Padding="18,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Frame WidthRequest="42" HeightRequest="42" CornerRadius="13" Padding="0" BackgroundColor="#FCE7F3" HasShadow="False">
                            <Label Text="&#xE87D;" FontFamily="MaterialIcons" FontSize="22" TextColor="#D34C88"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Notifications de match" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Être notifié en temps réel lors d'un match." FontSize="13" TextColor="#8B86A3" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="2" IsToggled="True" OnColor="#D34C88" ThumbColor="White" VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EEEAF8" />

                    <Grid Padding="18,14" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                        <Frame WidthRequest="42" HeightRequest="42" CornerRadius="13" Padding="0" BackgroundColor="#FEF3C7" HasShadow="False">
                            <Label Text="&#xE894;" FontFamily="MaterialIcons" FontSize="22" TextColor="#D97706"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Langue" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Langue de l'interface." FontSize="13" TextColor="#8B86A3" />
                        </VerticalStackLayout>
                        <Frame Grid.Column="2" CornerRadius="12" Padding="12,4" BackgroundColor="#F0EAFE" HasShadow="False" VerticalOptions="Center">
                            <Label Text="Français" FontSize="13" FontAttributes="Bold" TextColor="#7C4DFF" />
                        </Frame>
                        <Label Grid.Column="3" Text="›" FontSize="24" TextColor="#B0ABCE" VerticalTextAlignment="Center" />
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- CONFIDENTIALITE -->
            <Frame CornerRadius="24" Padding="0" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                <VerticalStackLayout Spacing="0">
                    <Grid Padding="18" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Frame WidthRequest="42" HeightRequest="42" CornerRadius="13" Padding="0" BackgroundColor="#DCFCE7" HasShadow="False">
                            <Label Text="&#xE9E0;" FontFamily="MaterialIcons" FontSize="23" TextColor="#16A34A"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <Label Grid.Column="1" Text="Confidentialité" FontSize="20" FontAttributes="Bold"
                               TextColor="#111827" VerticalTextAlignment="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EEEAF8" />

                    <Grid Padding="18,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Frame WidthRequest="42" HeightRequest="42" CornerRadius="13" Padding="0" BackgroundColor="#DCFCE7" HasShadow="False">
                            <Label Text="&#xE897;" FontFamily="MaterialIcons" FontSize="22" TextColor="#16A34A"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Changer le mot de passe" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Modifier vos identifiants de connexion." FontSize="13" TextColor="#8B86A3" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="24" TextColor="#B0ABCE" VerticalTextAlignment="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EEEAF8" />

                    <Grid Padding="18,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Frame WidthRequest="42" HeightRequest="42" CornerRadius="13" Padding="0" BackgroundColor="#FEF3C7" HasShadow="False">
                            <Label Text="&#xE0BE;" FontFamily="MaterialIcons" FontSize="22" TextColor="#D97706"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Email" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                            <Label x:Name="lblCurrentEmail" Text="email@example.com" FontSize="13" TextColor="#8B86A3" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="24" TextColor="#B0ABCE" VerticalTextAlignment="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EEEAF8" />

                    <Grid Padding="18,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Frame WidthRequest="42" HeightRequest="42" CornerRadius="13" Padding="0" BackgroundColor="#F0EAFE" HasShadow="False">
                            <Label Text="&#xE873;" FontFamily="MaterialIcons" FontSize="22" TextColor="#7C4DFF"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Conditions d'utilisation" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Consulter les CGU de SparkWork." FontSize="13" TextColor="#8B86A3" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="24" TextColor="#B0ABCE" VerticalTextAlignment="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- SUPPORT -->
            <Frame CornerRadius="24" Padding="0" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                <VerticalStackLayout Spacing="0">
                    <Grid Padding="18" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Frame WidthRequest="42" HeightRequest="42" CornerRadius="13" Padding="0" BackgroundColor="#FCE7F3" HasShadow="False">
                            <Label Text="&#xE887;" FontFamily="MaterialIcons" FontSize="23" TextColor="#D34C88"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <Label Grid.Column="1" Text="Support" FontSize="20" FontAttributes="Bold" TextColor="#111827" VerticalTextAlignment="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EEEAF8" />

                    <Grid Padding="18,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Frame WidthRequest="42" HeightRequest="42" CornerRadius="13" Padding="0" BackgroundColor="#FCE7F3" HasShadow="False">
                            <Label Text="&#xE0BF;" FontFamily="MaterialIcons" FontSize="22" TextColor="#D34C88"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Contacter le support" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Signaler un problème ou poser une question." FontSize="13" TextColor="#8B86A3" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="24" TextColor="#B0ABCE" VerticalTextAlignment="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EEEAF8" />

                    <Grid Padding="18,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Frame WidthRequest="42" HeightRequest="42" CornerRadius="13" Padding="0" BackgroundColor="#FEF3C7" HasShadow="False">
                            <Label Text="&#xE838;" FontFamily="MaterialIcons" FontSize="22" TextColor="#D97706"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Noter l'application" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="Donnez-nous votre avis sur le store." FontSize="13" TextColor="#8B86A3" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="24" TextColor="#B0ABCE" VerticalTextAlignment="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- SECURITY -->
            <Frame CornerRadius="24" Padding="18" BackgroundColor="White" BorderColor="#DED8F5" HasShadow="False">
                <VerticalStackLayout Spacing="14">
                    <HorizontalStackLayout Spacing="12">
                        <Frame WidthRequest="42" HeightRequest="42" CornerRadius="13" Padding="0" BackgroundColor="#FFF1F2" HasShadow="False">
                            <Label Text="&#xE002;" FontFamily="MaterialIcons" FontSize="23" TextColor="#EF4444"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <Label Text="Sécurité" FontSize="20" FontAttributes="Bold" TextColor="#111827" VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>

                    <Button Text="↪  Se déconnecter"
                            HeightRequest="58"
                            BackgroundColor="#F0EAFE"
                            TextColor="#7C4DFF"
                            FontAttributes="Bold"
                            FontSize="17"
                            CornerRadius="29"
                            Clicked="Logout_Clicked" />

                    <Button Text="🗑  Supprimer le compte"
                            HeightRequest="58"
                            BackgroundColor="#FFF1F4"
                            BorderColor="#F7C8D4"
                            BorderWidth="1"
                            TextColor="#EF4444"
                            FontAttributes="Bold"
                            FontSize="17"
                            CornerRadius="29"
                            Clicked="DeleteAccount_Clicked" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="SparkWork · Version 1.0"
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="#B0ABCE"
                   HorizontalTextAlignment="Center"
                   Margin="0,8,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
