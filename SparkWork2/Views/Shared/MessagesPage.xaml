<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Shared.MessagesPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto,*"
              RowSpacing="18"
              Padding="24,28,24,16">

            <!-- HEADER -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto">

                <VerticalStackLayout Spacing="4">
                    <Label Text="Messages"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <Label Text="Retrouvez vos conversations récentes"
                           FontSize="13"
                           TextColor="#8B86A3" />
                </VerticalStackLayout>

                <Frame Grid.Column="1"
                       WidthRequest="52"
                       HeightRequest="52"
                       CornerRadius="26"
                       Padding="0"
                       HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Profile_Tapped" />
                    </Frame.GestureRecognizers>

                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C4DFF" Offset="0.0" />
                            <GradientStop Color="#D34C88" Offset="1.0" />
                        </LinearGradientBrush>
                    </Frame.Background>

                    <Label x:Name="lblHeaderInitials"
                           Text="ME"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="16"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Frame>
            </Grid>

            <!-- SEARCH -->
            <Frame Grid.Row="1"
                   CornerRadius="18"
                   Padding="14"
                   BackgroundColor="White"
                   BorderColor="#EEEAF8"
                   HasShadow="False">

                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">

                    <Label Text="⌕"
                           FontSize="18"
                           TextColor="#8B86A3"
                           VerticalTextAlignment="Center" />

                    <Label Grid.Column="1"
                           Text="Rechercher une conversation..."
                           FontSize="13"
                           TextColor="#A6A0C0"
                           VerticalTextAlignment="Center" />
                </Grid>
            </Frame>

            <!-- CONVERSATIONS -->
            <CollectionView Grid.Row="2"
                            x:Name="messagesCollection"
                            SelectionMode="None">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                                       ItemSpacing="12" />
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="14"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">

                        <Frame WidthRequest="76"
                               HeightRequest="76"
                               CornerRadius="38"
                               Padding="0"
                               BackgroundColor="#F0EAFE"
                               HasShadow="False">

                            <Label Text="✉"
                                   FontSize="34"
                                   TextColor="#7C4DFF"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>

                        <Label Text="Aucune conversation"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               HorizontalTextAlignment="Center" />

                        <Label Text="Vos messages apparaîtront ici."
                               FontSize="13"
                               TextColor="#8B86A3"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>

                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItemView>
                                        <Grid WidthRequest="118"
                                              ColumnDefinitions="*,*"
                                              ColumnSpacing="8"
                                              VerticalOptions="Center">

                                            <Frame Grid.Column="0"
                                                   WidthRequest="48"
                                                   HeightRequest="48"
                                                   CornerRadius="24"
                                                   Padding="0"
                                                   Scale="0.92"
                                                   BackgroundColor="#F0EAFE"
                                                   HasShadow="False"
                                                   BindingContext="{Binding .}"
                                                   Loaded="SwipeBubble_Loaded">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="ConversationBubble_Tapped" />
                                                </Frame.GestureRecognizers>

                                                <Label Text="✉"
                                                       FontSize="18"
                                                       TextColor="#7C4DFF"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Frame>

                                            <Frame Grid.Column="1"
                                                   WidthRequest="48"
                                                   HeightRequest="48"
                                                   CornerRadius="24"
                                                   Padding="0"
                                                   Scale="0.92"
                                                   BackgroundColor="#FFF1F4"
                                                   HasShadow="False"
                                                   BindingContext="{Binding .}"
                                                   Loaded="SwipeBubble_Loaded">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="DeleteBubble_Tapped" />
                                                </Frame.GestureRecognizers>

                                                <Label Text="×"
                                                       FontSize="24"
                                                       TextColor="#EF4D7A"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Frame>
                                        </Grid>
                                    </SwipeItemView>
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Frame CornerRadius="22"
                                   Padding="14"
                                   BackgroundColor="White"
                                   BorderColor="#EEEAF8"
                                   HasShadow="False"
                                   Opacity="0"
                                   TranslationY="12"
                                   Scale="0.985"
                                   Loaded="MessageCard_Loaded">

                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="Message_Tapped"
                                                          CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>

                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="12">

                                    <Frame WidthRequest="54"
                                           HeightRequest="54"
                                           CornerRadius="27"
                                           Padding="0"
                                           HasShadow="False"
                                           VerticalOptions="Center">

                                        <Frame.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                                <GradientStop Color="#D34C88" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Frame.Background>

                                        <Label Text="{Binding ParticipantName, StringFormat='{0}'}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="White"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               MaxLines="1" />
                                    </Frame>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="3"
                                                         VerticalOptions="Center">

                                        <Label Text="{Binding ParticipantName}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="#111827"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />

                                        <Label Text="{Binding LastMessage}"
                                               FontSize="13"
                                               TextColor="#5F5A75"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2"
                                                         Spacing="5"
                                                         VerticalOptions="Center"
                                                         HorizontalOptions="End">

                                        <Label Text="{Binding LastMessageDate, StringFormat='{0:HH:mm}'}"
                                               FontSize="12"
                                               TextColor="#8B86A3"
                                               HorizontalTextAlignment="End" />

                                        <Ellipse WidthRequest="8"
                                                 HeightRequest="8"
                                                 Fill="#7C4DFF"
                                                 HorizontalOptions="End" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- CANDIDATE NAV -->
        <Grid x:Name="candidateBottomNav"
              Grid.Row="1"
              BackgroundColor="White"
              Padding="18,8,18,18"
              ColumnDefinitions="*,*,*,*">

            <Button Text="Accueil"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Home_Clicked" />

            <Button Grid.Column="1"
                    Text="Découvrir"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Discover_Clicked" />

            <Button Grid.Column="2"
                    Text="Messages"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#7C4DFF" />

            <Button Grid.Column="3"
                    Text="Profil"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Profile_Clicked" />
        </Grid>

        <!-- RECRUITER NAV -->
        <Grid x:Name="recruiterBottomNav"
              Grid.Row="1"
              IsVisible="False"
              BackgroundColor="White"
              Padding="18,8,18,18"
              ColumnDefinitions="*,*,Auto,*,*">

            <Button Text="Accueil"
                    Grid.Column="0"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Home_Clicked" />

            <Button Grid.Column="1"
                    Text="Découvrir"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Discover_Clicked" />

            <Frame Grid.Column="2"
                   WidthRequest="50"
                   HeightRequest="50"
                   CornerRadius="25"
                   Padding="0"
                   BackgroundColor="#7C4DFF"
                   HasShadow="True"
                   Margin="8,0">
                <Frame.Shadow>
                    <Shadow Brush="#557C4DFF"
                            Offset="0,8"
                            Radius="18" />
                </Frame.Shadow>

                <Button Text="+"
                        FontSize="24"
                        FontAttributes="Bold"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        Clicked="AddOffer_Clicked" />
            </Frame>

            <Button Grid.Column="3"
                    Text="Messages"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#7C4DFF" />

            <Button Grid.Column="4"
                    Text="Profil"
                    FontSize="11"
                    BackgroundColor="Transparent"
                    TextColor="#8B86A3"
                    Clicked="Profile_Clicked" />
        </Grid>
    </Grid>
</ContentPage>
