<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Shared.MessagesPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto,*"
              RowSpacing="14"
              Padding="28,34,28,0">


            <!-- HEADER -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  Padding="0">



                <VerticalStackLayout Spacing="4">
                    <Label Text="Messages"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <Label Text="Retrouvez vos conversations récentes"
                           FontSize="13"
                           TextColor="#8B86A3" />
                </VerticalStackLayout>

                <Frame Grid.Column="1"
                       WidthRequest="52"
                       HeightRequest="52"
                       CornerRadius="26"
                       Padding="0"
                       HasShadow="False"
                       VerticalOptions="Center">
                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C4DFF" Offset="0.0" />
                            <GradientStop Color="#D34C88" Offset="1.0" />
                        </LinearGradientBrush>
                    </Frame.Background>

                    <Label x:Name="lblInitials"
                           Text="M"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="18"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Frame>
            </Grid>

            <!-- SEARCH -->
            <Frame Grid.Row="1"
                   HeightRequest="48"
                   CornerRadius="16"
                   Padding="16,0"
                   Margin="0"
                   BackgroundColor="#F8F6FF"
                   BorderColor="#DED8F5"
                   HasShadow="False">


                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label Text="&#xE8B6;"
                           FontFamily="MaterialIcons"
                           FontSize="20"
                           TextColor="#8B86A3"
                           VerticalTextAlignment="Center" />

                    <Label Grid.Column="1"
                           Text="Rechercher une conversation..."
                           FontSize="14"
                           TextColor="#A6A0C0"
                           VerticalTextAlignment="Center" />
                </Grid>
            </Frame>


            <!-- CONVERSATIONS -->
            <Grid Grid.Row="2">

                <CollectionView x:Name="messagesCollection"
                                IsVisible="False"
                                SelectionMode="None"
                                Margin="0,18,0,12">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                               ItemSpacing="12" />
                    </CollectionView.ItemsLayout>

                    <!-- Garde ici ton ItemTemplate actuel -->
                </CollectionView>

                <VerticalStackLayout x:Name="emptyStateLayout"
                                     IsVisible="False"
                                     Spacing="18"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Fill"
                                     Margin="0,-18,0,0">

                    <!-- ILLUSTRATION -->
                    <Grid WidthRequest="230"
                          HeightRequest="190"
                          HorizontalOptions="Center">

                        <Ellipse WidthRequest="136"
                                 HeightRequest="136"
                                 Fill="#F0EAFE"
                                 Opacity="0.85"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center" />

                        <Ellipse WidthRequest="158"
                                 HeightRequest="158"
                                 Stroke="#CFC4FF"
                                 StrokeThickness="1.6"
                                 StrokeDashArray="6,5"
                                 Fill="Transparent"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center" />

                        <Border WidthRequest="58"
                                HeightRequest="40"
                                Stroke="#DED8F5"
                                StrokeThickness="1"
                                BackgroundColor="White"
                                HorizontalOptions="Start"
                                VerticalOptions="Start"
                                Margin="36,46,0,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13" />
                            </Border.StrokeShape>
                            <Label Text="•••"
                                   FontSize="20"
                                   TextColor="#C4B5FD"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>

                        <Border WidthRequest="72"
                                HeightRequest="46"
                                StrokeThickness="0"
                                HorizontalOptions="End"
                                VerticalOptions="Center"
                                Margin="0,36,26,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C4DFF" Offset="0.0" />
                                    <GradientStop Color="#D34C88" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Text="•••"
                                   FontSize="20"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>

                        <Frame WidthRequest="72"
                               HeightRequest="72"
                               CornerRadius="36"
                               Padding="0"
                               BackgroundColor="White"
                               HasShadow="True"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
                            <Frame.Shadow>
                                <Shadow Brush="#18000000"
                                        Offset="0,10"
                                        Radius="18"
                                        Opacity="1" />
                            </Frame.Shadow>

                            <Label Text="&#xE0BE;"
                                   FontFamily="MaterialIcons"
                                   FontSize="34"
                                   TextColor="#B13CC7"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>
                    </Grid>

                    <!-- TEXTES -->
                    <VerticalStackLayout Spacing="10"
                                         HorizontalOptions="Center"
                                         Margin="0,-4,0,0">

                        <Label Text="Aucune conversation"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#17172A"
                               HorizontalTextAlignment="Center" />

                        <Label Text="Vos échanges avec les candidats apparaîtront ici après un match mutuel."
                               WidthRequest="300"
                               FontSize="15"
                               LineHeight="1.25"
                               TextColor="#8B86A3"
                               LineBreakMode="WordWrap"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <!-- CTA -->
                    <Frame HeightRequest="62"
                           CornerRadius="31"
                           Padding="0"
                           HasShadow="True"
                           Margin="18,18,18,0"
                           HorizontalOptions="Fill">
                        <Frame.Shadow>
                            <Shadow Brush="#307C4DFF"
                                    Offset="0,10"
                                    Radius="18"
                                    Opacity="1" />
                        </Frame.Shadow>

                        <Frame.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0.0" />
                                <GradientStop Color="#D34C88" Offset="1.0" />
                            </LinearGradientBrush>
                        </Frame.Background>

                        <Grid>
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="12"
                                  Padding="28,0"
                                  VerticalOptions="Center">

                                <Label Text="&#xE8B6;"
                                       FontFamily="MaterialIcons"
                                       FontSize="24"
                                       TextColor="White"
                                       VerticalTextAlignment="Center" />

                                <Label Grid.Column="1"
                                       Text="Découvrir des candidats"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Grid>

                            <Button BackgroundColor="Transparent"
                                    Text=""
                                    Clicked="DiscoverCandidates_Clicked" />
                        </Grid>

                    </Frame>

                    <Label Text="• Un match = une conversation débloquée •"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#B0ABCE"
                           HorizontalTextAlignment="Center" />

                </VerticalStackLayout>
            </Grid>

        </Grid>

        <Grid x:Name="recruiterBottomNav"
                Grid.Row="1"
                HeightRequest="78"
                BackgroundColor="White"
                Padding="4,8,4,10"
                ColumnDefinitions="*,*,*,*,*"
                IsVisible="False">


            <BoxView Grid.ColumnSpan="5"
                     HeightRequest="0.5"
                     Color="#E5E0F5"
                     VerticalOptions="Start" />

            <VerticalStackLayout Grid.Column="0"
                                 HorizontalOptions="Center"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Home_Nav_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="&#xE88A;"
                       FontFamily="MaterialIcons"
                       FontSize="24"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
                <Label Text="Accueil"
                       FontSize="9"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1"
                                 HorizontalOptions="Center"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Discover_Nav_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="&#xE8B6;"
                       FontFamily="MaterialIcons"
                       FontSize="24"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
                <Label Text="Découvrir"
                       FontSize="9"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Border Grid.Column="2"
                    WidthRequest="46"
                    HeightRequest="46"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="23" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Add_Nav_Tapped" />
                </Border.GestureRecognizers>
                <Label Text="+"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>

            <VerticalStackLayout Grid.Column="3"
                         HorizontalOptions="Center"
                         Spacing="2"
                         VerticalOptions="Center">
                <Label Text="&#xE0BF;"
                       FontFamily="MaterialIcons"
                       FontSize="24"
                       TextColor="#7C4DFF"
                       HorizontalTextAlignment="Center" />
                <Label Text="Messages"
                       FontSize="9"
                       TextColor="#7C4DFF"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
                <BoxView HeightRequest="4"
                         WidthRequest="4"
                         Color="#7C4DFF"
                         CornerRadius="2"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4"
                                 HorizontalOptions="Center"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Profile_Nav_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="&#xE7FD;"
                       FontFamily="MaterialIcons"
                       FontSize="24"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
                <Label Text="Profil"
                       FontSize="9"
                       TextColor="#b0a8cc"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>
        <!-- CANDIDATE NAV -->
        <Grid x:Name="candidateBottomNav"
              Grid.Row="1"
              BackgroundColor="White"
              Padding="18,8,18,18"
              ColumnDefinitions="*,*,*,*"
              IsVisible="False">

            <Grid Grid.Column="0">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="&#xE88A;" FontFamily="MaterialIcons" FontSize="25" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                    <Label Text="Accueil" FontSize="11" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <Button Text="" BackgroundColor="Transparent" Clicked="Home_Clicked" />
            </Grid>

            <Grid Grid.Column="1">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="&#xE8B6;" FontFamily="MaterialIcons" FontSize="25" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                    <Label Text="Découvrir" FontSize="11" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <Button Text="" BackgroundColor="Transparent" Clicked="Discover_Clicked" />
            </Grid>

            <Grid Grid.Column="2">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="&#xE0BF;" FontFamily="MaterialIcons" FontSize="25" TextColor="#7C4DFF" HorizontalTextAlignment="Center" />
                    <Label Text="Messages" FontSize="11" FontAttributes="Bold" TextColor="#7C4DFF" HorizontalTextAlignment="Center" />
                    <BoxView WidthRequest="4" HeightRequest="4" CornerRadius="2" Color="#7C4DFF" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>

            <Grid Grid.Column="3">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="&#xE7FD;" FontFamily="MaterialIcons" FontSize="25" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                    <Label Text="Profil" FontSize="11" TextColor="#B0ABCE" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <Button Text="" BackgroundColor="Transparent" Clicked="Profile_Clicked" />
            </Grid>
        </Grid>


    </Grid>
</ContentPage>
