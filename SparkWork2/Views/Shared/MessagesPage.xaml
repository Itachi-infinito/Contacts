<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Shared.MessagesPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="28,26,28,0"
              RowDefinitions="Auto,Auto"
              ColumnDefinitions="*,Auto">

            <Label Text="SparkWork"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#7C4DFF"
                   VerticalOptions="Center" />

            <Frame Grid.Column="1"
                   HeightRequest="54"
                   WidthRequest="54"
                   CornerRadius="27"
                   Padding="0"
                   HasShadow="False"
                   HorizontalOptions="End"
                   VerticalOptions="Center">
                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C4DFF" Offset="0.0" />
                        <GradientStop Color="#D34C88" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <Label Text="ME"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="16"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Frame>

            <Grid Grid.Row="1"
                  Grid.ColumnSpan="2"
                  ColumnDefinitions="*,*,*"
                  Margin="0,24,0,0"
                  HeightRequest="42">

                <Label Text="DÉCOUVRIR"
                       Grid.Column="0"
                       FontSize="15"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Discover_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="MESSAGES"
                       Grid.Column="1"
                       FontSize="15"
                       TextColor="#7C4DFF"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />

                <Label Text="STATS"
                       Grid.Column="2"
                       FontSize="15"
                       TextColor="#8B86A3"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Stats_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <BoxView Grid.Column="1"
                         HeightRequest="3"
                         Color="#7C4DFF"
                         VerticalOptions="End"
                         Margin="14,0,14,0" />
            </Grid>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1"
              RowDefinitions="Auto,*"
              Padding="28,34,28,20">

            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  Margin="0,0,0,18">

                <Label Text="Conversations"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#111827"
                       VerticalOptions="Center" />

                <Frame Grid.Column="1"
                       BackgroundColor="#7C4DFF"
                       CornerRadius="16"
                       Padding="12,4"
                       HasShadow="False"
                       VerticalOptions="Center">
                    <Label Text="new"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="White" />
                </Frame>
            </Grid>

            <CollectionView Grid.Row="1"
                            x:Name="messagesCollection"
                            SelectionMode="None">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                                       ItemSpacing="14" />
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="14"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">

                        <Frame WidthRequest="76"
                               HeightRequest="76"
                               CornerRadius="38"
                               Padding="0"
                               BackgroundColor="#F0EAFE"
                               HasShadow="False">
                            <Label Text="💬"
                                   FontSize="34"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>

                        <Label Text="No conversations yet"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               HorizontalTextAlignment="Center" />

                        <Label Text="Your messages will appear here."
                               FontSize="13"
                               TextColor="#8B86A3"
                               HorizontalTextAlignment="Center" />

                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>

                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItemView>
                                        <Grid WidthRequest="130"
                                              ColumnDefinitions="*,*"
                                              ColumnSpacing="10"
                                              VerticalOptions="Center">

                                            <Frame Grid.Column="0"
                                                   WidthRequest="50"
                                                   HeightRequest="50"
                                                   CornerRadius="25"
                                                   Padding="0"
                                                   BackgroundColor="#F0EAFE"
                                                   HasShadow="False"
                                                   BindingContext="{Binding .}"
                                                   Loaded="SwipeBubble_Loaded">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="ConversationBubble_Tapped" />
                                                </Frame.GestureRecognizers>

                                                <Label Text="✉"
                                                       FontSize="20"
                                                       TextColor="#7C4DFF"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Frame>

                                            <Frame Grid.Column="1"
                                                   WidthRequest="50"
                                                   HeightRequest="50"
                                                   CornerRadius="25"
                                                   Padding="0"
                                                   BackgroundColor="#FFF1F4"
                                                   HasShadow="False"
                                                   BindingContext="{Binding .}"
                                                   Loaded="SwipeBubble_Loaded">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="DeleteBubble_Tapped" />
                                                </Frame.GestureRecognizers>

                                                <Label Text="×"
                                                       FontSize="24"
                                                       TextColor="#EF4D7A"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Frame>
                                        </Grid>
                                    </SwipeItemView>
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Grid Padding="4,14"
                                  ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="14"
                                  Loaded="MessageCard_Loaded"
                                  Opacity="0"
                                  TranslationY="12"
                                  Scale="0.985">

                                <Frame Grid.Column="0"
                                       WidthRequest="58"
                                       HeightRequest="58"
                                       CornerRadius="29"
                                       Padding="0"
                                       HasShadow="False"
                                       VerticalOptions="Center">
                                    <Frame.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#7C4DFF" Offset="0.0" />
                                            <GradientStop Color="#D34C88" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Frame.Background>

                                    <Grid>
                                        <Ellipse WidthRequest="34"
                                                 HeightRequest="34"
                                                 Fill="White"
                                                 Opacity="0.45"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Margin="0,-12,0,0" />

                                        <Ellipse WidthRequest="48"
                                                 HeightRequest="26"
                                                 Fill="White"
                                                 Opacity="0.30"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="End"
                                                 Margin="0,0,0,8" />
                                    </Grid>
                                </Frame>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="3"
                                                     VerticalOptions="Center">

                                    <Label Text="{Binding ParticipantName}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#111827"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1" />

                                    <Label Text="{Binding LastMessage}"
                                           FontSize="14"
                                           TextColor="#5F5A75"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="2"
                                                     Spacing="4"
                                                     VerticalOptions="Center"
                                                     HorizontalOptions="End">

                                    <Label Text="{Binding LastMessageDate, StringFormat='{0:HH:mm}'}"
                                           FontSize="13"
                                           TextColor="#111827"
                                           HorizontalTextAlignment="End" />

                                    <Ellipse WidthRequest="8"
                                             HeightRequest="8"
                                             Fill="#7C4DFF"
                                             HorizontalOptions="End" />
                                </VerticalStackLayout>

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="Message_Tapped"
                                                          CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
