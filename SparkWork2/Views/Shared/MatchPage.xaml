<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SparkWork2.Views.Shared.MatchPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5FC">

    <Grid x:Name="RootGrid"
          Padding="24"
          RowDefinitions="Auto,*,Auto">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.0" />
                <GradientStop Color="#F7F5FC" Offset="0.45" />
                <GradientStop Color="#EDE7FF" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- CONFETTIS -->
        <AbsoluteLayout Grid.RowSpan="3"
                        InputTransparent="True">

            <BoxView x:Name="confetti1" WidthRequest="10" HeightRequest="18" Color="#7C4DFF" CornerRadius="2" AbsoluteLayout.LayoutBounds="0.08,0.02,10,18" AbsoluteLayout.LayoutFlags="PositionProportional" />
            <BoxView x:Name="confetti2" WidthRequest="12" HeightRequest="12" Color="#D34C88" CornerRadius="2" AbsoluteLayout.LayoutBounds="0.18,0.05,12,12" AbsoluteLayout.LayoutFlags="PositionProportional" />
            <BoxView x:Name="confetti3" WidthRequest="8" HeightRequest="20" Color="#49C390" CornerRadius="2" AbsoluteLayout.LayoutBounds="0.30,0.03,8,20" AbsoluteLayout.LayoutFlags="PositionProportional" />
            <BoxView x:Name="confetti4" WidthRequest="10" HeightRequest="16" Color="#A78BFA" CornerRadius="2" AbsoluteLayout.LayoutBounds="0.42,0.04,10,16" AbsoluteLayout.LayoutFlags="PositionProportional" />
            <BoxView x:Name="confetti5" WidthRequest="14" HeightRequest="10" Color="#EF4D7A" CornerRadius="2" AbsoluteLayout.LayoutBounds="0.56,0.02,14,10" AbsoluteLayout.LayoutFlags="PositionProportional" />
            <BoxView x:Name="confetti6" WidthRequest="9" HeightRequest="18" Color="#7C4DFF" CornerRadius="2" AbsoluteLayout.LayoutBounds="0.68,0.06,9,18" AbsoluteLayout.LayoutFlags="PositionProportional" />
            <BoxView x:Name="confetti7" WidthRequest="11" HeightRequest="14" Color="#D34C88" CornerRadius="2" AbsoluteLayout.LayoutBounds="0.80,0.03,11,14" AbsoluteLayout.LayoutFlags="PositionProportional" />
            <BoxView x:Name="confetti8" WidthRequest="10" HeightRequest="18" Color="#49C390" CornerRadius="2" AbsoluteLayout.LayoutBounds="0.90,0.05,10,18" AbsoluteLayout.LayoutFlags="PositionProportional" />

            <BoxView x:Name="confetti9" WidthRequest="10" HeightRequest="18" Color="#A78BFA" CornerRadius="2" AbsoluteLayout.LayoutBounds="0.12,0.10,10,18" AbsoluteLayout.LayoutFlags="PositionProportional" />
            <BoxView x:Name="confetti10" WidthRequest="12" HeightRequest="12" Color="#EF4D7A" CornerRadius="2" AbsoluteLayout.LayoutBounds="0.25,0.11,12,12" AbsoluteLayout.LayoutFlags="PositionProportional" />
            <BoxView x:Name="confetti11" WidthRequest="8" HeightRequest="20" Color="#7C4DFF" CornerRadius="2" AbsoluteLayout.LayoutBounds="0.50,0.10,8,20" AbsoluteLayout.LayoutFlags="PositionProportional" />
            <BoxView x:Name="confetti12" WidthRequest="14" HeightRequest="10" Color="#D34C88" CornerRadius="2" AbsoluteLayout.LayoutBounds="0.75,0.09,14,10" AbsoluteLayout.LayoutFlags="PositionProportional" />
        </AbsoluteLayout>

        <!-- TOP -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="4"
                             Margin="0,20,0,0"
                             HorizontalOptions="Center">

            <Label x:Name="lblBrand"
                   Text="SparkWork"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#7C4DFF"
                   HorizontalTextAlignment="Center"
                   Opacity="0" />

            <Label Text="Nouveau match"
                   FontSize="14"
                   TextColor="#8581A6"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- CENTER -->
        <VerticalStackLayout Grid.Row="1"
                             Spacing="18"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">

            <Label x:Name="lblCongrats"
                   Text="C'est un match !"
                   FontSize="36"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   HorizontalTextAlignment="Center"
                   Opacity="0"
                   Scale="0.8" />

            <Label x:Name="lblMatchText"
                   Text="Vous vous êtes mutuellement likés."
                   FontSize="15"
                   TextColor="#8581A6"
                   HorizontalTextAlignment="Center"
                   Opacity="0" />

            <Frame x:Name="matchCard"
                   BackgroundColor="White"
                   BorderColor="#EEEAF8"
                   CornerRadius="28"
                   Padding="24"
                   HasShadow="False"
                   WidthRequest="300"
                   Opacity="0"
                   TranslationY="30">

                <VerticalStackLayout Spacing="16"
                                     HorizontalOptions="Center">

                    <Grid WidthRequest="132"
                          HeightRequest="132">

                        <Frame WidthRequest="132"
                               HeightRequest="132"
                               CornerRadius="66"
                               Padding="0"
                               HasShadow="False">
                            <Frame.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C4DFF" Offset="0.0" />
                                    <GradientStop Color="#D34C88" Offset="1.0" />
                                </LinearGradientBrush>
                            </Frame.Background>

                            <Label x:Name="lblParticipantInitials"
                                   Text="?"
                                   FontSize="36"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>

                        <Frame WidthRequest="42"
                               HeightRequest="42"
                               CornerRadius="21"
                               Padding="0"
                               BackgroundColor="White"
                               HasShadow="False"
                               HorizontalOptions="End"
                               VerticalOptions="End">
                            <Label Text="♥"
                                   FontSize="22"
                                   TextColor="#EF4D7A"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>
                    </Grid>

                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="lblParticipantName"
                               Text="Nom"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               HorizontalTextAlignment="Center" />

                        <Label Text="Vous pouvez maintenant démarrer une conversation."
                               FontSize="14"
                               TextColor="#8581A6"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>

        <!-- ACTIONS -->
        <VerticalStackLayout Grid.Row="2"
                             Spacing="12"
                             Margin="0,0,0,20">

            <Button x:Name="btnMessage"
                    Text="Envoyer un message"
                    HeightRequest="52"
                    BackgroundColor="#7C4DFF"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="14"
                    Clicked="SendMessage_Clicked"
                    Opacity="0" />

            <Button x:Name="btnKeepSwiping"
                    Text="Continuer à découvrir"
                    HeightRequest="52"
                    BackgroundColor="White"
                    BorderColor="#DED8F5"
                    BorderWidth="1"
                    TextColor="#111827"
                    FontAttributes="Bold"
                    CornerRadius="14"
                    Clicked="KeepSwiping_Clicked"
                    Opacity="0" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
